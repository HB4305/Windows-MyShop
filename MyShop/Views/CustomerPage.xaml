<Page x:Class="MyShop.Views.CustomerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:m="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <SolidColorBrush x:Key="AppPurpleBrush" Color="#8B52FF"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    </Page.Resources>

    <Grid Margin="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header & Search -->
        <Grid Grid.Row="0" ColumnSpacing="14" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0"
                    MinHeight="48"
                    VerticalAlignment="Stretch"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                    BorderThickness="1"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="12,8">
                <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondary}" VerticalAlignment="Center"/>
                    <TextBox x:Name="SearchBox"
                             Grid.Column="1"
                             PlaceholderText="Search customer name or phone..."
                             Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                             KeyDown="OnSearchKeyDown"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0,6"
                             VerticalAlignment="Center"/>
                    <Button Grid.Column="2"
                            Content="&#xE721;"
                            FontFamily="Segoe MDL2 Assets"
                            Command="{Binding SearchCommand}"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="8"
                            Foreground="{StaticResource AppPurpleBrush}"
                            ToolTipService.ToolTip="Search"/>
                </Grid>
            </Border>

            <Button Grid.Column="1"
                    Background="{StaticResource AppPurpleBrush}"
                    Foreground="White"
                    CornerRadius="{ThemeResource ControlCornerRadius}"
                    Padding="16,10"
                    MinHeight="48"
                    Click="OnAddCustomerClick">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <FontIcon Glyph="&#xE710;" FontSize="15" Foreground="White"/>
                    <TextBlock Text="New Customer" VerticalAlignment="Center" FontWeight="SemiBold"/>
                </StackPanel>
            </Button>
        </Grid>

        <Rectangle Grid.Row="1" Height="1" Margin="0,0,0,20" HorizontalAlignment="Stretch"
                   Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>

        <!-- Table -->
        <Border Grid.Row="2"
                Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Padding="0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0" Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="16,14">
                    <Grid ColumnSpacing="12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" MinWidth="150"/>
                            <ColumnDefinition Width="130"/>
                            <ColumnDefinition Width="180"/>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="100"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="NAME" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="PHONE" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="2" Text="ADDRESS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="3" Text="TOTAL SPENT" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="4" Text="ORDERS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="5" Text="ACTIONS" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextFillColorPrimary}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Table Body -->
                <Grid Grid.Row="1">
                    <ListView ItemsSource="{Binding Customers}"
                              IsItemClickEnabled="True"
                              ItemClick="OnCustomerClick"
                              Padding="0,4,0,8"
                              SelectionMode="None"
                              Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="Padding" Value="16,0"/>
                                <Setter Property="MinHeight" Value="56"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="m:Customer">
                                <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" MinWidth="150"/>
                                            <ColumnDefinition Width="130"/>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="120"/>
                                            <ColumnDefinition Width="90"/>
                                            <ColumnDefinition Width="100"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0" Text="{x:Bind Name}" FontWeight="SemiBold" 
                                                   Foreground="{ThemeResource TextFillColorPrimary}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="1" Text="{x:Bind Phone}" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>

                                        <TextBlock Grid.Column="2" Text="{x:Bind Address}" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13" 
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="3" Text="{x:Bind TotalSpent, Converter={StaticResource CurrencyFormatter}}"
                                                   VerticalAlignment="Center" Foreground="{StaticResource AppPurpleBrush}" FontWeight="SemiBold" FontSize="13"/>

                                        <TextBlock Grid.Column="4" Text="{x:Bind OrderCount}" VerticalAlignment="Center"
                                                   Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13" HorizontalAlignment="Left" Margin="10,0,0,0"/>

                                        <StackPanel Grid.Column="5" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                            <Button Background="Transparent" BorderThickness="0" Padding="4"
                                                    Click="OnEditCustomerClick" ToolTipService.ToolTip="Edit">
                                                <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{ThemeResource TextFillColorSecondary}"/>
                                            </Button>
                                            <Button Background="Transparent" BorderThickness="0" Padding="4"
                                                    Click="OnDeleteCustomerClick" ToolTipService.ToolTip="Delete">
                                                <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="#DC2626"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- Loading overlay -->
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                                Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
                        <ProgressBar IsIndeterminate="True" Width="120" Foreground="{StaticResource AppPurpleBrush}"/>
                        <TextBlock Text="Loading customers..." Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Table Footer (Pagination) -->
                <Border Grid.Row="2"
                        Background="{ThemeResource ControlFillColorDefaultBrush}"
                        CornerRadius="{ThemeResource ControlCornerRadius}"
                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="16,14">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Spacing="4">
                            <TextBlock Text="Showing" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
                            <TextBlock Text="{Binding DisplayFrom}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
                            <TextBlock Text="–" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
                            <TextBlock Text="{Binding DisplayTo}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
                            <TextBlock Text="of" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
                            <TextBlock Text="{Binding TotalItems}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
                            <TextBlock Text="customers" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
                        </StackPanel>

                        <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                            <Button Style="{StaticResource PagerIconButtonStyle}"
                                    Command="{Binding PreviousPageCommand}">
                                <FontIcon Glyph="&#xE76B;" FontSize="14"/>
                            </Button>
                            <Border Background="{StaticResource AppPurpleBrush}" CornerRadius="8" Padding="12,8" MinWidth="40" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentPage}"
                                           Foreground="White"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"/>
                            </Border>
                            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiary}" FontSize="13" Margin="4,0">
                                <Run Text="/ "/><Run Text="{Binding TotalPages}"/>
                            </TextBlock>
                            <Button Style="{StaticResource PagerIconButtonStyle}"
                                    Command="{Binding NextPageCommand}">
                                <FontIcon Glyph="&#xE76C;" FontSize="14"/>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>

        <!-- Error Message -->
        <TextBlock Grid.Row="3"
                   Margin="0,12,0,0"
                   Text="{Binding ErrorMessage}"
                   Foreground="#DC2626"
                   TextWrapping="Wrap"
                   HorizontalAlignment="Center"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        <!-- Global Loading Overlay (for dialog opening) -->
        <Grid x:Name="GlobalLoadingOverlay"
              Grid.Row="0" Grid.RowSpan="4"
              Background="#66000000"
              Visibility="Collapsed"
              Canvas.ZIndex="100">
            <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="32,24" CornerRadius="12"
                    BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
                <StackPanel Spacing="12">
                    <ProgressBar IsIndeterminate="True" Width="120" Foreground="{StaticResource AppPurpleBrush}"/>
                    <TextBlock Text="Opening..." FontWeight="SemiBold" HorizontalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimary}"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
