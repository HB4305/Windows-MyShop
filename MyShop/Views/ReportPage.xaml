<Page x:Class="MyShop.Views.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24"
                Spacing="16">
      <TextBlock Text="Report Test"
                 FontSize="28"
                 FontWeight="Bold"/>

      <StackPanel Orientation="Horizontal"
                  Spacing="12">
        <Button Content="Reload"
                Command="{Binding LoadReportCommand}"/>
        <TextBlock Text="Loading..."
                   VerticalAlignment="Center"
                   Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
      </StackPanel>

      <Border Padding="12"
              BorderThickness="1"
              BorderBrush="Gray"
              CornerRadius="6">
        <StackPanel Spacing="8">
          <TextBlock Text="Filters"
                     FontWeight="SemiBold"/>

          <TextBlock Text="Period type: day / week / month / year"/>
          <TextBox Header="Selected Period"
                   Text="{Binding Filter.Period, Mode=TwoWay}"/>

          <DatePicker Header="Start Date"
                      Date="{Binding StartDateValue, Mode=TwoWay}"/>

          <DatePicker Header="End Date"
                      Date="{Binding EndDateValue, Mode=TwoWay}"/>

          <TextBox Header="Category Name"
                   Text="{Binding Filter.CategoryName, Mode=TwoWay}"/>

          <TextBox Header="Product Name"
                   Text="{Binding Filter.ProductName, Mode=TwoWay}"/>
        </StackPanel>
      </Border>

      <Border Padding="12"
              BorderThickness="1"
              BorderBrush="Gray"
              CornerRadius="6">
        <StackPanel Spacing="8">
          <TextBlock Text="Top Performing Products"
                     FontWeight="SemiBold"/>

          <ItemsControl ItemsSource="{Binding TopPerformingProductLines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="LightGray"
                        Padding="0,0,0,8"
                        Margin="0,0,0,8">
                  <TextBlock Text="{Binding}"
                             TextWrapping="Wrap"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Padding="12"
              BorderThickness="1"
              BorderBrush="Gray"
              CornerRadius="6">
        <StackPanel Spacing="8">
          <TextBlock Text="Sales Points"
                     FontWeight="SemiBold"/>

          <ItemsControl ItemsSource="{Binding SalesLines}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border BorderThickness="0,0,0,1"
                        BorderBrush="LightGray"
                        Padding="0,0,0,8"
                        Margin="0,0,0,8">
                  <TextBlock Text="{Binding}"
                             TextWrapping="Wrap"/>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </StackPanel>
      </Border>

      <Border Padding="12"
              BorderThickness="1"
              BorderBrush="Gray"
              CornerRadius="6">
        <StackPanel Spacing="8">
          <TextBlock Text="Raw Output"
                     FontWeight="SemiBold"/>

          <TextBlock Text="{Binding Output}"
                     TextWrapping="Wrap"
                     FontFamily="Consolas"/>
        </StackPanel>
      </Border>

      <TextBlock Text="{Binding ErrorMessage}"
                 Foreground="Red"
                 TextWrapping="Wrap"/>
    </StackPanel>
  </ScrollViewer>
</Page>
