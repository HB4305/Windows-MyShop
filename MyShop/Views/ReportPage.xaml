<Page x:Class="MyShop.Views.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:lvc="using:LiveChartsCore.SkiaSharpView.WinUI"
      xmlns:conv="using:MyShop.Converters"
      Background="#F3F4F6"
      Tapped="Page_Tapped">
  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E8E8F2"/>
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextStrong" Color="#1F2937"/>
    <SolidColorBrush x:Key="Accent" Color="#8B5CF6"/>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
  </Page.Resources>

  <ScrollViewer x:Name="PageScrollViewer"
                VerticalScrollBarVisibility="Auto"
                ViewChanged="PageScrollViewer_ViewChanged">
    <Grid x:Name="RootLayout" HorizontalAlignment="Stretch" Padding="28,24,28,40" SizeChanged="RootLayout_SizeChanged">
      <StackPanel Spacing="18">
        <Grid x:Name="HeaderGrid" ColumnSpacing="18" RowSpacing="12">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <StackPanel x:Name="HeaderTitlePanel" Spacing="4" Grid.Row="0" Grid.Column="0">
            <TextBlock Text="MyShop Reports" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            <TextBlock Text="Overview, product sales, revenue, profit, and top performing products" Foreground="{StaticResource TextMuted}" FontSize="14"/>
          </StackPanel>

          <Border x:Name="HeaderPeriodCard" Grid.Row="0" Grid.Column="1" Background="#FFFFFF" CornerRadius="12" Padding="14,10">
            <StackPanel Spacing="8">
              <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                <TextBlock Text="{Binding PeriodTitle}" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center"/>
                <TextBlock Text=":" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RangeStartDisplay, Converter={StaticResource DateFormatter}}" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center"/>
                <TextBlock Text="-" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding RangeEndDisplay, Converter={StaticResource DateFormatter}}" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center"/>
              </StackPanel>

              <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                <TextBlock Text="Select Period" Foreground="{StaticResource TextMuted}" VerticalAlignment="Center"/>
                <Button Content="Week"
                        Click="WeekPeriodButton_Click"
                        Background="{Binding WeekButtonBackground}"
                        Foreground="{Binding WeekButtonForeground}"
                        BorderThickness="0"
                        FontSize="12"
                        Padding="10,4"/>
                <Button Content="Month"
                        Click="MonthPeriodButton_Click"
                        Background="{Binding MonthButtonBackground}"
                        Foreground="{Binding MonthButtonForeground}"
                        BorderThickness="0"
                        FontSize="12"
                        Padding="10,4"/>
                <Button Content="Year"
                        Click="YearPeriodButton_Click"
                        Background="{Binding YearButtonBackground}"
                        Foreground="{Binding YearButtonForeground}"
                        BorderThickness="0"
                        FontSize="12"
                        Padding="10,4"/>
              </StackPanel>
            </StackPanel>
          </Border>
        </Grid>

        <Grid x:Name="OverviewGrid" ColumnSpacing="14" RowSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Border x:Name="OverviewRevenueCard" Grid.Column="0" Grid.Row="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
              <TextBlock Text="Revenue" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding Overview.Revenue, Converter={StaticResource CurrencyFormatter}}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="{Binding Overview.RevenueChangePercentage, Converter={StaticResource PercentageFormatter}}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
            </StackPanel>
          </Border>

          <Border x:Name="OverviewQuantityCard" Grid.Column="1" Grid.Row="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
              <TextBlock Text="Quantity Sold" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding Overview.QuantitySold}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="{Binding Overview.QuantitySoldChangePercentage, Converter={StaticResource PercentageFormatter}}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
            </StackPanel>
          </Border>

          <Border x:Name="OverviewProfitCard" Grid.Column="2" Grid.Row="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
              <TextBlock Text="Profit" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding Overview.Profit, Converter={StaticResource CurrencyFormatter}}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="{Binding Overview.ProfitChangePercentage, Converter={StaticResource PercentageFormatter}}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
            </StackPanel>
          </Border>

          <Border x:Name="OverviewCustomersCard" Grid.Column="3" Grid.Row="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="8">
              <TextBlock Text="Customers" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding Overview.CustomersCount}" FontSize="28" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="{Binding Overview.CustomersChangePercentage, Converter={StaticResource PercentageFormatter}}" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
            </StackPanel>
          </Border>
        </Grid>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="16">
            <StackPanel Spacing="4">
              <TextBlock Text="Product Sales" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="Daily sold quantity across the selected period." Foreground="{StaticResource TextMuted}"/>
            </StackPanel>

            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <ComboBox x:Name="CategoryComboBox"
                        Grid.Column="0"
                        ItemsSource="{Binding CategoryOptions}"
                        SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                        SelectionChanged="CategoryComboBox_SelectionChanged"
                        PlaceholderText="Category"/>

              <AutoSuggestBox x:Name="ProductSearchAutoSuggestBox"
                              Grid.Column="1"
                              PlaceholderText="Search product name..."
                              Text="{Binding ProductSearchText, Mode=TwoWay}"
                              ItemsSource="{Binding ProductOptions}"
                              TextChanged="ProductSearchAutoSuggestBox_TextChanged"
                              SuggestionChosen="ProductSearchAutoSuggestBox_SuggestionChosen"
                              QuerySubmitted="ProductSearchAutoSuggestBox_QuerySubmitted"
                              Background="#F5F1FF"
                              BorderThickness="0"
                              Padding="12,10"
                              VerticalContentAlignment="Center"/>

              <Button Grid.Column="2"
                      Click="SearchButton_Click"
                      Background="{StaticResource Accent}"
                      Foreground="White"
                      BorderThickness="0"
                      Padding="14,10"
                      CornerRadius="12">
                <FontIcon Glyph="&#xE721;"/>
              </Button>
            </Grid>

            <Border Background="#FCFBFF" BorderBrush="#ECECF4" BorderThickness="1" CornerRadius="18" Padding="12">
              <lvc:CartesianChart Height="280"
                                  LegendPosition="Hidden"
                                  Series="{Binding SoldQuantitySeries}"
                                  XAxes="{Binding SoldQuantityXAxes}"
                                  YAxes="{Binding SoldQuantityYAxes}"/>
            </Border>
          </StackPanel>
        </Border>

        <Grid x:Name="RevenueProfitGrid" ColumnSpacing="18" RowSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Border x:Name="RevenueCard" Grid.Row="0" Grid.Column="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
              <TextBlock Text="Revenue" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="Daily revenue across the selected period." Foreground="{StaticResource TextMuted}"/>

              <Border Background="#FCFBFF" BorderBrush="#ECECF4" BorderThickness="1" CornerRadius="18" Padding="12">
                <lvc:CartesianChart Height="240"
                                    LegendPosition="Hidden"
                                    Series="{Binding RevenueSeries}"
                                    XAxes="{Binding RevenueXAxes}"
                                    YAxes="{Binding RevenueYAxes}"/>
              </Border>
            </StackPanel>
          </Border>

          <Border x:Name="ProfitCard" Grid.Row="0" Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
              <TextBlock Text="Profit by Category" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Text="Profit distribution by category for the selected period." Foreground="{StaticResource TextMuted}"/>

              <Border Background="#FCFBFF" BorderBrush="#ECECF4" BorderThickness="1" CornerRadius="18" Padding="12">
                <lvc:PieChart Height="240"
                              LegendPosition="Right"
                              Series="{Binding ProfitSeries}"/>
              </Border>
            </StackPanel>
          </Border>
        </Grid>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="18">
            <TextBlock Text="Top Performing Products" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>

            <Grid ColumnSpacing="18">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.4*"/>
                <ColumnDefinition Width="1.1*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="PRODUCT" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="1" Text="QTY SOLD" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="2" Text="REVENUE" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="3" Text="PROFIT" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="4" Text="CATEGORY" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding TopPerformingProducts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Border BorderBrush="#ECECF4" BorderThickness="0,0,0,1" Padding="0,12">
                    <Grid ColumnSpacing="18">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.4*"/>
                        <ColumnDefinition Width="1.1*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1*"/>
                      </Grid.ColumnDefinitions>

                      <StackPanel>
                        <TextBlock Text="{Binding ProductName}" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Text="{Binding ImageUrl}" FontSize="12" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                      </StackPanel>

                      <TextBlock Grid.Column="1" Text="{Binding TotalQuantitySold}" VerticalAlignment="Center" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="2" Text="{Binding GrossRevenue, Converter={StaticResource CurrencyFormatter}}" VerticalAlignment="Center" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="3" Text="{Binding Profit, Converter={StaticResource CurrencyFormatter}}" VerticalAlignment="Center" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="4" Text="{Binding CategoryName}" VerticalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#DC2626" TextWrapping="Wrap"/>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
