<Page x:Class="MyShop.Views.ReportPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:report="using:MyShop.Models.ReportModels"
      Background="#F3F4F6">
  <Page.Resources>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E8E8F2"/>
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextStrong" Color="#1F2937"/>
    <SolidColorBrush x:Key="Accent" Color="#8B5CF6"/>
    <SolidColorBrush x:Key="AccentSoft" Color="#F1EAFE"/>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="20"/>
      <Setter Property="Padding" Value="18"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid MaxWidth="1200" HorizontalAlignment="Center" Padding="28,24,28,40">
      <StackPanel Spacing="18">
        <Grid ColumnSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <StackPanel Spacing="4">
            <TextBlock Text="MyShop 2026 Reports" FontSize="34" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            <TextBlock Text="Performance metrics &amp; sports merchandise analytics" Foreground="{StaticResource TextMuted}" FontSize="14"/>
          </StackPanel>
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">
            <Border Background="#FFFFFF" CornerRadius="12" Padding="14,10">
              <TextBlock Text="{Binding EndDateDisplay}" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold"/>
            </Border>
            <Button Content="Export" Padding="16,10" Background="{StaticResource Accent}" Foreground="White" BorderThickness="0"/>
          </StackPanel>
        </Grid>

        <Grid ColumnSpacing="14">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="10">
              <TextBlock Text="Total Revenue" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding TotalRevenueDisplay}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="10">
              <TextBlock Text="Products Sold" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding TotalQuantitySoldDisplay}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="2" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="10">
              <TextBlock Text="Gross Profit" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding TotalProfitDisplay}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            </StackPanel>
          </Border>
          <Border Grid.Column="3" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="10">
              <TextBlock Text="Customer Count" Foreground="{StaticResource TextMuted}"/>
              <TextBlock Text="{Binding TotalCustomersDisplay}" FontSize="30" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
            </StackPanel>
          </Border>
        </Grid>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="16">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <StackPanel Spacing="4">
                <TextBlock Text="Product Sales" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                <TextBlock Text="Quantity of merchandise sold over time" Foreground="{StaticResource TextMuted}"/>
              </StackPanel>
              <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                <Button Content="Day" Click="DayPeriodButton_Click" Background="{Binding DayButtonBackground}" Foreground="{Binding DayButtonForeground}" BorderThickness="0" Padding="12,6"/>
                <Button Content="Week" Click="WeekPeriodButton_Click" Background="{Binding WeekButtonBackground}" Foreground="{Binding WeekButtonForeground}" BorderThickness="0" Padding="12,6"/>
                <Button Content="Month" Click="MonthPeriodButton_Click" Background="{Binding MonthButtonBackground}" Foreground="{Binding MonthButtonForeground}" BorderThickness="0" Padding="12,6"/>
                <Button Content="Year" Click="YearPeriodButton_Click" Background="{Binding YearButtonBackground}" Foreground="{Binding YearButtonForeground}" BorderThickness="0" Padding="12,6"/>
              </StackPanel>
            </Grid>

            <Grid ColumnSpacing="12">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <TextBox Grid.Column="0" PlaceholderText="Search by product name..." Text="{Binding Filter.ProductName, Mode=TwoWay}" TextChanged="ProductSearchTextBox_TextChanged" Background="#F5F1FF" BorderThickness="0" Padding="12,10"/>
              <DatePicker Grid.Column="1" Date="{Binding StartDateValue, Mode=TwoWay}" DateChanged="StartDatePicker_DateChanged"/>
              <DatePicker Grid.Column="2" Date="{Binding EndDateValue, Mode=TwoWay}" DateChanged="EndDatePicker_DateChanged"/>
              <TextBox Grid.Column="3" PlaceholderText="Filter by category..." Text="{Binding Filter.CategoryName, Mode=TwoWay}" TextChanged="CategoryTextBox_TextChanged"/>
            </Grid>

            <Border Background="#FCFBFF" CornerRadius="18" Padding="12">
              <StackPanel Spacing="12">
                <Canvas Height="300">
                  <Line X1="0" Y1="250" X2="980" Y2="250" Stroke="#ECECF4" StrokeThickness="1"/>
                  <Line X1="0" Y1="190" X2="980" Y2="190" Stroke="#F1F1F7" StrokeThickness="1"/>
                  <Line X1="0" Y1="130" X2="980" Y2="130" Stroke="#F1F1F7" StrokeThickness="1"/>
                  <Line X1="0" Y1="70" X2="980" Y2="70" Stroke="#F1F1F7" StrokeThickness="1"/>
                  <Polygon Points="8,238 110,208 196,176 288,162 392,154 500,110 612,28 718,42 822,134 906,224 972,56 972,270 8,270" Fill="#E9DDFF" Opacity="0.85"/>
                  <Polyline Points="8,238 110,208 196,176 288,162 392,154 500,110 612,28 718,42 822,134 906,224 972,56" Stroke="{StaticResource Accent}" StrokeThickness="5" StrokeLineJoin="Round" StrokeStartLineCap="Round" StrokeEndLineCap="Round"/>
                </Canvas>

                <ItemsControl ItemsSource="{Binding Sales}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="report:ProductSale">
                      <Grid Margin="0,2">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="{x:Bind PeriodLabel}" Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind QuantitySoldDisplay}" Margin="12,0,0,0" Foreground="{StaticResource TextStrong}" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind GrossRevenueDisplay}" Margin="12,0,0,0" Foreground="{StaticResource TextMuted}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </StackPanel>
            </Border>
          </StackPanel>
        </Border>

        <Grid ColumnSpacing="18">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="*"/>
          </Grid.ColumnDefinitions>

          <Border Grid.Column="0" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
              <TextBlock Text="Revenue Performance" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <Grid Height="190" VerticalAlignment="Bottom">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/><ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Border Grid.Column="0" Width="38" Height="74" Background="#EEF1F7" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                <Border Grid.Column="1" Width="38" Height="132" Background="#EEF1F7" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                <Border Grid.Column="2" Width="38" Height="174" Background="{StaticResource Accent}" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                <Border Grid.Column="3" Width="38" Height="136" Background="#EEF1F7" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
                <Border Grid.Column="4" Width="38" Height="88" Background="#EEF1F7" CornerRadius="8" VerticalAlignment="Bottom" HorizontalAlignment="Center"/>
              </Grid>
              <ItemsControl ItemsSource="{Binding CategoryRevenue}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate x:DataType="report:RevenueData">
                    <Grid Margin="0,2">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                      </Grid.ColumnDefinitions>
                      <TextBlock Text="{x:Bind CategoryName}" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="1" Text="{x:Bind GrossRevenueDisplay}" Foreground="{StaticResource TextMuted}"/>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <Border Grid.Column="1" Style="{StaticResource CardStyle}">
            <StackPanel Spacing="14">
              <TextBlock Text="Profit Distribution" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <Grid ColumnSpacing="18">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="170"/>
                  <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid Width="150" Height="150" HorizontalAlignment="Center" VerticalAlignment="Center">
                  <Ellipse Fill="#F3EDFF"/>
                  <Ellipse Width="98" Height="98" Fill="White"/>
                  <TextBlock Text="{Binding TotalProfitDisplay}" HorizontalAlignment="Center" VerticalAlignment="Center" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>
                </Grid>
                <ItemsControl Grid.Column="1" ItemsSource="{Binding CategoryProfit}">
                  <ItemsControl.ItemTemplate>
                    <DataTemplate x:DataType="report:ProfitData">
                      <Grid Margin="0,6">
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="16"/>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Border Width="10" Height="10" CornerRadius="5" Background="{StaticResource Accent}" VerticalAlignment="Center"/>
                        <TextBlock Grid.Column="1" Text="{x:Bind CategoryName}" Margin="10,0,0,0" Foreground="{StaticResource TextStrong}"/>
                        <TextBlock Grid.Column="2" Text="{x:Bind ProfitDisplay}" Foreground="{StaticResource TextMuted}"/>
                      </Grid>
                    </DataTemplate>
                  </ItemsControl.ItemTemplate>
                </ItemsControl>
              </Grid>
            </StackPanel>
          </Border>
        </Grid>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="18">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="Top Performing Products" FontSize="22" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
              <TextBlock Grid.Column="1" Text="View All Inventory" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
            </Grid>

            <Grid ColumnSpacing="18">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2.5*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="1.4*"/>
                <ColumnDefinition Width="1*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="PRODUCT NAME" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="1" Text="QUANTITY SOLD" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="2" Text="REVENUE" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="3" Text="NET PROFIT" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
              <TextBlock Grid.Column="4" Text="CATEGORY" Foreground="{StaticResource TextMuted}" FontWeight="SemiBold" FontSize="12"/>
            </Grid>

            <ItemsControl ItemsSource="{Binding TopPerformingProducts}">
              <ItemsControl.ItemTemplate>
                <DataTemplate x:DataType="report:TopPerformingProduct">
                  <Border BorderBrush="#ECECF4" BorderThickness="0,0,0,1" Padding="0,12">
                    <Grid ColumnSpacing="18">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.5*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.2*"/>
                        <ColumnDefinition Width="1.4*"/>
                        <ColumnDefinition Width="1*"/>
                      </Grid.ColumnDefinitions>
                      <StackPanel Orientation="Horizontal" Spacing="10">
                        <Border Width="34" Height="34" CornerRadius="17" Background="{StaticResource AccentSoft}">
                          <TextBlock Text="◌" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="{StaticResource Accent}"/>
                        </Border>
                        <StackPanel>
                          <TextBlock Text="{x:Bind ProductName}" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                          <TextBlock Text="{x:Bind ImageUrl}" FontSize="12" Foreground="{StaticResource TextMuted}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                      </StackPanel>
                      <TextBlock Grid.Column="1" Text="{x:Bind TotalQuantitySoldDisplay}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="2" Text="{x:Bind GrossRevenueDisplay}" VerticalAlignment="Center" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="3" Text="{x:Bind ProfitDisplay}" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
                      <TextBlock Grid.Column="4" Text="{x:Bind CategoryName}" VerticalAlignment="Center" Foreground="{StaticResource Accent}" FontWeight="SemiBold"/>
                    </Grid>
                  </Border>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </Border>

        <Border Style="{StaticResource CardStyle}">
          <StackPanel Spacing="8">
            <TextBlock Text="Debug Output" FontSize="20" FontWeight="SemiBold" Foreground="{StaticResource TextStrong}"/>
            <TextBlock Text="{Binding Output}" TextWrapping="Wrap" FontFamily="Consolas" Foreground="{StaticResource TextStrong}"/>
          </StackPanel>
        </Border>

        <TextBlock Text="{Binding ErrorMessage}" Foreground="#FCA5A5" TextWrapping="Wrap"/>
      </StackPanel>
    </Grid>
  </ScrollViewer>
</Page>
