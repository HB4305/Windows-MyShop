<Page x:Class="MyShop.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="16">
      <TextBlock Text="Settings"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="#1F2937"/>
      <Border Padding="24" CornerRadius="12" Background="White" BorderBrush="#E5E7EB" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" Spacing="8">
          <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="#D1D5DB" HorizontalAlignment="Center"/>
          <TextBlock Text="Settings" FontSize="18" FontWeight="SemiBold" Foreground="#6B7280" HorizontalAlignment="Center"/>
          <TextBlock Text="This page is under construction." FontSize="13" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
