<Page x:Class="MyShop.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">
  <Page.Resources>
    <SolidColorBrush x:Key="CardBrush" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="BorderBrushSoft" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280"/>
    <SolidColorBrush x:Key="TextStrong" Color="#1F2937"/>
    <SolidColorBrush x:Key="Accent" Color="#8B5CF6"/>
    <Style x:Key="CardStyle" TargetType="Border">
      <Setter Property="Background" Value="{StaticResource CardBrush}"/>
      <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="16"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <Grid HorizontalAlignment="Stretch" Padding="28,24,28,40">
      <Border Style="{StaticResource CardStyle}">
        <StackPanel Spacing="16">
          <TextBlock Text="Settings" FontSize="24" FontWeight="Bold" Foreground="{StaticResource TextStrong}"/>

          <Grid ColumnSpacing="12" RowSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock Text="Pagination:" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center"/>
            <ComboBox Grid.Column="1"
                      ItemsSource="{Binding ItemsPerPageOptions}"
                      SelectedItem="{Binding SelectedItemsPerPage, Mode=TwoWay}"
                      PlaceholderText="Products per page"/>

            <TextBlock Grid.Row="1" Text="Save last activity:" Foreground="{StaticResource TextStrong}" VerticalAlignment="Center"/>
            <ToggleSwitch Grid.Row="1" Grid.Column="1"
                          OnContent="On"
                          OffContent="Off"
                          Foreground="{StaticResource Accent}"
                          IsOn="{Binding RememberLastActivity, Mode=TwoWay}">
              <ToggleSwitch.Resources>
                <SolidColorBrush x:Key="ToggleSwitchFillOn" Color="#8B5CF6"/>
                <SolidColorBrush x:Key="ToggleSwitchFillOnPointerOver" Color="#8B5CF6"/>
                <SolidColorBrush x:Key="ToggleSwitchFillOnPressed" Color="#7C3AED"/>
                <SolidColorBrush x:Key="ToggleSwitchKnobFillOn" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPointerOver" Color="#FFFFFF"/>
                <SolidColorBrush x:Key="ToggleSwitchKnobFillOnPressed" Color="#FFFFFF"/>
              </ToggleSwitch.Resources>
            </ToggleSwitch>
          </Grid>

          <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="Save Changes"
                    Background="{StaticResource Accent}"
                    Foreground="White"
                    BorderThickness="0"
                    Padding="18,8"
                    Click="SaveChanges_Click"/>
            <Button Content="Reset"
                    Background="#F3F4F6"
                    Foreground="{StaticResource TextStrong}"
                    BorderThickness="0"
                    Padding="18,8"
                    Command="{Binding ResetCommand}"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </Grid>
  </ScrollViewer>
</Page>
