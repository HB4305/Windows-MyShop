<Page x:Class="MyShop.Views.LoginPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:BoolToForegroundConverter x:Key="BoolToForegroundConverter"/>

    <!-- Font: Inter (Google Font) - fallback Segoe UI nếu Inter không load -->
    <FontFamily x:Key="InterFont">Segoe UI, Segoe UI Variable Display</FontFamily>

    <!-- Theme-aware accent brushes -->
    <SolidColorBrush x:Key="PrimaryBrush" Color="#8B52FF"/>
    <SolidColorBrush x:Key="GrayBrush"     Color="#99A1AF"/>
    <SolidColorBrush x:Key="ErrorBrush"    Color="#EF4444"/>
  </Page.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <!-- Left: Hero decoration -->
      <ColumnDefinition Width="*"/>
      <!-- Right: Login Form -->
      <ColumnDefinition Width="600"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- RIGHT PANEL: Login Form (600px) -->
    <!-- ═══════════════════════════════════════════════ -->
    <Grid Grid.Column="1" Margin="48,48,48,48">

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <!-- Logo + brand -->
        <RowDefinition Height="Auto"/>
        <!-- Heading -->
        <RowDefinition Height="Auto"/>
        <!-- Form fields -->
        <RowDefinition Height="*"/>
        <!-- Version footer -->
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ── Brand Header ── -->
      <Grid Grid.Row="0" Margin="0,0,0,48">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Logo icon (rounded square 48x48) -->
        <Border Grid.Column="0"
                Width="48" Height="48"
                CornerRadius="{ThemeResource OverlayCornerRadius}"
                Background="{StaticResource PrimaryBrush}"
                Padding="12">
          <Viewbox Width="24" Height="24">
            <Path Data="M12 2L2 7L12 12L22 7L12 2Z M2 17L12 22L22 17 M2 12L12 17L22 12"
                  Stroke="{ThemeResource TextFillColorPrimary}" StrokeThickness="2"
                  StrokeLineJoin="Round" Fill="Transparent"/>
          </Viewbox>
        </Border>

        <!-- Brand text -->
        <StackPanel Grid.Column="1" Margin="12,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="ProSport Hub"
                     Style="{StaticResource TitleTextBlockStyle}"
                     Foreground="{ThemeResource TextFillColorPrimary}"/>
          <TextBlock Text="INVENTORY MANAGEMENT"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="12" FontWeight="400"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     CharacterSpacing="600"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Back to Config button -->
        <Button Grid.Column="2"
                Command="{Binding OpenConfigCommand}"
                VerticalAlignment="Center"
                Background="Transparent"
                BorderThickness="0"
                Padding="8,4"
                ToolTipService.ToolTip="Back to Database Config">
          <StackPanel Orientation="Horizontal" Spacing="6">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE72B;"
                       FontSize="14"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       VerticalAlignment="Center"/>
            <TextBlock Text="Config"
                       Style="{StaticResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       VerticalAlignment="Center"/>
          </StackPanel>
        </Button>
      </Grid>

      <!-- ── Heading ── -->
      <StackPanel Grid.Row="1" Margin="0,0,0,32">
        <TextBlock Text="Partner Login"
                   Style="{StaticResource TitleLargeTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorPrimary}"/>
        <TextBlock Text="Welcome back to the ProSport ecosystem."
                   Style="{StaticResource BodyTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondary}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>
      </StackPanel>

      <!-- ── Form Fields ── -->
      <StackPanel Grid.Row="2" VerticalAlignment="Top">

        <!-- Email field -->
        <TextBlock Text="Organization Email"
                   Style="{StaticResource BodyStrongTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondary}"
                   Margin="0,0,0,8"/>
        <TextBox x:Name="EmailInput"
                 Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="admin@prosport.com"
                 FontFamily="{StaticResource InterFont}"
                 FontSize="14"
                 IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                 Background="{ThemeResource ControlFillColorDefaultBrush}"
                 Foreground="{ThemeResource TextFillColorPrimary}"
                 BorderBrush="{ThemeResource TextBoxBorderBrush}"
                 CornerRadius="{ThemeResource ControlCornerRadius}"
                 Padding="12,10,12,10"
                 Height="48"
                 VerticalContentAlignment="Center"/>

        <!-- Password field -->
        <TextBlock Text="Security Key"
                   Style="{StaticResource BodyStrongTextBlockStyle}"
                   Foreground="{ThemeResource TextFillColorSecondary}"
                   Margin="0,16,0,8"/>
        <Grid>
          <PasswordBox x:Name="PasswordBox"
                       IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                       PasswordRevealMode="Hidden"
                       Background="{ThemeResource ControlFillColorDefaultBrush}"
                       Foreground="{ThemeResource TextFillColorPrimary}"
                       BorderBrush="{ThemeResource TextBoxBorderBrush}"
                       CornerRadius="{ThemeResource ControlCornerRadius}"
                       Padding="12,10,40,10"
                       Height="48"
                       VerticalContentAlignment="Center"/>
          <!-- Show/hide password toggle -->
          <Button HorizontalAlignment="Right"
                  VerticalAlignment="Center"
                  Margin="0,0,8,0"
                  Width="32" Height="32"
                  Background="Transparent"
                  BorderThickness="0"
                  Click="TogglePassword_Click">
            <Viewbox Width="17" Height="12">
              <Path Data="M1 6C1 6 4 1 8.5 1C13 1 16 6 16 6C16 6 13 11 8.5 11C4 11 1 6 1 6ZM8.5 3C6.01 3 4 5.01 4 7.5C4 9.99 6.01 12 8.5 12C10.99 12 13 9.99 13 7.5C13 5.01 10.99 3 8.5 3ZM8.5 4.5C9.88 4.5 11 5.62 11 7C11 8.38 9.88 9.5 8.5 9.5C7.12 9.5 6 8.38 6 7C6 5.62 7.12 4.5 8.5 4.5ZM1 6V12H16V6"
                    Stroke="{ThemeResource TextFillColorSecondary}" StrokeThickness="1"
                    Fill="Transparent" StrokeLineJoin="Round"/>
            </Viewbox>
          </Button>
        </Grid>

        <!-- Error message -->
        <TextBlock Text="{Binding ErrorMessage}"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Progress bar -->
        <ProgressBar IsIndeterminate="True"
                      Height="4"
                      Margin="0,16,0,0"
                      Foreground="{StaticResource PrimaryBrush}"
                      Background="{ThemeResource ControlFillColorDefaultBrush}"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Primary Sign In button -->
        <Button Command="{Binding LoginCommand}"
                HorizontalAlignment="Stretch"
                Height="48"
                Margin="0,20,0,0"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{StaticResource PrimaryBrush}"
                BorderThickness="0"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
          <TextBlock Text="Sign In to Hub"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorPrimary}"/>
        </Button>
      </StackPanel>

      <!-- ── Version Footer ── -->
      <TextBlock Grid.Row="4"
                 Text="{Binding AppVersion}"
                 Style="{StaticResource CaptionTextBlockStyle}"
                 Foreground="{ThemeResource TextFillColorTertiary}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"
                 Margin="0,0,0,0"/>
    </Grid>

    <!-- ═══════════════════════════════════════════════ -->
    <!-- LEFT PANEL: Hero decoration -->
    <!-- ═══════════════════════════════════════════════ -->
    <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">

      <!-- Decorative circles (top-right) -->
      <Grid Margin="138,0,138,0">
        <Ellipse Width="600" Height="600"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.08">
          <Ellipse.Fill>
            <SolidColorBrush Color="White"/>
          </Ellipse.Fill>
          <Ellipse.RenderTransform>
            <TranslateTransform Y="-200"/>
          </Ellipse.RenderTransform>
        </Ellipse>

        <!-- Small circle (top-left of ellipse) -->
        <Border Width="80" Height="80"
                CornerRadius="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="60,80,0,0">
          <Grid>
            <Border Background="White" Opacity="0.20" CornerRadius="24"/>
            <Viewbox Width="40" Height="40" Margin="20">
              <Path Data="M12 2L2 7L12 12L22 7L12 2Z M2 17L12 22L22 17"
                    Stroke="White" StrokeThickness="2"
                    StrokeLineJoin="Round" Fill="Transparent"/>
            </Viewbox>
          </Grid>
        </Border>

        <!-- Hero text (left-aligned on the right panel) -->
        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center"
                    Margin="0,0,0,0">
          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="72" FontWeight="Bold"
                     Foreground="White"
                     LineHeight="88">
            <Run Text="Welcome to"/><LineBreak/>
            <Run Text="ProSport Hub"/>
          </TextBlock>

          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="18" FontWeight="400"
                     Foreground="White"
                     Opacity="0.90"
                     TextWrapping="Wrap"
                     Margin="0,16,0,0"
                     MaxWidth="512">
            <Run Text="The ultimate platform for sports equipment"/>
            <LineBreak/>
            <Run Text="logistics, inventory and sales management."/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Page>
