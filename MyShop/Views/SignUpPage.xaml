<Page x:Class="MyShop.Views.SignUpPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="White">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>

    <FontFamily x:Key="InterFont">Segoe UI, Segoe UI Variable Display</FontFamily>

    <SolidColorBrush x:Key="PrimaryBrush"      Color="#8B52FF"/>
    <SolidColorBrush x:Key="DarkTextBrush"     Color="#101828"/>
    <SolidColorBrush x:Key="MutedTextBrush"   Color="#6A7282"/>
    <SolidColorBrush x:Key="InputBgBrush"    Color="#F9FAFB"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="LabelTextBrush"   Color="#364553"/>
    <SolidColorBrush x:Key="ErrorBrush"      Color="#EF4444"/>
    <SolidColorBrush x:Key="GrayBrush"       Color="#99A1AF"/>
  </Page.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="*"/>
      <ColumnDefinition Width="600"/>
    </Grid.ColumnDefinitions>

    <!-- LEFT: Hero (purple) -->
    <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">
      <Grid Margin="138,0,138,0">
        <Ellipse Width="600" Height="600"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.08"
                 Margin="0,-200,0,0">
          <Ellipse.Fill>
            <SolidColorBrush Color="White"/>
          </Ellipse.Fill>
          <Ellipse.RenderTransform>
            <TranslateTransform Y="-200"/>
          </Ellipse.RenderTransform>
        </Ellipse>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center">
          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="72" FontWeight="Bold"
                     Foreground="White"
                     LineHeight="88">
            <Run Text="Start your"/><LineBreak/>
            <Run Text="ProSport Hub"/>
          </TextBlock>

          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="18" FontWeight="400"
                     Foreground="White"
                     Opacity="0.90"
                     TextWrapping="Wrap"
                     Margin="0,16,0,0"
                     MaxWidth="512">
            <Run Text="Create your store account and manage"/>
            <LineBreak/>
            <Run Text="your sports business efficiently."/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Grid>

    <!-- RIGHT: Sign Up Form -->
    <Grid Grid.Column="1" Margin="48,48,48,48">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Back button -->
      <Button Grid.Row="0"
              Content="← Back to Login"
              Command="{Binding BackToLoginCommand}"
              HorizontalAlignment="Left"
              Background="Transparent"
              Foreground="{StaticResource PrimaryBrush}"
              FontFamily="{StaticResource InterFont}"
              FontSize="14" FontWeight="500"
              BorderThickness="0"
              Margin="0,0,0,32"/>

      <StackPanel Grid.Row="1" VerticalAlignment="Center">

        <TextBlock Text="Create Account"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="30" FontWeight="Bold"
                   Foreground="{StaticResource DarkTextBrush}"/>
        <TextBlock Text="Set up your store management account."
                   FontFamily="{StaticResource InterFont}"
                   FontSize="16"
                   Foreground="{StaticResource MutedTextBrush}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,32"/>

        <!-- Email -->
        <TextBlock Text="Organization Email"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource LabelTextBrush}"
                   Margin="0,0,0,8"/>
        <TextBox Text="{Binding Email, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                 PlaceholderText="admin@prosport.com"
                 FontFamily="{StaticResource InterFont}"
                 FontSize="14"
                 IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                 Background="{StaticResource InputBgBrush}"
                 Foreground="{StaticResource DarkTextBrush}"
                 BorderBrush="{StaticResource InputBorderBrush}"
                 CornerRadius="8"
                 Padding="12,16,12,16"
                 Height="48"
                 VerticalContentAlignment="Center"/>

        <!-- Password -->
        <TextBlock Text="Password"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource LabelTextBrush}"
                   Margin="0,16,0,8"/>
        <PasswordBox x:Name="PasswordBox"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                    Background="{StaticResource InputBgBrush}"
                    Foreground="{StaticResource DarkTextBrush}"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    CornerRadius="8"
                    Padding="12,16,40,16"
                    Height="48"
                    VerticalContentAlignment="Center"/>

        <!-- Confirm Password -->
        <TextBlock Text="Confirm Password"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14" FontWeight="SemiBold"
                   Foreground="{StaticResource LabelTextBrush}"
                   Margin="0,16,0,8"/>
        <PasswordBox x:Name="ConfirmPasswordBox"
                    IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                    Background="{StaticResource InputBgBrush}"
                    Foreground="{StaticResource DarkTextBrush}"
                    BorderBrush="{StaticResource InputBorderBrush}"
                    CornerRadius="8"
                    Padding="12,16,40,16"
                    Height="48"
                    VerticalContentAlignment="Center"/>

        <!-- Error -->
        <TextBlock Text="{Binding ErrorMessage}"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14"
                   Foreground="{StaticResource ErrorBrush}"
                   TextWrapping="Wrap"
                   Margin="0,12,0,0"
                   Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>

        <!-- Progress -->
        <ProgressBar IsIndeterminate="True"
                     Height="4"
                     Margin="0,16,0,0"
                     Foreground="{StaticResource PrimaryBrush}"
                     Background="#F3F3F5"
                     Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

        <!-- Sign Up Button -->
        <Button Command="{Binding SignUpCommand}"
                HorizontalAlignment="Stretch"
                Height="48"
                Margin="0,20,0,0"
                CornerRadius="14"
                Background="{StaticResource PrimaryBrush}"
                BorderThickness="0"
                IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
          <TextBlock Text="Create Account"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="White"/>
        </Button>

        <!-- Version -->
        <TextBlock Text="{Binding AppVersion}"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14"
                   Foreground="{StaticResource GrayBrush}"
                   HorizontalAlignment="Center"
                   Margin="0,24,0,0"/>
      </StackPanel>
    </Grid>
  </Grid>
</Page>
