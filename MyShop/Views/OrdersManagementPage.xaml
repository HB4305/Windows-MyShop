<Page x:Class="MyShop.Views.OrdersManagementPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      xmlns:m="using:MyShop.Models"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <!-- ══ Converters ══ -->
    <conv:OrderAthIdConverter x:Key="OrderAthIdConverter"/>
    <conv:InitialsConverter x:Key="InitialsConverter"/>
    <conv:OrderDateConverter x:Key="OrderDateConverter"/>
    <conv:CurrencyConverter x:Key="CurrencyConverter"/>
    <conv:OrderStatusToBrushConverter x:Key="OrderStatusToBrushConverter"/>
    <conv:OrderStatusToForegroundConverter x:Key="OrderStatusToForegroundConverter"/>
    <conv:PayBadgeBgConverter x:Key="PayBadgeBgConverter"/>
    <conv:PayBadgeFgConverter x:Key="PayBadgeFgConverter"/>
    <conv:CountToVisibilityConverter x:Key="CountToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:LineTotalConverter x:Key="LineTotalConverter"/>

    <!-- ══ Accent Colors ══ -->
    <SolidColorBrush x:Key="PurpleBrush"      Color="#7C3AED"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#F3F0FF"/>
    <SolidColorBrush x:Key="GrayLightBrush"   Color="#F9FAFB"/>

    <!-- ══ Corner Radius ══ -->
    <CornerRadius x:Key="CardRadius">12</CornerRadius>
    <CornerRadius x:Key="BadgeRadius">6</CornerRadius>
    <CornerRadius x:Key="AvatarRadius">9999</CornerRadius>

    <!-- ══ Card Style ══ -->
    <Style x:Key="CardBorder" TargetType="Border">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{StaticResource CardRadius}"/>
    </Style>

    <!-- ══ Primary Button ══ -->
    <Style x:Key="PrimaryBtn" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PurpleBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="SecondaryBtn" TargetType="Button">
      <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="Padding" Value="16,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
    </Style>

    <Style x:Key="IconBtn" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Padding" Value="8"/>
      <Setter Property="CornerRadius" Value="6"/>
    </Style>

    <!-- ══ Tab Button ══ -->
    <Style x:Key="TabBtn" TargetType="Button">
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondary}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <Style x:Key="TabBtnActive" TargetType="Button">
      <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Padding" Value="14,8"/>
      <Setter Property="CornerRadius" Value="8"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ══ Pagination Button ══ -->
    <Style x:Key="PageBtn" TargetType="Button">
      <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
    </Style>

    <Style x:Key="PageBtnActive" TargetType="Button">
      <Setter Property="Background" Value="{StaticResource PurpleBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="MinWidth" Value="32"/>
      <Setter Property="Height" Value="32"/>
      <Setter Property="Padding" Value="8,4"/>
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>

    <!-- ══ Text Styles ══ -->
    <Style x:Key="SectionTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="11"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiary}"/>
      <Setter Property="CharacterSpacing" Value="400"/>
    </Style>

    <Style x:Key="MutedText" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorTertiary}"/>
    </Style>

    <Style x:Key="PageTitle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="22"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
    </Style>

    <!-- ══ Status Badge Base ══ -->
    <Style x:Key="StatusBadge" TargetType="Border">
      <Setter Property="CornerRadius" Value="6"/>
      <Setter Property="Padding" Value="8,4"/>
    </Style>

    <!-- ══ ListViewItem: Selected Row Highlight ══ -->
    <Style x:Name="OrderListItemStyle" TargetType="ListViewItem">
      <Setter Property="Padding" Value="0"/>
      <Setter Property="Margin" Value="0"/>
      <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
      <Setter Property="Background" Value="Transparent"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ListViewItem">
            <ListViewItemPresenter
              SelectedBackground="#F4F3FF"
              SelectedBorderBrush="#7C3AED"
              SelectedBorderThickness="1"
              Background="Transparent"
              BorderThickness="0"/>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ══ DataTemplate: Order Row ══ -->
    <DataTemplate x:Key="OrderRowTemplate" x:DataType="m:CustomerOrder">
      <Border x:Name="RowBorder"
              Background="Transparent"
              CornerRadius="8"
              Padding="12,12"
              Margin="0,0,0,4"
              BorderThickness="0">
        <Grid VerticalAlignment="Center">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="100"/>
          </Grid.ColumnDefinitions>

          <!-- Order ID -->
          <TextBlock Grid.Column="0"
                     Text="{x:Bind Id, Converter={StaticResource OrderAthIdConverter}}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{StaticResource PurpleBrush}"
                     VerticalAlignment="Center"/>

          <!-- Athlete -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
            <!-- Avatar initials -->
            <Border Width="32" Height="32"
                    CornerRadius="16"
                    Background="{StaticResource PurpleLightBrush}">
              <TextBlock Text="{x:Bind CustomerName, Converter={StaticResource InitialsConverter}}"
                         FontSize="11"
                         FontWeight="Bold"
                         Foreground="{StaticResource PurpleBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{x:Bind CustomerName}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimary}"
                       VerticalAlignment="Center"
                       TextTrimming="CharacterEllipsis"
                       MaxWidth="180"/>
          </StackPanel>

          <!-- Date -->
          <TextBlock Grid.Column="2"
                     Text="{x:Bind CreatedAt, Converter={StaticResource OrderDateConverter}}"
                     FontSize="12"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     VerticalAlignment="Center"/>

          <!-- Status -->
          <Border Grid.Column="3"
                  Style="{StaticResource StatusBadge}"
                  Background="{x:Bind PaymentStatus, Converter={StaticResource PayBadgeBgConverter}}"
                  HorizontalAlignment="Left"
                  VerticalAlignment="Center">
            <TextBlock Text="{x:Bind PaymentStatus}"
                       FontSize="11"
                       FontWeight="SemiBold"
                       Foreground="{x:Bind PaymentStatus, Converter={StaticResource PayBadgeFgConverter}}"/>
          </Border>
        </Grid>
      </Border>
    </DataTemplate>

    <!-- ══ DataTemplate: Order Item Row ══ -->
    <DataTemplate x:Key="OrderItemTemplate" x:DataType="m:OrderDetail">
      <Grid Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="Auto"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Item thumbnail placeholder -->
        <Border Grid.Column="0"
                Width="44" Height="44"
                CornerRadius="8"
                Background="{StaticResource PurpleLightBrush}"
                Margin="0,0,12,0">
          <TextBlock FontFamily="Segoe MDL2 Assets"
                     Text="&#xE7BF;"
                     FontSize="18"
                     Foreground="{StaticResource PurpleBrush}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>

        <!-- Item info -->
        <StackPanel Grid.Column="1" VerticalAlignment="Center">
          <TextBlock Text="{x:Bind ItemName}"
                     FontSize="13"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorPrimary}"
                     TextTrimming="CharacterEllipsis"/>
          <TextBlock FontSize="11"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,2,0,0">
            <Run Text="Qty: "/><Run Text="{x:Bind Quantity, Mode=OneWay}"/>
          </TextBlock>
        </StackPanel>

        <!-- Price -->
        <TextBlock Grid.Column="2"
                   Text="{x:Bind Converter={StaticResource LineTotalConverter}}"
                   FontSize="14"
                   FontWeight="Bold"
                   Foreground="{ThemeResource TextFillColorPrimary}"
                   VerticalAlignment="Center"/>
      </Grid>
    </DataTemplate>

  </Page.Resources>

  <!-- ═══════════════════════════════════════════════════════════════ -->
  <!-- MAIN LAYOUT                                                  -->
  <!-- ═══════════════════════════════════════════════════════════════ -->
  <Grid>

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- ── Top Header Bar ── -->
    <Border Grid.Row="0"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="0,0,0,1"
            Padding="24,16">
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Left: title + subtitle -->
        <StackPanel Grid.Column="0" VerticalAlignment="Center">
          <TextBlock Text="Gear Orders Overview"
                     Style="{StaticResource PageTitle}"/>
          <TextBlock Text="Managing professional sports equipment and apparel"
                     FontSize="13"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Right: date range + new sale -->
        <StackPanel Grid.Column="1"
                    Orientation="Horizontal"
                    Spacing="8"
                    VerticalAlignment="Center">

          <!-- Date Range Picker (placeholder button) -->
          <Button Style="{StaticResource SecondaryBtn}"
                  Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="8">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE787;"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="Oct 1, 2023 – Oct 31, 2023"
                         FontSize="12"
                         Foreground="{ThemeResource TextFillColorPrimary}"
                         VerticalAlignment="Center"/>
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE70D;"
                         FontSize="10"
                         Foreground="{ThemeResource TextFillColorTertiary}"
                         VerticalAlignment="Center"
                         Margin="4,0,0,0"/>
            </StackPanel>
          </Button>

          <!-- New Sale Button -->
          <Button Style="{StaticResource PrimaryBtn}"
                  Click="NewSale_Click">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE710;"
                         FontSize="12"
                         VerticalAlignment="Center"/>
              <TextBlock Text="New Sale"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>
    </Border>

    <!-- ── Body: Order List + Detail Panel ── -->
    <Grid Grid.Row="1">

      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="380"/>
      </Grid.ColumnDefinitions>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- LEFT: ORDER LIST                               -->
      <!-- ═══════════════════════════════════════════════ -->
      <Grid Grid.Column="0">

        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab Bar -->
        <Border Grid.Row="0" Padding="24,12,24,0">
          <ScrollViewer HorizontalScrollBarVisibility="Auto"
                        VerticalScrollBarVisibility="Disabled">
            <StackPanel Orientation="Horizontal" Spacing="2">

              <!-- All Tab (active) -->
              <Button x:Name="TabAll" Click="TabAll_Click" Style="{StaticResource TabBtnActive}">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock Text="All Orders"/>
                  <Border Background="{StaticResource PurpleBrush}" CornerRadius="20" Padding="8,2">
                    <TextBlock Text="1,240" FontSize="11" FontWeight="SemiBold" Foreground="White"/>
                  </Border>
                </StackPanel>
              </Button>

              <!-- Pending -->
              <Button x:Name="TabPending" Click="TabPending_Click" Style="{StaticResource TabBtn}">
                <TextBlock Text="Pending"/>
              </Button>

              <!-- Processing -->
              <Button x:Name="TabProcessing" Click="TabProcessing_Click" Style="{StaticResource TabBtn}">
                <TextBlock Text="Processing"/>
              </Button>

              <!-- Shipped -->
              <Button x:Name="TabShipped" Click="TabShipped_Click" Style="{StaticResource TabBtn}">
                <TextBlock Text="Shipped"/>
              </Button>

              <!-- Returned -->
              <Button x:Name="TabReturned" Click="TabReturned_Click" Style="{StaticResource TabBtn}">
                <TextBlock Text="Returned"/>
              </Button>

            </StackPanel>
          </ScrollViewer>
        </Border>

        <!-- Table -->
        <Border Grid.Row="1" Margin="24,12,24,0">
          <Grid>

            <!-- Table card -->
            <Border Style="{StaticResource CardBorder}" Padding="0">
              <Grid>
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Table Header -->
                <Border Grid.Row="0"
                        BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,10">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="110"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="130"/>
                      <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="ORDER ID"  Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="1" Text="ATHLETE"   Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="2" Text="DATE"      Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                    <TextBlock Grid.Column="3" Text="STATUS"    Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>
                  </Grid>
                </Border>

                <!-- Table Body: ListView -->
                <ListView Grid.Row="1"
                          x:Name="OrderListView"
                          ItemsSource="{Binding Orders}"
                          ItemTemplate="{StaticResource OrderRowTemplate}"
                          ItemContainerStyle="{StaticResource OrderListItemStyle}"
                          SelectionMode="Single"
                          SelectionChanged="OrderList_SelectionChanged"
                          BorderThickness="0"
                          Background="Transparent"
                          Padding="0,4"/>

                <!-- Empty State -->
                <StackPanel Grid.Row="1"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="10"
                            Canvas.ZIndex="10"
                            Visibility="{Binding Orders.Count, Converter={StaticResource CountToVisibilityConverter}}">
                  <Border Width="60" Height="60" CornerRadius="30"
                          Background="{StaticResource PurpleLightBrush}">
                    <TextBlock FontFamily="Segoe MDL2 Assets"
                               Text="&#xE7BC;"
                               FontSize="28"
                               Foreground="{StaticResource PurpleBrush}"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                  </Border>
                  <TextBlock Text="No orders found"
                             FontSize="15" FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorSecondary}"
                             HorizontalAlignment="Center"/>
                  <TextBlock Text="No orders in this category yet."
                             FontSize="13"
                             Foreground="{ThemeResource TextFillColorTertiary}"
                             HorizontalAlignment="Center"/>
                </StackPanel>

              </Grid>
            </Border>

          </Grid>
        </Border>

        <!-- Pagination Footer -->
        <Border Grid.Row="2" Padding="24,10">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Showing text -->
            <TextBlock Grid.Column="0"
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       VerticalAlignment="Center">
              <Run Text="Showing"/>
              <Run Text=" "/>
              <Run Text="1"/>
              <Run Text=" "/>
              <Run Text="to"/>
              <Run Text=" "/>
              <Run Text="5"/>
              <Run Text=" "/>
              <Run Text="of"/>
              <Run Text=" "/>
              <Run Text="1,240"/>
              <Run Text=" gear orders"/>
            </TextBlock>

            <!-- Pagination Buttons -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="4"
                        x:Name="PaginationPanel"/>

          </Grid>
        </Border>

      </Grid>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- RIGHT: ORDER DETAIL PANEL                      -->
      <!-- ═══════════════════════════════════════════════ -->
      <Border Grid.Column="1"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0"
              Visibility="{Binding ShowDetailPanel, Converter={StaticResource BoolToVisibilityConverter}}">

        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <!-- Detail Header -->
          <Border Grid.Row="0"
                  BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                  BorderThickness="0,0,0,1"
                  Padding="20,16">

            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
              </Grid.ColumnDefinitions>

              <!-- Back / close button -->
              <Button Grid.Column="0"
                      Style="{StaticResource IconBtn}"
                      Click="CloseDetail_Click"
                      ToolTipService.ToolTip="Close">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE72B;"
                           FontSize="16"
                           Foreground="{ThemeResource TextFillColorSecondary}"/>
              </Button>

              <!-- Order ID -->
              <StackPanel Grid.Column="1" Margin="8,0,0,0" VerticalAlignment="Center">
                <TextBlock Text="Order Details"
                           FontSize="15"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimary}"/>
                <TextBlock Text="{Binding SelectedOrder.Id, Converter={StaticResource OrderAthIdConverter}}"
                           FontSize="12"
                           Foreground="{StaticResource TextFillColorTertiary}"
                           Margin="0,2,0,0"/>
              </StackPanel>

              <!-- Status badge -->
              <Border Grid.Column="2"
                      Style="{StaticResource StatusBadge}"
                      Background="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource PayBadgeBgConverter}}"
                      VerticalAlignment="Center">
                <TextBlock Text="{Binding SelectedOrder.PaymentStatus}"
                           FontSize="11"
                           FontWeight="SemiBold"
                           Foreground="{Binding SelectedOrder.PaymentStatus, Converter={StaticResource PayBadgeFgConverter}}"/>
              </Border>
            </Grid>
          </Border>

          <!-- Detail Content -->
          <ScrollViewer Grid.Row="1"
                        VerticalScrollBarVisibility="Auto"
                        Padding="20,16">

            <StackPanel Spacing="16">

              <!-- Athlete Profile Card -->
              <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                  <TextBlock Text="ATHLETE PROFILE" Style="{StaticResource SectionTitle}"/>

                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="Auto"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Avatar -->
                    <Border Grid.Column="0"
                            Width="44" Height="44"
                            CornerRadius="22"
                            Background="{StaticResource PurpleLightBrush}"
                            Margin="0,0,14,0">
                      <TextBlock Text="{Binding SelectedOrder.CustomerName, Converter={StaticResource InitialsConverter}}"
                                 FontSize="14"
                                 FontWeight="Bold"
                                 Foreground="{StaticResource PurpleBrush}"
                                 HorizontalAlignment="Center"
                                 VerticalAlignment="Center"/>
                    </Border>

                    <!-- Name + email -->
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="4">
                      <TextBlock Text="{Binding SelectedOrder.CustomerName}"
                                 FontSize="14"
                                 FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimary}"/>
                      <StackPanel Orientation="Horizontal" Spacing="4">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE715;"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorTertiary}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedOrder.CustomerPhone}"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondary}"/>
                      </StackPanel>
                    </StackPanel>

                    <!-- Message icon -->
                    <Button Grid.Column="2" Style="{StaticResource IconBtn}" ToolTipService.ToolTip="Message">
                      <TextBlock FontFamily="Segoe MDL2 Assets"
                                 Text="&#xE8BD;"
                                 FontSize="14"
                                 Foreground="{ThemeResource TextFillColorSecondary}"/>
                    </Button>
                  </Grid>
                </StackPanel>
              </Border>

              <!-- Gear Selection Card -->
              <Border Style="{StaticResource CardBorder}" Padding="16">
                <StackPanel Spacing="12">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="GEAR SELECTION" Style="{StaticResource SectionTitle}"/>
                    <Border Grid.Column="1"
                            Background="{StaticResource PurpleLightBrush}"
                            CornerRadius="6"
                            Padding="8,3">
                      <TextBlock FontSize="11"
                                 Foreground="{StaticResource PurpleBrush}">
                        <Run Text="{Binding SelectedOrderDetails.Count, Mode=OneWay}"/>
                        <Run Text=" items"/>
                      </TextBlock>
                    </Border>
                  </Grid>

                  <!-- Items list -->
                  <ItemsControl ItemsSource="{Binding SelectedOrderDetails}"
                                ItemTemplate="{StaticResource OrderItemTemplate}"/>

                  <TextBlock Text="No items in this order."
                             FontSize="13"
                             Foreground="{ThemeResource TextFillColorTertiary}"
                             HorizontalAlignment="Center"
                             Margin="0,4,0,0"
                             Visibility="{Binding SelectedOrderDetails.Count, Converter={StaticResource CountToVisibilityConverter}}"/>

                  <Border BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                          BorderThickness="0,1,0,0"
                          Margin="0,4,0,0"/>

                  <!-- Totals -->
                  <StackPanel Spacing="8">
                    <Grid>
                      <TextBlock Text="Subtotal"
                                 FontSize="13"
                                 Foreground="{ThemeResource TextFillColorSecondary}"/>
                      <TextBlock Text="{Binding SelectedOrder.TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                 FontSize="13"
                                 Foreground="{ThemeResource TextFillColorPrimary}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid>
                      <TextBlock Text="Express Delivery"
                                 FontSize="13"
                                 Foreground="{ThemeResource TextFillColorSecondary}"/>
                      <TextBlock Text="Free"
                                 FontSize="13"
                                 Foreground="#10B981"
                                 FontWeight="SemiBold"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                    <Border BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="0,1,0,0"/>
                    <Grid>
                      <TextBlock Text="Total"
                                 FontSize="15"
                                 FontWeight="Bold"
                                 Foreground="{ThemeResource TextFillColorPrimary}"/>
                      <TextBlock Text="{Binding SelectedOrder.TotalAmount, Converter={StaticResource CurrencyConverter}}"
                                 FontSize="18"
                                 FontWeight="Bold"
                                 Foreground="{StaticResource PurpleBrush}"
                                 HorizontalAlignment="Right"/>
                    </Grid>
                  </StackPanel>
                </StackPanel>
              </Border>

            </StackPanel>
          </ScrollViewer>

          <!-- Footer Actions -->
          <Border Grid.Row="2"
                  BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                  BorderThickness="0,1,0,0"
                  Padding="20,14">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="8"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>

              <Button Grid.Column="0"
                      Content="Order Manifest"
                      Style="{StaticResource SecondaryBtn}"
                      Click="OrderManifest_Click"/>

              <Button Grid.Column="2"
                      Content="Fulfill Gear"
                      Style="{StaticResource PrimaryBtn}"
                      Click="FulfillGear_Click"/>
            </Grid>
          </Border>

        </Grid>
      </Border>

      <!-- ═══════════════════════════════════════════════ -->
      <!-- RIGHT: Empty State (no order selected)          -->
      <!-- ═══════════════════════════════════════════════ -->
      <Border Grid.Column="1"
              Background="{ThemeResource SolidBackgroundFillColorBaseBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1,0,0,0"
              Visibility="{Binding ShowDetailPanel, Converter={StaticResource InverseBoolConverter}}">
        <StackPanel HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="12">
          <Border Width="72" Height="72" CornerRadius="36"
                  Background="{StaticResource PurpleLightBrush}">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                       Text="&#xE7BC;"
                       FontSize="32"
                       Foreground="{StaticResource PurpleBrush}"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>
          <TextBlock Text="Select an order"
                     FontSize="18" FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorPrimary}"
                     HorizontalAlignment="Center"/>
          <TextBlock Text="Click an order from the list to view its details."
                     FontSize="13"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     HorizontalAlignment="Center"
                     TextWrapping="Wrap"
                     MaxWidth="220"
                     TextAlignment="Center"/>
        </StackPanel>
      </Border>

    </Grid>

  </Grid>

</Page>
