<Page x:Class="MyShop.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="#F3F4F6">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <!-- Purple accent color -->
    <SolidColorBrush x:Key="PurpleBrush" Color="#7C3AED"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#F3F0FF"/>
    <SolidColorBrush x:Key="PurpleFaintBrush" Color="#EDE9FE"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="DarkTextBrush" Color="#1F2937"/>
    <SolidColorBrush x:Key="GrayTextBrush" Color="#6B7280"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="#9CA3AF"/>
    <SolidColorBrush x:Key="GreenBrush" Color="#059669"/>

    <!-- Card style -->
    <Style x:Key="CardBorder" TargetType="Border">
      <Setter Property="Background" Value="White"/>
      <Setter Property="BorderBrush" Value="#E5E7EB"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="12"/>
      <Setter Property="Padding" Value="20"/>
    </Style>

    <!-- KPI Value style -->
    <Style x:Key="KpiValueStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="28"/>
      <Setter Property="FontWeight" Value="Bold"/>
      <Setter Property="Foreground" Value="#1F2937"/>
    </Style>

    <!-- KPI Label style -->
    <Style x:Key="KpiLabelStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="12"/>
      <Setter Property="Foreground" Value="#6B7280"/>
      <Setter Property="Margin" Value="0,0,0,4"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="20">

      <!-- ═══════════════════════════ PAGE TITLE ═══════════════════════════ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Executive Dashboard"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#1F2937"/>
          <TextBlock Text="Real-time performance metrics for Elite Sports."
                     FontSize="13"
                     Foreground="#6B7280"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="10">

          <!-- Date picker button -->
          <Border Background="White"
                  BorderBrush="#E5E7EB"
                  BorderThickness="1"
                  CornerRadius="8"
                  Padding="12,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE787;" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
              <TextBlock Text="July 2026" FontSize="13" Foreground="#374151" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Create Order button -->
          <Border Background="#7C3AED"
                  CornerRadius="8"
                  Padding="14,8">
            <StackPanel Orientation="Horizontal" Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE710;" FontSize="13" Foreground="White" VerticalAlignment="Center"/>
              <TextBlock Text="Create Order" FontSize="13" FontWeight="SemiBold" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>

      <!-- ═══════════════════════════ KPI CARDS ═══════════════════════════ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Card 1: Total Products -->
        <Border Grid.Column="0" Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TOTAL PRODUCTS" Style="{StaticResource KpiLabelStyle}" FontWeight="SemiBold" CharacterSpacing="40"/>
            <TextBlock Text="{Binding TotalProductsDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,8"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74A;" FontSize="11" Foreground="#059669" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding TotalProductsTrend}" FontSize="11" Foreground="#059669" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Card 2: Today's Orders -->
        <Border Grid.Column="2" Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TODAY'S ORDERS" Style="{StaticResource KpiLabelStyle}" FontWeight="SemiBold" CharacterSpacing="40"/>
            <TextBlock Text="{Binding TotalTodayOrdersDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,8"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE74A;" FontSize="11" Foreground="#059669" VerticalAlignment="Center"/>
              <TextBlock Text="{Binding TodayOrdersTrend}" FontSize="11" Foreground="#059669" VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>

        <!-- Card 3: Today's Revenue -->
        <Border Grid.Column="4" Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TODAY'S REVENUE" Style="{StaticResource KpiLabelStyle}" FontWeight="SemiBold" CharacterSpacing="40"/>
            <TextBlock Text="{Binding TodayRevenueDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,8"/>
            <StackPanel Orientation="Horizontal" Spacing="4">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="{Binding RevenueTrendIcon}"
                         FontSize="11"
                         Foreground="{Binding RevenueTrendBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="{Binding TodayRevenueTrend}"
                         FontSize="11"
                         Foreground="{Binding RevenueTrendBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ═══════════════════════════ MONTHLY REVENUE CHART ═══════════════════════════ -->
      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Monthly Revenue Analysis"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="#1F2937"/>
              <TextBlock Text="Daily breakdown of revenue for the current month"
                         FontSize="12"
                         Foreground="#9CA3AF"
                         Margin="0,2,0,0"/>
            </StackPanel>
            <!-- Legend -->
            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
              <Border Width="8" Height="8" CornerRadius="4" Background="#7C3AED"/>
              <TextBlock Text="Revenue ($)" FontSize="12" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Chart Area -->
          <Border Margin="0,16,0,0"
                  Background="#FAFAFA"
                  CornerRadius="8"
                  Height="200"
                  BorderBrush="#F3F4F6"
                  BorderThickness="1">
            <Canvas x:Name="RevenueChartCanvas"
                    SizeChanged="RevenueChartCanvas_SizeChanged"/>
          </Border>

          <!-- X-axis labels -->
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="DAY 1" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1" Text="DAY 7" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="DAY 14" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="DAY 21" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="DAY 30" FontSize="11" Foreground="#9CA3AF" HorizontalAlignment="Right"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════ TWO COLUMN: LEFT + RIGHT ═══════════════════════════ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="16"/>
          <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ── LEFT COLUMN ── -->
        <StackPanel Grid.Column="0" Spacing="16">

          <!-- Top 5 Best Sellers -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,0,0,16">
                <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xECC7;" FontSize="14" Foreground="#7C3AED" VerticalAlignment="Center"/>
                <TextBlock Text="Top 5 Best Sellers"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="#1F2937"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <!-- Loading state -->
              <TextBlock Text="Loading..."
                         Foreground="#9CA3AF"
                         FontSize="13"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

              <!-- Best sellers list -->
              <ItemsControl ItemsSource="{Binding TopSellerItems}" Margin="0,0,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#F3F4F6"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,12"
                            Margin="0,0,0,12">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2937"/>
                          <TextBlock FontSize="11" Foreground="#9CA3AF" Margin="0,2,0,0"
                                     Text="{Binding SubInfo}"/>
                          <!-- Revenue badge -->
                          <Border Background="#ECFDF5"
                                  CornerRadius="4"
                                  Padding="6,2"
                                  Margin="0,4,0,0"
                                  HorizontalAlignment="Left">
                            <TextBlock FontSize="11" Foreground="#059669"
                                       Text="{Binding RevenueBadgeText}"/>
                          </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding QuantitySoldDisplay}"
                                     FontSize="16"
                                     FontWeight="Bold"
                                     Foreground="#1F2937"
                                     HorizontalAlignment="Right"/>
                          <TextBlock Text="sold"
                                     FontSize="10"
                                     Foreground="#9CA3AF"
                                     HorizontalAlignment="Right"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Low Stock Alerts -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BA;" FontSize="14" Foreground="#DC2626" VerticalAlignment="Center"/>
                  <TextBlock Text="Low Stock Alerts"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="#1F2937"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Restock All"
                           FontSize="12"
                           Foreground="#7C3AED"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </Grid>

              <!-- Table header -->
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="60"/>
                  <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0" Text="PRODUCT" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold" CharacterSpacing="40"/>
                <TextBlock Grid.Column="1" Text="STOCK" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold" HorizontalAlignment="Center" CharacterSpacing="40"/>
                <TextBlock Grid.Column="2" Text="ACTION" FontSize="10" Foreground="#9CA3AF" FontWeight="SemiBold" HorizontalAlignment="Right" CharacterSpacing="40"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding LowStockItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                      </Grid.ColumnDefinitions>

                      <TextBlock Grid.Column="0"
                                 Text="{Binding Name}"
                                 FontSize="12"
                                 Foreground="#374151"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"/>

                      <!-- Stock badge -->
                      <Border Grid.Column="1"
                              Background="#FEF2F2"
                              CornerRadius="4"
                              Padding="6,3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="11" Foreground="#DC2626" HorizontalAlignment="Center">
                          <Run Text="{Binding StockQuantity}"/>
                          <Run Text=" left"/>
                        </TextBlock>
                      </Border>

                      <!-- Order button -->
                      <Border Grid.Column="2"
                              Background="#F3F0FF"
                              CornerRadius="4"
                              Padding="8,3"
                              HorizontalAlignment="Right">
                        <TextBlock Text="Order"
                                   FontSize="11"
                                   Foreground="#7C3AED"
                                   FontWeight="SemiBold"/>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- ── RIGHT COLUMN ── -->
        <StackPanel Grid.Column="2" Spacing="16">

          <!-- Recent Orders -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BC;" FontSize="14" Foreground="#7C3AED" VerticalAlignment="Center"/>
                  <TextBlock Text="Recent Orders"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="#1F2937"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="View All Orders"
                           FontSize="12"
                           Foreground="#7C3AED"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding RecentOrders}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#F3F4F6"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,14"
                            Margin="0,0,0,14">
                      <StackPanel Spacing="6">
                        <!-- Customer & Amount row -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0"
                                     Text="{Binding CustomerName}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2937"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding TotalPriceDisplay}"
                                     FontSize="13"
                                     FontWeight="Bold"
                                     Foreground="#1F2937"
                                     HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Order meta -->
                        <TextBlock FontSize="11" Foreground="#9CA3AF">
                          <Run Text="Order #"/>
                          <Run Text="{Binding IdDisplay}"/>
                          <Run Text=" • "/>
                          <Run Text="{Binding TimeAgo}"/>
                        </TextBlock>

                        <!-- Status badge -->
                        <Border CornerRadius="4"
                                Padding="8,3"
                                HorizontalAlignment="Left"
                                Background="{Binding StatusBadgeBg, Converter={StaticResource HexToBrushConverter}}">
                          <TextBlock Text="{Binding Status}"
                                     FontSize="10"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding StatusBadgeFg, Converter={StaticResource HexToBrushConverter}}"/>
                        </Border>

                        <!-- Item line -->
                        <TextBlock Text="{Binding FirstItemLine}"
                                   FontSize="11"
                                   Foreground="#6B7280"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Inventory Sync Panel -->
          <Border Background="#7C3AED"
                  CornerRadius="12"
                  Padding="24,20">
            <StackPanel Spacing="8">
              <TextBlock Text="Inventory Sync?"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="White"/>
              <TextBlock Text="Ensure your local stock matches the online storefront across all channels."
                             FontSize="12"
                             Foreground="#DDD6FE"
                             TextWrapping="Wrap"
                             LineHeight="18"/>
              <!-- Sync button -->
              <Border Background="White"
                      CornerRadius="8"
                      Padding="14,10"
                      Margin="0,4,0,0"
                      HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal" Spacing="6">
                  <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE895;" FontSize="13" Foreground="#7C3AED" VerticalAlignment="Center"/>
                  <TextBlock Text="Run Full Sync"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="#7C3AED"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>

    </StackPanel>
  </ScrollViewer>
</Page>
