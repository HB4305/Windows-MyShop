<Page x:Class="MyShop.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <!-- Accent colors (matching Login) -->
    <SolidColorBrush x:Key="PurpleBrush"
        Color="#8B52FF"/>
    <SolidColorBrush x:Key="PurpleLightBrush"
        Color="#8B52FF"
        Opacity="0.12"/>
    <SolidColorBrush x:Key="PurpleFaintBrush"
        Color="#8B52FF"
        Opacity="0.08"/>

    <!-- Text brushes (Theme-aware) -->
    <StaticResource x:Key="DarkTextBrush"
        ResourceKey="TextFillColorPrimaryBrush"/>
    <StaticResource x:Key="GrayTextBrush"
        ResourceKey="TextFillColorSecondaryBrush"/>
    <StaticResource x:Key="MutedTextBrush"
        ResourceKey="TextFillColorTertiaryBrush"/>
    <SolidColorBrush x:Key="GreenBrush"
        Color="#10B981"/>
    <!-- Better green -->

    <!-- Card style -->
    <Style x:Key="CardBorder"
        TargetType="Border">
      <Setter Property="Background"
          Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="BorderBrush"
          Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness"
          Value="1"/>
      <Setter Property="CornerRadius"
          Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding"
          Value="20"/>
    </Style>

    <!-- KPI Value style -->
    <Style x:Key="KpiValueStyle"
        TargetType="TextBlock">
      <Setter Property="FontSize"
          Value="32"/>
      <Setter Property="FontWeight"
          Value="Bold"/>
      <Setter Property="Foreground"
          Value="{ThemeResource TextFillColorPrimary}"/>
    </Style>

    <!-- KPI Label style -->
    <Style x:Key="KpiLabelStyle"
        TargetType="TextBlock">
      <Setter Property="FontSize"
          Value="12"/>
      <Setter Property="Foreground"
          Value="{ThemeResource TextFillColorSecondary}"/>
      <Setter Property="Margin"
          Value="0,0,0,4"/>
    </Style>
  </Page.Resources>

  <StackPanel x:Name="RootStack"
              Margin="24"
        Spacing="20">
    <VisualStateManager.VisualStateGroups>
      <VisualStateGroup>
        <VisualState x:Name="NarrowState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="0"/>
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="HeaderActionsPanel.(Grid.Row)" Value="1"/>
            <Setter Target="HeaderActionsPanel.(Grid.Column)" Value="0"/>
            <Setter Target="HeaderActionsPanel.HorizontalAlignment" Value="Left"/>
            <Setter Target="HeaderActionsPanel.Margin" Value="0,12,0,0"/>
            <Setter Target="HeaderActionsPanel.Orientation" Value="Vertical"/>
            <Setter Target="KpiSpacerColumn1.Width" Value="0"/>
            <Setter Target="KpiSpacerColumn2.Width" Value="0"/>
            <Setter Target="KpiValueColumn2.Width" Value="0"/>
            <Setter Target="KpiValueColumn3.Width" Value="0"/>
            <Setter Target="KpiCardTwo.(Grid.Row)" Value="1"/>
            <Setter Target="KpiCardTwo.(Grid.Column)" Value="0"/>
            <Setter Target="KpiCardThree.(Grid.Row)" Value="2"/>
            <Setter Target="KpiCardThree.(Grid.Column)" Value="0"/>
            <Setter Target="MainSpacerColumn.Width" Value="0"/>
            <Setter Target="MainRightColumn.Width" Value="0"/>
            <Setter Target="RightContentPanel.(Grid.Row)" Value="1"/>
            <Setter Target="RightContentPanel.(Grid.Column)" Value="0"/>
            <Setter Target="RightContentPanel.Margin" Value="0,16,0,0"/>
          </VisualState.Setters>
        </VisualState>
        <VisualState x:Name="WideState">
          <VisualState.StateTriggers>
            <AdaptiveTrigger MinWindowWidth="1200"/>
          </VisualState.StateTriggers>
          <VisualState.Setters>
            <Setter Target="HeaderActionsPanel.(Grid.Row)" Value="0"/>
            <Setter Target="HeaderActionsPanel.(Grid.Column)" Value="1"/>
            <Setter Target="HeaderActionsPanel.HorizontalAlignment" Value="Stretch"/>
            <Setter Target="HeaderActionsPanel.Margin" Value="0"/>
            <Setter Target="HeaderActionsPanel.Orientation" Value="Horizontal"/>
            <Setter Target="KpiSpacerColumn1.Width" Value="16"/>
            <Setter Target="KpiSpacerColumn2.Width" Value="16"/>
            <Setter Target="KpiValueColumn2.Width" Value="*"/>
            <Setter Target="KpiValueColumn3.Width" Value="*"/>
            <Setter Target="KpiCardTwo.(Grid.Row)" Value="0"/>
            <Setter Target="KpiCardTwo.(Grid.Column)" Value="2"/>
            <Setter Target="KpiCardThree.(Grid.Row)" Value="0"/>
            <Setter Target="KpiCardThree.(Grid.Column)" Value="4"/>
            <Setter Target="MainSpacerColumn.Width" Value="16"/>
            <Setter Target="MainRightColumn.Width" Value="*"/>
            <Setter Target="RightContentPanel.(Grid.Row)" Value="0"/>
            <Setter Target="RightContentPanel.(Grid.Column)" Value="2"/>
            <Setter Target="RightContentPanel.Margin" Value="0"/>
          </VisualState.Setters>
        </VisualState>
      </VisualStateGroup>
    </VisualStateManager.VisualStateGroups>

      <!-- ═══════════════════════════ PAGE TITLE ═══════════════════════════ -->
      <Grid x:Name="HeaderGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Executive Dashboard"
                     FontSize="24"
                     FontWeight="Bold"
                     Foreground="{ThemeResource TextFillColorPrimary}"/>
          <TextBlock Text="Real-time performance metrics for ProSport Hub."
                     FontSize="13"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel x:Name="HeaderActionsPanel"
          Grid.Column="1"
            Orientation="Horizontal"
            Spacing="10">

          <!-- Date picker button -->
          <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1"
                  CornerRadius="{ThemeResource ControlCornerRadius}"
                  Padding="12,8">
            <StackPanel Orientation="Horizontal"
                Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE787;"
                  FontSize="13"
                  Foreground="{ThemeResource TextFillColorSecondary}"
                  VerticalAlignment="Center"/>
              <TextBlock Text="July 2026"
                  FontSize="13"
                  Foreground="{ThemeResource TextFillColorPrimary}"
                  VerticalAlignment="Center"/>
            </StackPanel>
          </Border>

          <!-- Create Order button -->
          <Button Background="{StaticResource PurpleBrush}"
                  CornerRadius="{ThemeResource ControlCornerRadius}"
                  Padding="18,10"
                  BorderThickness="0"
                  MinHeight="44"
                  Command="{Binding CreateOrderCommand}">
            <StackPanel Orientation="Horizontal"
                Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE710;"
                  FontSize="14"
                  Foreground="White"
                  VerticalAlignment="Center"/>
              <TextBlock Text="Create Order"
                  FontSize="14"
                  FontWeight="SemiBold"
                  Foreground="White"
                  VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </StackPanel>
      </Grid>

      <!-- ═══════════════════════════ KPI CARDS ═══════════════════════════ -->
      <Grid x:Name="KpiGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition x:Name="KpiSpacerColumn1" Width="16"/>
          <ColumnDefinition x:Name="KpiValueColumn2" Width="*"/>
          <ColumnDefinition x:Name="KpiSpacerColumn2" Width="16"/>
          <ColumnDefinition x:Name="KpiValueColumn3" Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Card 1: Total Products -->
        <Border Grid.Column="0"
            Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TOTAL PRODUCTS"
                Style="{StaticResource KpiLabelStyle}"
                FontWeight="SemiBold"
                CharacterSpacing="40"/>
            <TextBlock Text="{Binding TotalProductsDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>

        <!-- Card 2: Today's Orders -->
        <Border x:Name="KpiCardTwo"
          Grid.Column="2"
            Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TODAY'S ORDERS"
                Style="{StaticResource KpiLabelStyle}"
                FontWeight="SemiBold"
                CharacterSpacing="40"/>
            <TextBlock Text="{Binding TotalTodayOrdersDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>

        <!-- Card 3: Today's Revenue -->
        <Border x:Name="KpiCardThree"
          Grid.Column="4"
            Style="{StaticResource CardBorder}">
          <StackPanel>
            <TextBlock Text="TODAY'S REVENUE"
                Style="{StaticResource KpiLabelStyle}"
                FontWeight="SemiBold"
                CharacterSpacing="40"/>
            <TextBlock Text="{Binding TodayRevenueDisplay}"
                       Style="{StaticResource KpiValueStyle}"
                       Margin="0,4,0,0"/>
          </StackPanel>
        </Border>
      </Grid>

      <!-- ═══════════════════════════ MONTHLY REVENUE CHART ═══════════════════════════ -->
      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <Grid Margin="0,0,0,4">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0">
              <TextBlock Text="Monthly Revenue Analysis"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorPrimary}"/>
              <TextBlock Text="Daily breakdown of revenue for the current month"
                         FontSize="12"
                         Foreground="{ThemeResource TextFillColorTertiary}"
                         Margin="0,2,0,0"/>
            </StackPanel>
            <!-- Legend -->
            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                Spacing="6"
                VerticalAlignment="Center">
              <Border Width="8"
                  Height="8"
                  CornerRadius="4"
                  Background="{StaticResource PurpleBrush}"/>
              <TextBlock Text="Revenue ($)"
                  FontSize="12"
                  Foreground="{ThemeResource TextFillColorSecondary}"
                  VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Chart Area -->
          <Border Margin="0,16,0,0"
                  Background="{ThemeResource ControlFillColorDefaultBrush}"
                  CornerRadius="{ThemeResource ControlCornerRadius}"
                  Height="240"
                  BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                  BorderThickness="1">
            <Canvas x:Name="RevenueChartCanvas"
                    SizeChanged="RevenueChartCanvas_SizeChanged"/>
          </Border>

          <!-- X-axis labels -->
          <Grid Margin="0,6,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0"
                Text="DAY 1"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorTertiary}"
                HorizontalAlignment="Left"/>
            <TextBlock Grid.Column="1"
                Text="DAY 7"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorTertiary}"
                HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2"
                Text="DAY 14"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorTertiary}"
                HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3"
                Text="DAY 21"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorTertiary}"
                HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4"
                Text="DAY 30"
                FontSize="11"
                Foreground="{ThemeResource TextFillColorTertiary}"
                HorizontalAlignment="Right"/>
          </Grid>
        </StackPanel>
      </Border>

      <!-- ═══════════════════════════ TWO COLUMN: LEFT + RIGHT ═══════════════════════════ -->
      <Grid x:Name="MainContentGrid">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition x:Name="MainSpacerColumn" Width="16"/>
          <ColumnDefinition x:Name="MainRightColumn" Width="*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ── LEFT COLUMN ── -->
        <StackPanel Grid.Column="0"
            Spacing="16">

          <!-- Top 5 Best Sellers -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <StackPanel Orientation="Horizontal"
                  Spacing="8"
                  Margin="0,0,0,16">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                    Text="&#xECC7;"
                    FontSize="14"
                    Foreground="{StaticResource PurpleBrush}"
                    VerticalAlignment="Center"/>
                <TextBlock Text="Top 5 Best Sellers"
                           FontSize="15"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimary}"
                           VerticalAlignment="Center"/>
              </StackPanel>

              <!-- Loading state -->
              <TextBlock Text="Loading..."
                         Foreground="{ThemeResource TextFillColorTertiary}"
                         FontSize="13"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

              <!-- Best sellers list -->
              <ItemsControl ItemsSource="{Binding TopSellerItems}"
                  Margin="0,0,0,0">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="{ThemeResource ControlStrokeColorSecondaryBrush}"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,12"
                            Margin="0,0,0,12">
                      <Grid>
                        <Grid.ColumnDefinitions>
                          <ColumnDefinition Width="*"/>
                          <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                          <TextBlock Text="{Binding Name}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="{ThemeResource TextFillColorPrimary}"/>
                          <TextBlock FontSize="11"
                              Foreground="{ThemeResource TextFillColorTertiary}"
                              Margin="0,2,0,0"
                                     Text="{Binding SubInfo}"/>
                          <!-- Revenue badge -->
                          <Border Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                  CornerRadius="4"
                                  Padding="6,2"
                                  Margin="0,4,0,0"
                                  HorizontalAlignment="Left">
                            <TextBlock FontSize="11"
                                Foreground="{StaticResource GreenBrush}"
                                       Text="{Binding RevenueBadgeText}"/>
                          </Border>
                        </StackPanel>

                        <StackPanel Grid.Column="1"
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center">
                          <TextBlock Text="{Binding QuantitySoldDisplay}"
                                     FontSize="16"
                                     FontWeight="Bold"
                                     Foreground="{ThemeResource TextFillColorPrimary}"
                                     HorizontalAlignment="Right"/>
                          <TextBlock Text="sold"
                                     FontSize="10"
                                     Foreground="{ThemeResource TextFillColorTertiary}"
                                     HorizontalAlignment="Right"/>
                        </StackPanel>
                      </Grid>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Low Stock Alerts -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                      Text="&#xE7BA;"
                      FontSize="14"
                      Foreground="{ThemeResource SystemFillColorCriticalBrush}"
                      VerticalAlignment="Center"/>
                  <TextBlock Text="Low Stock Alerts"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorPrimary}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="Restock All"
                           FontSize="12"
                           Foreground="{StaticResource PurpleBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </Grid>

              <!-- Table header -->
              <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="60"/>
                  <ColumnDefinition Width="60"/>
                </Grid.ColumnDefinitions>
                <TextBlock Grid.Column="0"
                    Text="PRODUCT"
                    FontSize="10"
                    Foreground="{ThemeResource TextFillColorTertiary}"
                    FontWeight="SemiBold"
                    CharacterSpacing="40"/>
                <TextBlock Grid.Column="1"
                    Text="STOCK"
                    FontSize="10"
                    Foreground="{ThemeResource TextFillColorTertiary}"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Center"
                    CharacterSpacing="40"/>
                <TextBlock Grid.Column="2"
                    Text="ACTION"
                    FontSize="10"
                    Foreground="{ThemeResource TextFillColorTertiary}"
                    FontWeight="SemiBold"
                    HorizontalAlignment="Right"
                    CharacterSpacing="40"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding LowStockItems}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Grid Margin="0,0,0,10">
                      <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="60"/>
                        <ColumnDefinition Width="60"/>
                      </Grid.ColumnDefinitions>

                      <TextBlock Grid.Column="0"
                                 Text="{Binding Name}"
                                 FontSize="12"
                                 Foreground="{ThemeResource TextFillColorPrimary}"
                                 TextTrimming="CharacterEllipsis"
                                 VerticalAlignment="Center"/>

                      <!-- Stock badge -->
                      <Border Grid.Column="1"
                              Background="#FEF2F2"
                              CornerRadius="4"
                              Padding="6,3"
                              HorizontalAlignment="Center"
                              VerticalAlignment="Center">
                        <TextBlock FontSize="11"
                            Foreground="#DC2626"
                            HorizontalAlignment="Center">
                          <Run Text="{Binding StockQuantity}"/>
                          <Run Text=" left"/>
                        </TextBlock>
                      </Border>

                      <!-- Order button -->
                      <Border Grid.Column="2"
                              Background="{StaticResource PurpleLightBrush}"
                              CornerRadius="4"
                              Padding="8,3"
                              HorizontalAlignment="Right">
                        <TextBlock Text="Order"
                                   FontSize="11"
                                   Foreground="{StaticResource PurpleBrush}"
                                   FontWeight="SemiBold"/>
                      </Border>
                    </Grid>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

        </StackPanel>

        <!-- ── RIGHT COLUMN ── -->
        <StackPanel x:Name="RightContentPanel"
          Grid.Column="2"
            Spacing="16">

          <!-- Recent Orders -->
          <Border Style="{StaticResource CardBorder}">
            <StackPanel>
              <Grid Margin="0,0,0,16">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Grid.Column="0"
                    Orientation="Horizontal"
                    Spacing="8">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                      Text="&#xE7BC;"
                      FontSize="14"
                      Foreground="{StaticResource PurpleBrush}"
                      VerticalAlignment="Center"/>
                  <TextBlock Text="Recent Orders"
                             FontSize="15"
                             FontWeight="SemiBold"
                             Foreground="{ThemeResource TextFillColorPrimary}"
                             VerticalAlignment="Center"/>
                </StackPanel>
                <TextBlock Grid.Column="1"
                           Text="View All Orders"
                           FontSize="12"
                           Foreground="{StaticResource PurpleBrush}"
                           FontWeight="SemiBold"
                           VerticalAlignment="Center"/>
              </Grid>

              <ItemsControl ItemsSource="{Binding RecentOrders}">
                <ItemsControl.ItemTemplate>
                  <DataTemplate>
                    <Border BorderBrush="#F3F4F6"
                            BorderThickness="0,0,0,1"
                            Padding="0,0,0,14"
                            Margin="0,0,0,14">
                      <StackPanel Spacing="6">
                        <!-- Customer & Amount row -->
                        <Grid>
                          <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                          </Grid.ColumnDefinitions>
                          <TextBlock Grid.Column="0"
                                     Text="{Binding CustomerName}"
                                     FontSize="13"
                                     FontWeight="SemiBold"
                                     Foreground="#1F2937"/>
                          <TextBlock Grid.Column="1"
                                     Text="{Binding TotalPriceDisplay}"
                                     FontSize="13"
                                     FontWeight="Bold"
                                     Foreground="#1F2937"
                                     HorizontalAlignment="Right"/>
                        </Grid>

                        <!-- Order meta -->
                        <TextBlock FontSize="11"
                            Foreground="{ThemeResource TextFillColorTertiary}">
                          <Run Text="Order #"/>
                          <Run Text="{Binding IdDisplay}"/>
                          <Run Text=" • "/>
                          <Run Text="{Binding TimeAgo}"/>
                        </TextBlock>

                        <!-- Status badge -->
                        <Border CornerRadius="4"
                                Padding="8,3"
                                HorizontalAlignment="Left"
                                Background="{Binding StatusBadgeBg, Converter={StaticResource HexToBrushConverter}}">
                          <TextBlock Text="{Binding Status}"
                                     FontSize="10"
                                     FontWeight="SemiBold"
                                     Foreground="{Binding StatusBadgeFg, Converter={StaticResource HexToBrushConverter}}"/>
                        </Border>

                        <!-- Item line -->
                        <TextBlock Text="{Binding FirstItemLine}"
                                   FontSize="11"
                                   Foreground="{ThemeResource TextFillColorSecondary}"
                                   TextTrimming="CharacterEllipsis"/>
                      </StackPanel>
                    </Border>
                  </DataTemplate>
                </ItemsControl.ItemTemplate>
              </ItemsControl>
            </StackPanel>
          </Border>

          <!-- Inventory Sync Panel -->
          <Border Background="{StaticResource PurpleBrush}"
                  CornerRadius="12"
                  Padding="24,20">
            <StackPanel Spacing="8">
              <TextBlock Text="Inventory Sync?"
                         FontSize="16"
                         FontWeight="Bold"
                         Foreground="White"/>
              <TextBlock Text="Ensure your local stock matches the online storefront across all channels."
                         FontSize="12"
                         Foreground="White"
                  Opacity="0.8"
                         TextWrapping="Wrap"
                         LineHeight="18"/>
              <!-- Sync button -->
              <Border Background="White"
                      CornerRadius="8"
                      Padding="14,10"
                      Margin="0,4,0,0"
                      HorizontalAlignment="Left">
                <StackPanel Orientation="Horizontal"
                    Spacing="6">
                  <TextBlock FontFamily="Segoe MDL2 Assets"
                      Text="&#xE895;"
                      FontSize="13"
                      Foreground="{StaticResource PurpleBrush}"
                      VerticalAlignment="Center"/>
                  <TextBlock Text="Run Full Sync"
                             FontSize="13"
                             FontWeight="SemiBold"
                             Foreground="{StaticResource PurpleBrush}"
                             VerticalAlignment="Center"/>
                </StackPanel>
              </Border>
            </StackPanel>
          </Border>

        </StackPanel>
      </Grid>

    </StackPanel>
</Page>
