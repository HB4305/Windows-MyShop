<Page x:Class="MyShop.Views.SuppliersPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:CurrencyFormatter x:Key="CurrencyFormatter"/>
    <SolidColorBrush x:Key="Accent" Color="#8B52FF"/>
    <SolidColorBrush x:Key="AccentHover" Color="#7A42E5"/>
  </Page.Resources>

  <Grid Padding="24">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Header -->
    <StackPanel Grid.Row="0" Spacing="4" Margin="0,0,0,24">
      <TextBlock Text="Suppliers Management" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimary}"/>
      <TextBlock Text="Manage your suppliers and track supply order history." Foreground="{ThemeResource TextFillColorSecondary}"/>
    </StackPanel>

    <!-- Tabs -->
    <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
      <Button x:Name="TabSuppliers" Content="Suppliers" Click="TabSuppliers_Click" 
              Style="{StaticResource AccentButtonStyle}" Padding="16,8" CornerRadius="8"/>
      <Button x:Name="TabSupplyOrders" Content="Supply History" Click="TabSupplyOrders_Click" 
              Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" Padding="16,8" CornerRadius="8"/>
    </StackPanel>

    <!-- Content: Suppliers -->
    <Grid x:Name="SuppliersGrid" Grid.Row="2">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Toolbar -->
      <Grid Grid.Row="0" Margin="0,0,0,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>
        <StackPanel Orientation="Horizontal" Spacing="8">
          <TextBox PlaceholderText="Search by name, phone..." Width="250" Text="{Binding SearchSupplierKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
          <Button Content="Search" Command="{Binding SearchSuppliersCommand}"/>
        </StackPanel>
        <Button Grid.Column="1" Content="Add Supplier" Click="AddSupplier_Click" Background="{StaticResource Accent}" Foreground="White" CornerRadius="8">
          <Button.ContentTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                <TextBlock Text="Add Supplier" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </Button.ContentTemplate>
        </Button>
      </Grid>

      <!-- DataGrid -->
      <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
        <ListView ItemsSource="{Binding Suppliers}" SelectionMode="None">
          <ListView.Header>
            <Grid Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="Auto" MinWidth="100"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="Supplier Name" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Contact Phone" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Type" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Actions" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
          </ListView.Header>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="16,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="2*"/>
                  <ColumnDefinition Width="1.5*"/>
                  <ColumnDefinition Width="1.5*"/>
                  <ColumnDefinition Width="Auto" MinWidth="100"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding ContactPhone}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding SupplierType}" VerticalAlignment="Center"/>
                <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
                  <Button Click="EditSupplier_Click" Background="Transparent" ToolTipService.ToolTip="Edit">
                    <FontIcon Glyph="&#xE70F;" FontSize="14" Foreground="{StaticResource Accent}"/>
                  </Button>
                  <Button Command="{Binding DataContext.DeleteSupplierCommand, ElementName=SuppliersGrid}" CommandParameter="{Binding}" Background="Transparent" ToolTipService.ToolTip="Delete">
                    <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="Red"/>
                  </Button>
                </StackPanel>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <!-- Pagination -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,16,0,0">
        <Button Command="{Binding PrevSupplierPageCommand}" IsEnabled="{Binding SupplierCurrentPage, Converter={StaticResource NotEqualConverter}, ConverterParameter=1}" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="1" Width="36" Height="36" Padding="0"/>
        <TextBlock VerticalAlignment="Center">
          <Run Text="Page "/>
          <Run Text="{Binding SupplierCurrentPage}"/>
          <Run Text=" of "/>
          <Run Text="{Binding SupplierTotalPages}"/>
        </TextBlock>
        <Button Command="{Binding NextSupplierPageCommand}" IsEnabled="{Binding SupplierCurrentPage, Converter={StaticResource LessThanConverter}, ConverterParameter={Binding SupplierTotalPages}}" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="1" Width="36" Height="36" Padding="0"/>
      </StackPanel>
    </Grid>

    <!-- Content: Supply Orders -->
    <Grid x:Name="SupplyOrdersGrid" Grid.Row="2" Visibility="Collapsed">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Toolbar -->
      <Grid Grid.Row="0" Margin="0,0,0,16">
        <Button HorizontalAlignment="Right" Content="Create Supply Order" Click="CreateSupplyOrder_Click" Background="{StaticResource Accent}" Foreground="White" CornerRadius="8">
          <Button.ContentTemplate>
            <DataTemplate>
              <StackPanel Orientation="Horizontal" Spacing="8">
                <FontIcon Glyph="&#xE710;" FontSize="14"/>
                <TextBlock Text="Create Supply Order" VerticalAlignment="Center"/>
              </StackPanel>
            </DataTemplate>
          </Button.ContentTemplate>
        </Button>
      </Grid>

      <!-- DataGrid -->
      <Border Grid.Row="1" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8">
        <ListView ItemsSource="{Binding SupplyOrders}" SelectionMode="None">
          <ListView.Header>
            <Grid Padding="16,12" Background="{ThemeResource LayerFillColorDefaultBrush}">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="1.5*"/>
              </Grid.ColumnDefinitions>
              <TextBlock Text="Order ID" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="1" Text="Supplier" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="2" Text="Import Date" FontWeight="SemiBold"/>
              <TextBlock Grid.Column="3" Text="Total Cost" FontWeight="SemiBold" HorizontalAlignment="Right"/>
            </Grid>
          </ListView.Header>
          <ListView.ItemTemplate>
            <DataTemplate>
              <Grid Padding="16,12">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="1*"/>
                  <ColumnDefinition Width="2*"/>
                  <ColumnDefinition Width="1.5*"/>
                  <ColumnDefinition Width="1.5*"/>
                </Grid.ColumnDefinitions>
                <TextBlock Text="{Binding IdDisplay}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                <TextBlock Grid.Column="1" Text="{Binding SupplierName}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="2" Text="{Binding ImportDateDisplay}" VerticalAlignment="Center"/>
                <TextBlock Grid.Column="3" Text="{Binding TotalCost, Converter={StaticResource CurrencyFormatter}}" VerticalAlignment="Center" HorizontalAlignment="Right" FontWeight="SemiBold"/>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <!-- Pagination -->
      <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Center" Spacing="16" Margin="0,16,0,0">
        <Button Command="{Binding PrevOrderPageCommand}" IsEnabled="{Binding OrderCurrentPage, Converter={StaticResource NotEqualConverter}, ConverterParameter=1}" Content="&#xE72B;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="1" Width="36" Height="36" Padding="0"/>
        <TextBlock VerticalAlignment="Center">
          <Run Text="Page "/>
          <Run Text="{Binding OrderCurrentPage}"/>
          <Run Text=" of "/>
          <Run Text="{Binding OrderTotalPages}"/>
        </TextBlock>
        <Button Command="{Binding NextOrderPageCommand}" IsEnabled="{Binding OrderCurrentPage, Converter={StaticResource LessThanConverter}, ConverterParameter={Binding OrderTotalPages}}" Content="&#xE72A;" FontFamily="Segoe MDL2 Assets" Background="Transparent" BorderThickness="1" Width="36" Height="36" Padding="0"/>
      </StackPanel>
    </Grid>

  </Grid>
</Page>
