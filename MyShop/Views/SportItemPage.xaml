<Page x:Class="MyShop.Views.SportItemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:m="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      xmlns:controls="using:MyShop.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:FirstImageConverter x:Key="FirstImageConverter"/>
    <conv:CurrencyFormatter x:Key="CurrencyFormatter"/>
    <conv:SportItemStockPercentConverter x:Key="SportItemStockPercentConverter"/>
    <conv:SportItemStockBarForegroundConverter x:Key="SportItemStockBarForegroundConverter"/>
    <conv:SportItemStatusTextConverter x:Key="SportItemStatusTextConverter"/>
    <conv:SportItemStatusBadgeBackgroundConverter x:Key="SportItemStatusBadgeBackgroundConverter"/>
    <conv:SportItemStatusBadgeForegroundConverter x:Key="SportItemStatusBadgeForegroundConverter"/>

    <SolidColorBrush x:Key="SportPurpleBrush" Color="#8B52FF"/>
    <SolidColorBrush x:Key="SportPurpleLightBrush" Color="#8B52FF" Opacity="0.12"/>
    <StaticResource x:Key="SportHeaderBgBrush" ResourceKey="ControlFillColorSecondaryBrush"/>
    <StaticResource x:Key="SportHeaderTextBrush" ResourceKey="TextFillColorPrimaryBrush"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="#DC2626"/>

    <Style x:Key="BulkImportButtonStyle" TargetType="Button">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding" Value="14,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="MinHeight" Value="48"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="PurplePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
      <Setter Property="Background" Value="{StaticResource SportPurpleBrush}"/>
      <Setter Property="Foreground" Value="White"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding" Value="16,10"/>
      <Setter Property="FontSize" Value="13"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="MinHeight" Value="48"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="PagerIconButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding" Value="10,8"/>
      <Setter Property="MinWidth" Value="40"/>
      <Setter Property="MinHeight" Value="40"/>
    </Style>

    <!-- Hai panel Price / Sort: cùng kiểu khung -->
    <Style x:Key="FilterPanelCardStyle" TargetType="Border">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding" Value="18,16"/>
      <Setter Property="MinHeight" Value="200"/>
      <Setter Property="VerticalAlignment" Value="Stretch"/>
    </Style>

    <Style x:Key="FilterSectionTitleStyle" TargetType="TextBlock">
      <Setter Property="FontSize" Value="15"/>
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
    </Style>

    <Style x:Key="FilterComboBoxStyle" TargetType="ComboBox" BasedOn="{StaticResource DefaultComboBoxStyle}">
      <Setter Property="HorizontalAlignment" Value="Stretch"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="MinHeight" Value="40"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="Padding" Value="12,8"/>
    </Style>

    <Style x:Key="FilterCheckBoxStyle" TargetType="CheckBox">
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorPrimary}"/>
      <Setter Property="FontSize" Value="13"/>
    </Style>
  </Page.Resources>

  <Grid Margin="24,20">
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <!-- Top bar: search + actions -->
    <Grid Grid.Row="0" ColumnSpacing="14" Margin="0,0,0,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0"
              MinHeight="48"
              VerticalAlignment="Stretch"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="{ThemeResource ControlCornerRadius}"
              Padding="12,8">
        <Grid ColumnSpacing="10">
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <FontIcon Grid.Column="0" Glyph="&#xE721;" FontSize="16" Foreground="{ThemeResource TextFillColorSecondary}" VerticalAlignment="Center"/>
          <TextBox x:Name="SearchBox"
                   Grid.Column="1"
                   PlaceholderText="Search sports gear or brand..."
                   Text="{Binding SearchKeyword, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   KeyDown="OnSearchKeyDown"
                   BorderThickness="0"
                   Background="Transparent"
                   Padding="0,6"
                   VerticalAlignment="Center"/>
          <Button Grid.Column="2"
                  Content="&#xE721;"
                  FontFamily="Segoe MDL2 Assets"
                  Command="{Binding SearchCommand}"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="8"
                  Foreground="{StaticResource SportPurpleBrush}"
                  ToolTipService.ToolTip="Search"/>
        </Grid>
      </Border>

      <Button Grid.Column="1"
              Style="{StaticResource BulkImportButtonStyle}"
              ToolTipService.ToolTip="Coming soon">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE898;" FontSize="15"/>
          <TextBlock Text="Bulk Import" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>

      <Button Grid.Column="2"
              Style="{StaticResource PurplePrimaryButtonStyle}"
              Click="OnAddItemClick">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="15" Foreground="White"/>
          <TextBlock Text="New Equipment" VerticalAlignment="Center"/>
        </StackPanel>
      </Button>
    </Grid>

    <Rectangle Grid.Row="1" Height="1" Margin="0,0,0,20" HorizontalAlignment="Stretch"
               Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>


    <!-- Price range & Sort: hai box trắng tách riêng -->
    <Grid Grid.Row="3" ColumnSpacing="16" Margin="0,0,0,14">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Border Grid.Column="0" Style="{StaticResource FilterPanelCardStyle}">
        <StackPanel Spacing="12">
          <TextBlock Text="Price Range" Style="{StaticResource FilterSectionTitleStyle}"/>
          <controls:PriceRangeSlider
              Minimum="0"
              Maximum="500"
              LowerValue="{Binding PriceUsdMin, Mode=TwoWay}"
              UpperValue="{Binding PriceUsdMax, Mode=TwoWay}"/>
          <Grid Margin="0,2,0,0">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="$0" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}"/>
            <TextBlock Grid.Column="1" Text="$125" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="$250" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="$375" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}" HorizontalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="$500+" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}" HorizontalAlignment="Right"/>
          </Grid>
          <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="{ThemeResource ControlCornerRadius}" Padding="12,10">
            <TextBlock Text="{Binding PriceRangeSummary}"
                       FontSize="13"
                       FontWeight="SemiBold"
                       Foreground="{StaticResource SportPurpleBrush}"/>
          </Border>
        </StackPanel>
      </Border>

      <Border Grid.Column="1" Style="{StaticResource FilterPanelCardStyle}">
        <StackPanel Spacing="16" VerticalAlignment="Top">
          <TextBlock Text="Sort" Style="{StaticResource FilterSectionTitleStyle}"/>
          <ComboBox Style="{StaticResource FilterComboBoxStyle}"
                    SelectedValuePath="Tag"
                    SelectedValue="{Binding SortField, Mode=TwoWay}"
                    SelectionChanged="OnSortComboSelectionChanged">
            <ComboBoxItem Content="Name" Tag="name"/>
            <ComboBoxItem Content="Selling price" Tag="selling_price"/>
            <ComboBoxItem Content="Created" Tag="id"/>
          </ComboBox>
          <CheckBox Style="{StaticResource FilterCheckBoxStyle}"
                    Content="Ascending"
                    IsChecked="{Binding IsSortAscending, Mode=TwoWay}"/>
        </StackPanel>
      </Border>
    </Grid>

    <!-- Table -->
    <Border Grid.Row="4"
            Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
            BorderThickness="1"
            CornerRadius="{ThemeResource ControlCornerRadius}"
            Padding="0">
      <ScrollViewer HorizontalScrollBarVisibility="Auto"
                    HorizontalScrollMode="Enabled"
                    VerticalScrollBarVisibility="Disabled"
                    VerticalScrollMode="Disabled">
        <Grid MinWidth="820">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"
                Padding="16,14">
          <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*" MinWidth="200"/>
              <ColumnDefinition Width="130"/>
              <ColumnDefinition Width="96"/>
              <ColumnDefinition Width="168"/>
              <ColumnDefinition Width="118"/>
              <ColumnDefinition Width="40"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="PRODUCT" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SportHeaderTextBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="1" Text="CATEGORY" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SportHeaderTextBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="2" Text="PRICE" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SportHeaderTextBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="3" Text="STOCK LEVEL" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SportHeaderTextBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="4" Text="STATUS" FontSize="11" FontWeight="SemiBold"
                       Foreground="{StaticResource SportHeaderTextBrush}" VerticalAlignment="Center"/>
            <TextBlock Grid.Column="5" Text="" HorizontalAlignment="Center"/>
          </Grid>
        </Border>

        <ListView Grid.Row="1"
                  ItemsSource="{Binding Items}"
                  IsItemClickEnabled="True"
                  ItemClick="OnItemClick"
                  Padding="0,4,0,8"
                  SelectionMode="None">
          <ListView.ItemContainerStyle>
            <Style TargetType="ListViewItem">
              <Setter Property="Padding" Value="16,0"/>
              <Setter Property="MinHeight" Value="64"/>
              <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
              <Setter Property="Background" Value="Transparent"/>
            </Style>
          </ListView.ItemContainerStyle>
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="m:SportItemListRow">
              <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="0,10">
                <Grid ColumnSpacing="12">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" MinWidth="200"/>
                    <ColumnDefinition Width="130"/>
                    <ColumnDefinition Width="96"/>
                    <ColumnDefinition Width="168"/>
                    <ColumnDefinition Width="118"/>
                    <ColumnDefinition Width="40"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Width="44" Height="44" CornerRadius="8" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                      <Image Source="{x:Bind Item.ImageUrls, Converter={StaticResource FirstImageConverter}}"
                             Width="44" Height="44" Stretch="UniformToFill"/>
                    </Border>
                    <TextBlock Text="{x:Bind Item.Name}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"
                               VerticalAlignment="Center" TextTrimming="CharacterEllipsis" MaxLines="2"/>
                  </StackPanel>

                  <TextBlock Grid.Column="1" Text="{x:Bind CategoryName}" VerticalAlignment="Center"
                             Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13" TextTrimming="CharacterEllipsis"/>

                  <TextBlock Grid.Column="2"
                             Text="{x:Bind Item.SellingPrice, Converter={StaticResource CurrencyFormatter}}"
                             VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>

                  <StackPanel Grid.Column="3" VerticalAlignment="Center" Spacing="4">
                    <ProgressBar Minimum="0" Maximum="100"
                                 Value="{Binding Item, Converter={StaticResource SportItemStockPercentConverter}}"
                                 Foreground="{Binding Item, Converter={StaticResource SportItemStockBarForegroundConverter}}"
                                 Background="{ThemeResource ControlFillColorSecondaryBrush}"
                                 Height="6"/>
                    <TextBlock FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}">
                      <Run Text="{x:Bind Item.EffectiveStockQuantity}"/>
                      <Run Text=" in stock"/>
                    </TextBlock>
                  </StackPanel>

                    <Border Grid.Column="4"
                          CornerRadius="20"
                          Padding="10,5"
                          HorizontalAlignment="Left"
                          VerticalAlignment="Center"
                          Background="{Binding Item, Converter={StaticResource SportItemStatusBadgeBackgroundConverter}}">
                    <TextBlock FontSize="11" FontWeight="SemiBold"
                               Foreground="{Binding Item, Converter={StaticResource SportItemStatusBadgeForegroundConverter}}"
                               Text="{Binding Item, Converter={StaticResource SportItemStatusTextConverter}}"/>
                  </Border>

                  <FontIcon Grid.Column="5"
                            Glyph="&#xE10C;"
                            FontSize="16"
                            Foreground="{ThemeResource TextFillColorSecondary}"
                            VerticalAlignment="Center"
                            HorizontalAlignment="Center"
                            IsHitTestVisible="False"/>
                </Grid>
              </Border>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>

        <Border Grid.Row="2"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,1,0,0"
                Padding="16,14">
          <Grid>
            <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13" HorizontalAlignment="Left">
              <Run Text="Showing "/>
              <Run Text="{Binding DisplayFrom}"/>
              <Run Text=" to "/>
              <Run Text="{Binding DisplayTo}"/>
              <Run Text=" of "/>
              <Run Text="{Binding TotalItems}"/>
              <Run Text=" sports items"/>
            </TextBlock>

            <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
              <Button Style="{StaticResource PagerIconButtonStyle}"
                      Command="{Binding PreviousPageCommand}">
                <FontIcon Glyph="&#xE76B;" FontSize="14"/>
              </Button>
              <Border Background="{StaticResource SportPurpleBrush}" CornerRadius="8" Padding="12,8" MinWidth="40" VerticalAlignment="Center">
                <TextBlock Text="{Binding CurrentPage}"
                           Foreground="White"
                           FontWeight="SemiBold"
                           HorizontalAlignment="Center"/>
              </Border>
              <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiary}" FontSize="13" Margin="4,0">
                <Run Text="/ "/><Run Text="{Binding TotalPages}"/>
              </TextBlock>
              <Button Style="{StaticResource PagerIconButtonStyle}"
                      Command="{Binding NextPageCommand}">
                <FontIcon Glyph="&#xE76C;" FontSize="14"/>
              </Button>
            </StackPanel>
          </Grid>
        </Border>
        </Grid>
      </ScrollViewer>
    </Border>

    <TextBlock Grid.Row="5"
               Margin="0,12,0,0"
               Text="{Binding ErrorMessage}"
               Foreground="{StaticResource ErrorBrush}"
               TextWrapping="Wrap"
               HorizontalAlignment="Center"
               Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
  </Grid>
</Page>
