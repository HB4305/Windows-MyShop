<Page x:Class="MyShop.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="#F3F4F6">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════ SIDEBAR ═══════════════════════════════════ -->
    <Grid Grid.Column="0" Background="#FFFFFF">

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Brand Header -->
      <StackPanel Grid.Row="0" Margin="20,20,20,24">
        <!-- Logo circle -->
        <Border Width="40" Height="40" CornerRadius="20" Background="#7C3AED" HorizontalAlignment="Left" Margin="0,0,0,10">
          <TextBlock Text="ES"
                     Foreground="White"
                     FontWeight="Bold"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="Elite Sports"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="#1F2937"/>
      </StackPanel>

      <!-- Navigation Menu -->
      <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,0,12,0" Spacing="2">

          <!-- SECTION: MAIN -->
          <TextBlock Text="MAIN"
                     FontSize="10"
                     FontWeight="SemiBold"
                     Foreground="#9CA3AF"
                     Margin="8,0,0,8"
                     CharacterSpacing="60"/>

          <!-- Dashboard -->
          <Button x:Name="NavDashboard"
                  Click="NavDashboard_Click"
                  Tag="Dashboard"
                  Background="#F3F0FF"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <Button.Resources>
              <Style TargetType="Button" BasedOn="{StaticResource ButtonRevealStyle}">
                <Setter Property="Padding" Value="10,8"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
                <Setter Property="Background" Value="#F3F0FF"/>
              </Style>
            </Button.Resources>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE80F;" FontSize="14" Foreground="#7C3AED" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Dashboard" FontSize="13" FontWeight="SemiBold" Foreground="#7C3AED" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Reports -->
          <Button x:Name="NavReports"
                  Click="NavReports_Click"
                  Tag="Reports"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9F9;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Reports" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Product Catalog -->
          <Button x:Name="NavProductCatalog"
                  Click="NavProductCatalog_Click"
                  Tag="ProductCatalog"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BF;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Product Catalog" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Orders Management -->
          <Button x:Name="NavOrders"
                  Click="NavOrders_Click"
                  Tag="OrdersManagement"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7BC;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Orders Management" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Sales Stats -->
          <Button x:Name="NavSalesStats"
                  Click="NavSalesStats_Click"
                  Tag="SalesStats"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE9D2;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Sales Stats" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- SECTION: MANAGEMENT -->
          <TextBlock Text="MANAGEMENT"
                     FontSize="10"
                     FontWeight="SemiBold"
                     Foreground="#9CA3AF"
                     Margin="8,16,0,8"
                     CharacterSpacing="60"/>

          <!-- Suppliers -->
          <Button x:Name="NavSuppliers"
                  Click="NavSuppliers_Click"
                  Tag="Suppliers"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8B8;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Suppliers" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Category -->
          <Button x:Name="NavCategory"
                  Click="NavCategory_Click"
                  Tag="Category"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE8EC;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Category" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Settings -->
          <Button x:Name="NavSettings"
                  Click="NavSettings_Click"
                  Tag="Settings"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal" Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="14" Foreground="#6B7280" VerticalAlignment="Center" Width="20"/>
              <TextBlock Text="Settings" FontSize="13" Foreground="#6B7280" VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </StackPanel>
      </ScrollViewer>

      <!-- User Profile Footer -->
      <Border Grid.Row="2"
              Margin="12,12,12,16"
              Padding="10"
              CornerRadius="8"
              Background="#F9FAFB"
              BorderBrush="#E5E7EB"
              BorderThickness="1">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <!-- Avatar -->
          <Border Grid.Column="0"
                  Width="32" Height="32"
                  CornerRadius="16"
                  Background="#DBEAFE"
                  Margin="0,0,10,0">
            <TextBlock Text="AM"
                       FontSize="11"
                       FontWeight="Bold"
                       Foreground="#2563EB"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"/>
          </Border>

          <!-- Name & Role -->
          <StackPanel Grid.Column="1" VerticalAlignment="Center">
            <TextBlock Text="Alex Morgan"
                       FontSize="12"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"/>
            <TextBlock Text="Store Owner"
                       FontSize="10"
                       Foreground="#9CA3AF"/>
          </StackPanel>

          <!-- Logout icon -->
          <TextBlock Grid.Column="2"
                     FontFamily="Segoe MDL2 Assets"
                     Text="&#xE8E8;"
                     FontSize="12"
                     Foreground="#9CA3AF"
                     VerticalAlignment="Center"/>
        </Grid>
      </Border>

    </Grid>

    <!-- ═══════════════════════════════════ MAIN CONTENT ═══════════════════════════════════ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Top Header Bar -->
      <Border Grid.Row="0"
              Background="White"
              BorderBrush="#E5E7EB"
              BorderThickness="0,0,0,1"
              Padding="24,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="Welcome back, Alex"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="#1F2937"
                     VerticalAlignment="Center"/>

          <!-- Right side icons -->
          <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">

            <!-- Notification bell -->
            <Button Tag="Notifications"
                    Click="NavNotifications_Click"
                    Width="36" Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Notifications">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE7E3;" FontSize="16" Foreground="#6B7280"/>
            </Button>

            <!-- Settings gear -->
            <Button Tag="Settings"
                    Click="NavSettings_Click"
                    Width="36" Height="36"
                    Background="Transparent"
                    BorderThickness="0"
                    ToolTipService.ToolTip="Settings">
              <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE713;" FontSize="16" Foreground="#6B7280"/>
            </Button>

            <!-- User avatar -->
            <Border Width="36" Height="36" CornerRadius="18" Background="#DBEAFE" Margin="8,0,0,0">
              <TextBlock Text="AM"
                         FontSize="11"
                         FontWeight="Bold"
                         Foreground="#2563EB"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>

          </StackPanel>
        </Grid>
      </Border>

      <!-- Page Content Frame -->
      <Frame x:Name="ContentFrame"
             Grid.Row="1"
             Navigated="ContentFrame_Navigated"/>

      <!-- Footer -->
      <Border Grid.Row="2"
              Background="White"
              BorderBrush="#E5E7EB"
              BorderThickness="0,1,0,0"
              Padding="24,10">
        <TextBlock Text="© 2026 MyShop Performance Engine. All rights reserved. Data synced: 1 min ago."
                   FontSize="11"
                   Foreground="#9CA3AF"
                   HorizontalAlignment="Center"/>
      </Border>

    </Grid>
  </Grid>
</Page>
