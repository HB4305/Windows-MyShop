<Page x:Class="MyShop.Views.ShellPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Grid>
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="240"/>
      <ColumnDefinition Width="*"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════ SIDEBAR ═══════════════════════════════════ -->
    <Grid Grid.Column="0"
          Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Brand Header -->
      <StackPanel Grid.Row="0"
                  Margin="20,20,20,24">
        <!-- Logo circle -->
        <Border Width="40"
                Height="40"
                CornerRadius="20"
                Background="{StaticResource PurpleBrush}"
                HorizontalAlignment="Left"
                Margin="0,0,0,10">
          <TextBlock Text="ES"
                     Foreground="{ThemeResource TextFillColorPrimary}"
                     FontWeight="Bold"
                     FontSize="14"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Border>
        <TextBlock Text="Elite Sports"
                   FontSize="18"
                   FontWeight="Bold"
                   Foreground="{ThemeResource TextFillColorPrimary}"/>
      </StackPanel>

      <!-- Navigation Menu -->
      <ScrollViewer Grid.Row="1"
                    VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="12,0,12,0"
                    Spacing="2">

          <!-- SECTION: MENU -->
          <TextBlock Text="MENU"
                     FontSize="10"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorTertiary}"
                     Margin="8,0,0,8"
                     CharacterSpacing="60"/>

          <!-- Dashboard -->
          <Button x:Name="NavDashboard"
                  Click="NavDashboard_Click"
                  Tag="Dashboard"
                  Background="{StaticResource PurpleLightBrush}"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE80F;"
                         FontSize="14"
                         Foreground="{StaticResource PurpleBrush}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Dashboard"
                         FontSize="13"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource PurpleBrush}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Reports -->
          <Button x:Name="NavReports"
                  Click="NavReports_Click"
                  Tag="Reports"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE9F9;"
                         FontSize="14"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Reports"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Product Catalog -->
          <Button x:Name="NavProductCatalog"
                  Click="NavProductCatalog_Click"
                  Tag="ProductCatalog"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE7BF;"
                         FontSize="14"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Product Catalog"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Orders Management -->
          <Button x:Name="NavOrders"
                  Click="NavOrders_Click"
                  Tag="OrdersManagement"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE7BC;"
                         FontSize="14"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Orders Management"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>



          <!-- Category -->
          <Button x:Name="NavCategory"
                  Click="NavCategory_Click"
                  Tag="Category"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE8EC;"
                         FontSize="14"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Category"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

          <!-- Settings -->
          <Button x:Name="NavSettings"
                  Click="NavSettings_Click"
                  Tag="Settings"
                  Background="Transparent"
                  BorderThickness="0"
                  Padding="10,8"
                  HorizontalAlignment="Stretch"
                  HorizontalContentAlignment="Left">
            <StackPanel Orientation="Horizontal"
                        Spacing="10">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE713;"
                         FontSize="14"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"
                         Width="20"/>
              <TextBlock Text="Settings"
                         FontSize="13"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Button>

        </StackPanel>
      </ScrollViewer>

      <!-- User Profile Card -->
      <Grid Grid.Row="2" Margin="12,12,12,16">
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <!-- Profile Info -->
        <Border Grid.Column="0"
                Padding="10"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{StaticResource PurpleLightBrush}">
          <Grid>
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="Auto"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Avatar -->
            <Border Grid.Column="0"
                    Width="36"
                    Height="36"
                    CornerRadius="18"
                    Background="#FFFFFF"
                    Margin="0,0,10,0">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE77B;"
                         FontSize="16"
                         Foreground="{StaticResource PurpleBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>

            <!-- Name & Role -->
            <StackPanel Grid.Column="1"
                        VerticalAlignment="Center">
              <TextBlock Text="Coach Rivera"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorPrimary}"/>
              <TextBlock Text="HEAD COACH"
                         FontSize="10"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         CharacterSpacing="80"/>
            </StackPanel>
          </Grid>
        </Border>

        <!-- Logout Button -->
        <Button Grid.Column="1"
                Click="Logout_Click"
                Width="40"
                Height="40"
                Margin="6,0,0,0"
                CornerRadius="{ThemeResource ControlCornerRadius}"
                Background="{ThemeResource ControlFillColorDefaultBrush}"
                BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="1"
                ToolTipService.ToolTip="Sign Out"
                VerticalAlignment="Center">
          <TextBlock FontFamily="Segoe MDL2 Assets"
                     Text="&#xE8E8;"
                     FontSize="14"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     HorizontalAlignment="Center"
                     VerticalAlignment="Center"/>
        </Button>
      </Grid>

    </Grid>

    <!-- ═══════════════════════════════════ MAIN CONTENT ═══════════════════════════════════ -->
    <Grid Grid.Column="1">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- Top Header Bar -->
      <Border Grid.Row="0"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="0,0,0,1"
              Padding="24,16">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>

          <TextBlock Grid.Column="0"
                     Text="Welcome back, Alex"
                     FontSize="22"
                     FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorPrimary}"
                     VerticalAlignment="Center"/>

          <!-- Right side icons -->
          <StackPanel Grid.Column="1"
                      Orientation="Horizontal"
                      Spacing="6"
                      VerticalAlignment="Center"
                      HorizontalAlignment="Right">

            <!-- Notification bell -->
            <Button Tag="Notifications"
                    Click="NavNotifications_Click"
                Width="40"
                Height="40"
                Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                HorizontalContentAlignment="Center"
                VerticalContentAlignment="Center"
                    ToolTipService.ToolTip="Notifications">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE7E3;"
                         FontSize="16"
                 Foreground="{ThemeResource TextFillColorSecondary}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
            </Button>

            <!-- Settings gear -->
            <Button Tag="Settings"
                    Click="NavSettings_Click"
                  Width="40"
                  Height="40"
                  Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                  HorizontalContentAlignment="Center"
                  VerticalContentAlignment="Center"
                    ToolTipService.ToolTip="Settings">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE713;"
                         FontSize="16"
                 Foreground="{ThemeResource TextFillColorSecondary}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"/>
            </Button>

            <!-- User avatar -->
                    <Border Width="40"
                      Height="40"
                      CornerRadius="20"
                    Background="{StaticResource PurpleLightBrush}"
                    Margin="8,0,0,0">
              <TextBlock Text="AM"
                         FontSize="11"
                         FontWeight="Bold"
                         Foreground="{StaticResource PurpleBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>

          </StackPanel>
        </Grid>
      </Border>

      <!-- Page Content Frame -->
      <Frame x:Name="ContentFrame"
             Grid.Row="1"
             Navigated="ContentFrame_Navigated"/>

      <!-- Footer -->
      <Border Grid.Row="2"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="0,1,0,0"
              Padding="24,10">
        <TextBlock Text="© 2026 MyShop Performance Engine. All rights reserved. Data synced: 1 min ago."
                   FontSize="11"
                   Foreground="{ThemeResource TextFillColorTertiary}"
                   HorizontalAlignment="Center"/>
      </Border>

    </Grid>
  </Grid>
</Page>
