<Page x:Class="MyShop.Views.PosPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:controls="using:MyShop.Controls"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
      Tapped="Page_Tapped">
  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
    <SolidColorBrush x:Key="PurpleBrush" Color="#8B52FF"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#8B52FF" Opacity="0.12"/>
    <SolidColorBrush x:Key="DangerBrush" Color="#EF4444"/>

    <Style x:Key="PanelBorder" TargetType="Border">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
    </Style>
  </Page.Resources>

  <Grid x:Name="RootLayout" Padding="24,20" ColumnSpacing="20" RowSpacing="16" Loaded="RootLayout_Loaded" SizeChanged="RootLayout_SizeChanged">
    <Grid.ColumnDefinitions>
      <ColumnDefinition Width="3*"/>
      <ColumnDefinition Width="400"/>
    </Grid.ColumnDefinitions>
    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="Auto"/>
    </Grid.RowDefinitions>

    <Grid x:Name="HeaderPanel" Grid.Row="0" Grid.ColumnSpan="2" ColumnSpacing="16">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="*"/>
        <ColumnDefinition Width="Auto"/>
      </Grid.ColumnDefinitions>
      <StackPanel Spacing="2">
        <TextBlock Text="SwiftPOS Sports" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimary}"/>
        <TextBlock Text="New order register" FontSize="13" Foreground="{ThemeResource TextFillColorSecondary}"/>
      </StackPanel>
      <Button Grid.Column="1"
              Command="{Binding NewOrderCommand}"
              Background="{StaticResource PurpleLightBrush}"
              Foreground="{StaticResource PurpleBrush}"
              BorderThickness="0"
              Padding="14,10"
              CornerRadius="{ThemeResource ControlCornerRadius}">
        <StackPanel Orientation="Horizontal" Spacing="8">
          <FontIcon Glyph="&#xE710;" FontSize="15"/>
          <TextBlock Text="New Order"/>
        </StackPanel>
      </Button>
    </Grid>

    <Border x:Name="ProductPanel" Grid.Row="1" Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="18">
      <Grid RowSpacing="16">
        <Grid.RowDefinitions>
          <RowDefinition Height="Auto"/>
          <RowDefinition Height="*"/>
          <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <controls:ProductSearchFilterBar x:Name="ProductFilterBar"
                                         CategoryItemsSource="{Binding CategoryOptions}"
                                         SelectedCategory="{Binding SelectedCategory, Mode=TwoWay}"
                                         SearchText="{Binding SearchText, Mode=TwoWay}"
                                         SearchItemsSource="{Binding ProductOptions}"
                                         SearchCommand="{Binding SearchCommand}"
                                         SearchPlaceholderText="Search sports gear or scan barcode (F1)"
                                         CategoryPlaceholderText="Category"
                                         SearchTextChanged="ProductFilterBar_SearchTextChanged"
                                         SearchSuggestionChosen="ProductFilterBar_SearchSuggestionChosen"
                                         SearchQuerySubmitted="ProductFilterBar_SearchQuerySubmitted"
                                         CategorySelectionChanged="ProductFilterBar_CategorySelectionChanged"/>

        <Grid Grid.Row="1">
          <GridView ItemsSource="{Binding Products}"
                    IsItemClickEnabled="True"
                    ItemClick="ProductsGrid_ItemClick"
                    SelectionMode="None"
                    Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
            <GridView.ItemContainerStyle>
              <Style TargetType="GridViewItem">
                <Setter Property="Width" Value="190"/>
                <Setter Property="Height" Value="260"/>
                <Setter Property="Margin" Value="0,0,16,16"/>
                <Setter Property="Padding" Value="0"/>
              </Style>
            </GridView.ItemContainerStyle>
            <GridView.ItemTemplate>
              <DataTemplate>
                <StackPanel Spacing="8">
                  <Border Height="152" CornerRadius="8" Background="{ThemeResource ControlFillColorSecondaryBrush}">
                    <Grid>
                      <Image Source="{Binding Item.ImageUrl}" Stretch="UniformToFill"/>
                      <Border Background="{StaticResource PurpleLightBrush}" CornerRadius="6" Padding="8,4" HorizontalAlignment="Right" VerticalAlignment="Top" Margin="8">
                        <TextBlock FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource PurpleBrush}">
                          <Run Text="{Binding Item.EffectiveStockQuantity}"/>
                          <Run Text=" in stock"/>
                        </TextBlock>
                      </Border>
                    </Grid>
                  </Border>
                  <TextBlock Text="{Binding Item.Name}" FontSize="15" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" TextWrapping="Wrap" MaxLines="2"/>
                  <TextBlock Text="{Binding CategoryName}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}" TextTrimming="CharacterEllipsis"/>
                  <TextBlock Text="{Binding Item.SellingPrice, Converter={StaticResource CurrencyFormatter}}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}"/>
                </StackPanel>
              </DataTemplate>
            </GridView.ItemTemplate>
          </GridView>

          <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12"
                      Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}">
            <ProgressRing IsActive="True" Width="36" Height="36" Foreground="{StaticResource PurpleBrush}"/>
            <TextBlock Text="Loading products..." Foreground="{ThemeResource TextFillColorSecondary}"/>
          </StackPanel>
        </Grid>

        <Border Grid.Row="2" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1,1,0,0" Padding="14">
          <controls:PaginationBar CurrentPage="{Binding CurrentPage}"
                                  TotalPages="{Binding TotalPages}"
                                  DisplayFrom="{Binding DisplayFrom}"
                                  DisplayTo="{Binding DisplayTo}"
                                  TotalItems="{Binding TotalItems}"
                                  ItemLabel="products"
                                  PreviousCommand="{Binding PreviousPageCommand}"
                                  NextCommand="{Binding NextPageCommand}"/>
        </Border>
      </Grid>
    </Border>

    <Grid x:Name="CheckoutPanel" Grid.Row="1" Grid.Column="1" RowSpacing="16">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <Border Style="{StaticResource PanelBorder}" Padding="18">
        <StackPanel Spacing="12">
          <Grid>
            <StackPanel Orientation="Horizontal" Spacing="10">
              <FontIcon Glyph="&#xE77B;" Foreground="{StaticResource PurpleBrush}" FontSize="18"/>
              <TextBlock Text="Customer" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
            </StackPanel>
          </Grid>
          <AutoSuggestBox x:Name="CustomerSearchBox"
                          PlaceholderText="Search customer by name or phone..."
                          Text="{Binding CustomerSearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                          ItemsSource="{Binding CustomerSuggestions}"
                          TextChanged="CustomerSearchBox_TextChanged"
                          SuggestionChosen="CustomerSearchBox_SuggestionChosen"
                          QuerySubmitted="CustomerSearchBox_QuerySubmitted"
                          MinHeight="42">
            <AutoSuggestBox.ItemTemplate>
              <DataTemplate>
                <Grid ColumnSpacing="10" MinWidth="260">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="36"/>
                    <ColumnDefinition Width="*"/>
                  </Grid.ColumnDefinitions>
                  <Border Width="32" Height="32" CornerRadius="16" Background="{StaticResource PurpleLightBrush}">
                    <FontIcon Glyph="&#xE77B;" FontSize="13" Foreground="{StaticResource PurpleBrush}" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                  </Border>
                  <StackPanel Grid.Column="1" Spacing="1">
                    <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
                    <TextBlock Text="{Binding Phone}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                  </StackPanel>
                </Grid>
              </DataTemplate>
            </AutoSuggestBox.ItemTemplate>
          </AutoSuggestBox>
          <TextBox PlaceholderText="Customer name"
                   Text="{Binding CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   MinHeight="42"/>
          <TextBox PlaceholderText="Phone"
                   Text="{Binding CustomerPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   MinHeight="42"/>
          <TextBox PlaceholderText="Address"
                   Text="{Binding CustomerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   MinHeight="42"/>
        </StackPanel>
      </Border>

      <Border Grid.Row="1" Style="{StaticResource PanelBorder}">
        <Grid>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>

          <Border Grid.Row="0" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,0,0,1" Padding="18">
            <Grid>
              <StackPanel Orientation="Horizontal" Spacing="10">
                <FontIcon Glyph="&#xE719;" Foreground="{StaticResource PurpleBrush}" FontSize="18"/>
                <TextBlock Text="Order Summary" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
              </StackPanel>
              <Border Background="{StaticResource PurpleLightBrush}" CornerRadius="16" Padding="10,4" HorizontalAlignment="Right">
                <TextBlock Foreground="{StaticResource PurpleBrush}" FontWeight="SemiBold" FontSize="12">
                  <Run Text="{Binding CartCount}"/>
                  <Run Text=" items"/>
                </TextBlock>
              </Border>
            </Grid>
          </Border>

          <ListView Grid.Row="1" ItemsSource="{Binding CartItems}" SelectionMode="None" Padding="14">
            <ListView.ItemContainerStyle>
              <Style TargetType="ListViewItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                <Setter Property="Padding" Value="0"/>
                <Setter Property="Margin" Value="0,0,0,10"/>
              </Style>
            </ListView.ItemContainerStyle>
            <ListView.ItemTemplate>
              <DataTemplate>
                <Border Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1" CornerRadius="8" Padding="10">
                  <Grid ColumnSpacing="10">
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="52"/>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Width="52" Height="52" CornerRadius="8" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                      <Image Source="{Binding ImageUrl}" Stretch="UniformToFill"/>
                    </Border>
                    <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                      <TextBlock Text="{Binding Name}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" TextTrimming="CharacterEllipsis"/>
                      <TextBlock Text="{Binding UnitPrice, Converter={StaticResource CurrencyFormatter}}" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                      <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Tag="{Binding}" Click="DecreaseCartItem_Click" Width="28" Height="28" Padding="0" Content="-" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                        <TextBlock Text="{Binding QuantityDisplay}" FontWeight="SemiBold" VerticalAlignment="Center" MinWidth="18" TextAlignment="Center"/>
                        <Button Tag="{Binding}" Click="IncreaseCartItem_Click" Width="28" Height="28" Padding="0" Content="+" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
                      </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="8" HorizontalAlignment="Right">
                      <Button Tag="{Binding}" Click="RemoveCartItem_Click" Width="28" Height="28" Padding="0" Background="Transparent" BorderThickness="0" ToolTipService.ToolTip="Remove">
                        <FontIcon Glyph="&#xE711;" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                      </Button>
                      <TextBlock Text="{Binding LineTotal, Converter={StaticResource CurrencyFormatter}}" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}" HorizontalAlignment="Right"/>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ListView.ItemTemplate>
          </ListView>

          <Border Grid.Row="2" Background="{ThemeResource ControlFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="0,1,0,0" Padding="18">
            <StackPanel Spacing="12">
              <Grid>
                <TextBlock Text="Subtotal" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Text="{Binding Subtotal, Converter={StaticResource CurrencyFormatter}}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
              </Grid>
              <Grid>
                <TextBlock Text="Tax (8.5%)" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Text="{Binding Tax, Converter={StaticResource CurrencyFormatter}}" HorizontalAlignment="Right" FontWeight="SemiBold"/>
              </Grid>
              <Grid>
                <TextBlock Text="Member Discount" Foreground="{ThemeResource TextFillColorSecondary}"/>
                <TextBlock Text="{Binding Discount, Converter={StaticResource CurrencyFormatter}}" HorizontalAlignment="Right" Foreground="#16A34A" FontWeight="SemiBold"/>
              </Grid>
              <Rectangle Height="1" Fill="{ThemeResource ControlStrokeColorDefaultBrush}"/>
              <Grid>
                <TextBlock Text="Total" FontSize="20" FontWeight="Bold" Foreground="{ThemeResource TextFillColorPrimary}"/>
                <TextBlock Text="{Binding Total, Converter={StaticResource CurrencyFormatter}}" FontSize="20" FontWeight="Bold" Foreground="{StaticResource PurpleBrush}" HorizontalAlignment="Right"/>
              </Grid>
              <Button Command="{Binding CheckoutCommand}"
                      Background="{StaticResource PurpleBrush}"
                      Foreground="White"
                      BorderThickness="0"
                      Padding="18,14"
                      CornerRadius="{ThemeResource ControlCornerRadius}"
                      HorizontalAlignment="Stretch">
                <StackPanel Orientation="Horizontal" Spacing="10" HorizontalAlignment="Center">
                  <FontIcon Glyph="&#xE8C7;" Foreground="White"/>
                  <TextBlock Text="Checkout" FontSize="16" FontWeight="Bold"/>
                </StackPanel>
              </Button>
            </StackPanel>
          </Border>
        </Grid>
      </Border>
    </Grid>

    <TextBlock x:Name="StatusText"
               Grid.Row="2"
               Grid.ColumnSpan="2"
               Text="{Binding StatusMessage}"
               Foreground="{StaticResource DangerBrush}"
               TextWrapping="Wrap"
               Visibility="{Binding StatusMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
  </Grid>
</Page>
