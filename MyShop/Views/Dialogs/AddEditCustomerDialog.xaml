<ContentDialog
    x:Class="MyShop.Views.Dialogs.AddEditCustomerDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:conv="using:MyShop.Converters"
    mc:Ignorable="d"
    x:Name="DialogRoot"
    MinWidth="460"
    CornerRadius="12">

    <ContentDialog.Resources>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <!-- Use ThemeResource for background to support dark mode, or force light if requested by branding -->
        <SolidColorBrush x:Key="ContentDialogBackground" Color="{ThemeResource ApplicationPageBackgroundThemeBrush}"/>
    </ContentDialog.Resources>

    <StackPanel Spacing="24" Margin="4,4,4,4">
        <!-- Header -->
        <StackPanel Spacing="16">
            <Border Background="#F3F0FF"
                    CornerRadius="24"
                    Width="48" Height="48"
                    HorizontalAlignment="Left">
                <TextBlock FontFamily="Segoe MDL2 Assets"
                           Text="&#xE77B;"
                           FontSize="20"
                           Foreground="#7C3AED"
                           HorizontalAlignment="Center"
                           VerticalAlignment="Center"/>
            </Border>

            <StackPanel Spacing="6">
                <TextBlock x:Name="FormTitle"
                           FontSize="22"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimary}"/>
                <TextBlock x:Name="FormSubtitle"
                           FontSize="14"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           Text="Manage customer contact information."/>
            </StackPanel>
        </StackPanel>

        <Border Background="{ThemeResource ControlStrokeColorDefaultBrush}" Height="1" Margin="-4,0,-4,0"/>

        <!-- Form Fields -->
        <StackPanel Spacing="20">
            <!-- Name -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Full Name" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
                    <TextBlock Text="*" FontSize="14" Foreground="#DC2626"/>
                </StackPanel>
                <TextBox x:Name="NameTextBox"
                         PlaceholderText="e.g. John Doe"
                         MaxLength="255"
                         CornerRadius="8"
                         Padding="12,12"
                         Background="{ThemeResource ControlFillColorDefaultBrush}"
                         BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                         Text="{x:Bind CustomerName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Border Visibility="{x:Bind NameValidationMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" Padding="4,2,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA39;" FontSize="12" Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind NameValidationMessage, Mode=OneWay}" FontSize="12" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Phone -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="4">
                    <TextBlock Text="Phone Number" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
                    <TextBlock Text="*" FontSize="14" Foreground="#DC2626"/>
                </StackPanel>
                <TextBox x:Name="PhoneTextBox"
                         PlaceholderText="e.g. 0912345678"
                         MaxLength="20"
                         CornerRadius="8"
                         Padding="12,12"
                         Background="{ThemeResource ControlFillColorDefaultBrush}"
                         BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                         Text="{x:Bind CustomerPhone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <Border Visibility="{x:Bind PhoneValidationMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}" Padding="4,2,0,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xEA39;" FontSize="12" Foreground="#DC2626" VerticalAlignment="Center"/>
                        <TextBlock Text="{x:Bind PhoneValidationMessage, Mode=OneWay}" FontSize="12" Foreground="#DC2626"/>
                    </StackPanel>
                </Border>
            </StackPanel>

            <!-- Address -->
            <StackPanel Spacing="8">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <TextBlock Text="Address" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}"/>
                    <Border Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="4" Padding="8,2">
                        <TextBlock Text="Optional" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    </Border>
                </StackPanel>
                <TextBox PlaceholderText="Enter shipping address..."
                         TextWrapping="Wrap"
                         AcceptsReturn="True"
                         MinHeight="100"
                         CornerRadius="8"
                         Padding="12,12"
                         Background="{ThemeResource ControlFillColorDefaultBrush}"
                         BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                         Text="{x:Bind CustomerAddress, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
            </StackPanel>
        </StackPanel>

        <Border Background="{ThemeResource ControlStrokeColorDefaultBrush}" Height="1" Margin="-4,0,-4,0"/>

        <!-- Buttons -->
        <Grid ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Click="CancelBtn_Click" HorizontalAlignment="Stretch" 
                    Background="Transparent" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" 
                    BorderThickness="1" CornerRadius="8" Padding="14,12">
                <TextBlock Text="Cancel" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" HorizontalAlignment="Center"/>
            </Button>

            <Button Grid.Column="1" Click="SaveBtn_Click" HorizontalAlignment="Stretch" 
                    Background="#7C3AED" BorderThickness="0" CornerRadius="8" Padding="14,12">
                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                    <TextBlock FontFamily="Segoe MDL2 Assets" Text="&#xE73E;" FontSize="14" Foreground="White" VerticalAlignment="Center"/>
                    <TextBlock x:Name="SaveBtnText" Text="Save" FontSize="14" FontWeight="SemiBold" Foreground="White"/>
                </StackPanel>
            </Button>
        </Grid>
    </StackPanel>
</ContentDialog>
