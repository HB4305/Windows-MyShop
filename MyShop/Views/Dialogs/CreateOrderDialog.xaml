<ContentDialog x:Class="MyShop.Views.Dialogs.CreateOrderDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:m="using:MyShop.Models"
               Title="Create New Order"
               MinWidth="900"
               MaxWidth="1200"
               PrimaryButtonText="Create Order"
               CloseButtonText="Cancel"
               DefaultButton="Primary"
               PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

  <ContentDialog.Resources>
    <x:Double x:Key="ContentDialogMaxWidth">1200</x:Double>
    
    <Style x:Key="HeaderStyle" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,16,0,8"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondary}"/>
      <Setter Property="FontSize" Value="18"/>
    </Style>
    <SolidColorBrush x:Key="PurpleBrush" Color="#8B52FF"/>
  </ContentDialog.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalAlignment="Stretch" MaxHeight="600">
    <StackPanel Spacing="16" Padding="24,16,24,16" HorizontalAlignment="Stretch">
      <Grid Width="850" Height="1"/>
      <!-- Error Message -->
      <TextBlock x:Name="ErrorTextBlock" 
                 Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                 Visibility="Collapsed" 
                 TextWrapping="Wrap"/>

      <!-- Order Type -->
      <TextBlock Text="ORDER TYPE" Style="{StaticResource HeaderStyle}"/>
      <ComboBox x:Name="OrderTypeCombo" 
                HorizontalAlignment="Stretch"
                CornerRadius="8"
                SelectedIndex="0"
                FontSize="16"
                SelectionChanged="OrderTypeCombo_SelectionChanged">
        <ComboBoxItem Content="AtStore"/>
        <ComboBoxItem Content="Delivery"/>
      </ComboBox>

      <!-- Customer Info -->
      <TextBlock Text="CUSTOMER INFORMATION" Style="{StaticResource HeaderStyle}" Margin="0,0,0,8"/>
      
      <TextBox x:Name="CustomerNameBox" 
               PlaceholderText="Customer Name (e.g. John Doe) *" 
               Text="{x:Bind ViewModel.Order.CustomerName, Mode=TwoWay}"
               FontSize="16"
               CornerRadius="8"/>
      
      <TextBox x:Name="CustomerPhoneBox" 
               PlaceholderText="Customer Phone (e.g. 1234567890)" 
               Text="{x:Bind ViewModel.Order.CustomerPhone, Mode=TwoWay}"
               InputScope="TelephoneNumber"
               FontSize="16"
               CornerRadius="8"
               Margin="0,0,0,8"/>

      <TextBox x:Name="CustomerAddressBox" 
               PlaceholderText="Shipping Address *" 
               Text="{x:Bind ViewModel.Order.ShippingAddress, Mode=TwoWay}"
               CornerRadius="8"
               Visibility="Collapsed"/>

      <!-- Order Items -->
      <TextBlock Text="ORDER ITEMS" Style="{StaticResource HeaderStyle}"/>

      <!-- Product Search -->
      <AutoSuggestBox x:Name="ProductSearchBox"
                      PlaceholderText="Search product by name..."
                      QueryIcon="Find"
                      TextChanged="ProductSearchBox_TextChanged"
                      SuggestionChosen="ProductSearchBox_SuggestionChosen"
                      DisplayMemberPath="Name"
                      TextMemberPath="Name"
                      FontSize="16"
                      CornerRadius="8"/>

      <!-- Selected Items List -->
      <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" 
              BorderThickness="1" 
              CornerRadius="8" 
              MinHeight="100"
              Padding="0"
              Background="{ThemeResource ControlFillColorDefaultBrush}">
        <ListView x:Name="OrderLinesListView"
                  ItemsSource="{x:Bind ViewModel.OrderDetails}"
                  SelectionMode="None"
                  MaxHeight="380">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="m:OrderDetail">
              <Grid Margin="0,6">
                <Grid.RowDefinitions>
                  <RowDefinition Height="Auto"/>
                  <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                
                <!-- Top Section: Name, Price, Stock Status -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" Margin="0,0,0,8" VerticalAlignment="Center">
                  <TextBlock Text="{x:Bind ItemName}" FontWeight="SemiBold" FontSize="15" TextWrapping="NoWrap" TextTrimming="CharacterEllipsis" MaxWidth="400" VerticalAlignment="Center"/>
                  
                  <TextBlock Text="{x:Bind UnitPrice, Converter={StaticResource CurrencyConverter}}" FontSize="14" Foreground="{ThemeResource TextFillColorSecondary}" VerticalAlignment="Center"/>
                  
                  <Border Background="#1A8B52FF" CornerRadius="4" Padding="6,2" VerticalAlignment="Center">
                    <TextBlock Text="{x:Bind StockStatusDisplay, Mode=OneWay}" FontSize="12" Foreground="{StaticResource PurpleBrush}" FontWeight="SemiBold"/>
                  </Border>
                </StackPanel>

                <!-- Bottom Section: Interactive Variant Selectors -->
                <Grid Grid.Row="1">
                  <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="2*"/>
                    <ColumnDefinition Width="1.5*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                  </Grid.ColumnDefinitions>

                  <StackPanel Grid.Column="0" Spacing="2" Margin="0,0,12,0">
                    <TextBlock Text="Size" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    <ComboBox ItemsSource="{x:Bind AvailableSizes, Mode=OneWay}" 
                              SelectedItem="{x:Bind SelectedSize, Mode=TwoWay}" 
                              HorizontalAlignment="Stretch" 
                              CornerRadius="8"/>
                  </StackPanel>

                  <StackPanel Grid.Column="1" Spacing="2" Margin="0,0,12,0">
                    <TextBlock Text="Color" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    <ComboBox ItemsSource="{x:Bind AvailableColors, Mode=OneWay}" 
                              SelectedItem="{x:Bind SelectedColor, Mode=TwoWay}" 
                              HorizontalAlignment="Stretch" 
                              CornerRadius="8"/>
                  </StackPanel>

                  <StackPanel Grid.Column="2" Spacing="2" Margin="0,0,12,0">
                    <TextBlock Text="Qty" FontSize="12" Foreground="{ThemeResource TextFillColorSecondary}"/>
                    <NumberBox Value="{x:Bind Quantity, Mode=TwoWay}" 
                               Minimum="1" 
                               Maximum="{x:Bind MaxQuantity, Mode=OneWay}"
                               IsEnabled="{x:Bind IsQuantityEnabled, Mode=OneWay}"
                               SpinButtonPlacementMode="Compact"
                               ValueChanged="Quantity_ValueChanged"
                               CornerRadius="8"
                               HorizontalAlignment="Stretch"/>
                  </StackPanel>

                  <StackPanel Grid.Column="3" Spacing="4" VerticalAlignment="Bottom" Margin="0,0,16,6">
                    <TextBlock Text="{x:Bind TotalPriceDisplay, Mode=OneWay}" FontWeight="Bold" FontSize="16"/>
                  </StackPanel>

                  <Button Grid.Column="4" Background="Transparent"
                          BorderThickness="0"
                          VerticalAlignment="Bottom"
                          Margin="0,0,0,0"
                          Click="RemoveItem_Click"
                          Tag="{x:Bind}">
                    <FontIcon Glyph="&#xE74D;" FontSize="16" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                  </Button>
                </Grid>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <!-- Totals -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16"
              Margin="0,8,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Total Amount:" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" x:Name="TotalAmountTextBlock" Text="{x:Bind ViewModel.TotalAmountDisplay, Mode=OneWay}" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PurpleBrush}"/>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</ContentDialog>
