<ContentDialog x:Class="MyShop.Views.Dialogs.CreateOrderDialog"
               xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
               xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
               xmlns:m="using:MyShop.Models"
               Title="Create New Order"
               PrimaryButtonText="Create Order"
               CloseButtonText="Cancel"
               DefaultButton="Primary"
               PrimaryButtonClick="ContentDialog_PrimaryButtonClick">

  <ContentDialog.Resources>
    <Style x:Key="HeaderStyle" TargetType="TextBlock">
      <Setter Property="FontWeight" Value="SemiBold"/>
      <Setter Property="Margin" Value="0,16,0,8"/>
      <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondary}"/>
    </Style>
    <SolidColorBrush x:Key="PurpleBrush" Color="#8B52FF"/>
  </ContentDialog.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto" Width="500" MaxHeight="600">
    <StackPanel Spacing="12">
      <!-- Error Message -->
      <TextBlock x:Name="ErrorTextBlock" 
                 Foreground="{ThemeResource SystemFillColorCriticalBrush}" 
                 Visibility="Collapsed" 
                 TextWrapping="Wrap"/>

      <!-- Order Type -->
      <TextBlock Text="ORDER TYPE" Style="{StaticResource HeaderStyle}"/>
      <ComboBox x:Name="OrderTypeCombo" 
                HorizontalAlignment="Stretch"
                CornerRadius="8"
                SelectedIndex="0"
                SelectionChanged="OrderTypeCombo_SelectionChanged">
        <ComboBoxItem Content="AtStore"/>
        <ComboBoxItem Content="Delivery"/>
      </ComboBox>

      <!-- Customer Info -->
      <TextBlock Text="CUSTOMER INFORMATION" Style="{StaticResource HeaderStyle}" Margin="0,0,0,8"/>
      
      <TextBox x:Name="CustomerNameBox" 
               PlaceholderText="Customer Name (e.g. John Doe) *" 
               Text="{x:Bind ViewModel.Order.CustomerName, Mode=TwoWay}"
               CornerRadius="8"/>
      
      <TextBox x:Name="CustomerPhoneBox" 
               PlaceholderText="Customer Phone (e.g. 1234567890)" 
               Text="{x:Bind ViewModel.Order.CustomerPhone, Mode=TwoWay}"
               InputScope="TelephoneNumber"
               CornerRadius="8"
               Margin="0,0,0,8"/>

      <TextBox x:Name="CustomerAddressBox" 
               PlaceholderText="Shipping Address *" 
               Text="{x:Bind ViewModel.Order.ShippingAddress, Mode=TwoWay}"
               CornerRadius="8"
               Visibility="Collapsed"/>

      <!-- Order Items -->
      <TextBlock Text="ORDER ITEMS" Style="{StaticResource HeaderStyle}"/>

      <!-- Product Search -->
      <AutoSuggestBox x:Name="ProductSearchBox"
                      PlaceholderText="Search product by name..."
                      QueryIcon="Find"
                      TextChanged="ProductSearchBox_TextChanged"
                      SuggestionChosen="ProductSearchBox_SuggestionChosen"
                      DisplayMemberPath="Name"
                      TextMemberPath="Name"
                      CornerRadius="8"/>

      <!-- Selected Items List -->
      <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" 
              BorderThickness="1" 
              CornerRadius="8" 
              MinHeight="100"
              Padding="0"
              Background="{ThemeResource ControlFillColorDefaultBrush}">
        <ListView x:Name="OrderLinesListView"
                  ItemsSource="{x:Bind ViewModel.OrderDetails}"
                  SelectionMode="None"
                  MaxHeight="250">
          <ListView.ItemTemplate>
            <DataTemplate x:DataType="m:OrderDetail">
              <Grid Margin="0,8">
                <Grid.ColumnDefinitions>
                  <ColumnDefinition Width="*"/>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="80"/>
                  <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" VerticalAlignment="Center">
                  <TextBlock Text="{x:Bind ItemName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" FontSize="13"/>
                  <TextBlock Text="{x:Bind UnitPrice, Converter={StaticResource CurrencyConverter}}" FontSize="11" Foreground="{ThemeResource TextFillColorSecondary}"/>
                </StackPanel>

                <NumberBox Grid.Column="1" 
                           Value="{x:Bind Quantity, Mode=TwoWay}" 
                           Minimum="1" 
                           Maximum="999"
                           SpinButtonPlacementMode="Compact"
                           ValueChanged="Quantity_ValueChanged"
                           Margin="8,0"
                           VerticalAlignment="Center"/>

                <TextBlock Grid.Column="2" 
                           Text="{x:Bind TotalPriceDisplay}" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           HorizontalAlignment="Right"/>

                <Button Grid.Column="3" 
                        Background="Transparent"
                        BorderThickness="0"
                        Margin="8,0,0,0"
                        Click="RemoveItem_Click"
                        Tag="{x:Bind ItemId}">
                  <FontIcon Glyph="&#xE74D;" FontSize="14" Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                </Button>
              </Grid>
            </DataTemplate>
          </ListView.ItemTemplate>
        </ListView>
      </Border>

      <!-- Totals -->
      <Border Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="8"
              Padding="16"
              Margin="0,8,0,0">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="Auto"/>
          </Grid.ColumnDefinitions>
          <TextBlock Grid.Column="0" Text="Total Amount:" FontWeight="SemiBold" FontSize="15" VerticalAlignment="Center"/>
          <TextBlock Grid.Column="1" x:Name="TotalAmountTextBlock" Text="{x:Bind ViewModel.TotalAmountDisplay, Mode=OneWay}" FontWeight="Bold" FontSize="18" Foreground="{StaticResource PurpleBrush}"/>
        </Grid>
      </Border>

    </StackPanel>
  </ScrollViewer>
</ContentDialog>
