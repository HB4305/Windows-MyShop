<ContentDialog
    x:Class="MyShop.Views.Dialogs.BulkImportDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Bulk Import Products"
    PrimaryButtonText="Import"
    CloseButtonText="Cancel"
    PrimaryButtonClick="OnImportClick"
    Style="{StaticResource DefaultContentDialogStyle}">

    <ContentDialog.Resources>
        <x:Double x:Key="ContentDialogMaxWidth">500</x:Double>
    </ContentDialog.Resources>

    <Grid RowSpacing="16" Margin="0,12,0,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Icon and Message -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,8,0,8">
            <Border Background="#1A8B52FF" CornerRadius="24" Width="48" Height="48" HorizontalAlignment="Center" VerticalAlignment="Center">
                <FontIcon Glyph="&#xE896;" FontSize="24" Foreground="#8B52FF" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            
            <StackPanel VerticalAlignment="Center" Spacing="4">
                <TextBlock x:Name="MessageLabel" 
                           Text="Do you want to import products?" 
                           FontSize="15" 
                           TextWrapping="Wrap" 
                           Width="360"
                           Foreground="{ThemeResource TextFillColorPrimary}"/>
            </StackPanel>
        </StackPanel>

        <TextBlock x:Name="StatusLabel" 
                   Grid.Row="1"
                   TextWrapping="Wrap" 
                   FontSize="13"
                   Foreground="Red" 
                   Visibility="Collapsed"/>
    </Grid>
</ContentDialog>
