<ContentDialog
	x:Class="MyShop.Views.Dialogs.SuccessDialog"
	xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
	xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
	mc:Ignorable="d"
	x:Name="DialogRoot"
	DefaultButton="Close"
	MinWidth="420">

	<ContentDialog.Resources>
		<CornerRadius x:Key="OverlayCornerRadius">12</CornerRadius>
	</ContentDialog.Resources>

	<StackPanel Spacing="20" Margin="4,0,4,0">
		<StackPanel Spacing="16">
			<!-- Success Icon with Theme-aware background -->
			<Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}"
					CornerRadius="24"
					Width="48" Height="48"
					HorizontalAlignment="Left">
				<TextBlock FontFamily="Segoe MDL2 Assets"
						   Text="&#xE73E;"
						   FontSize="20"
						   Foreground="{ThemeResource SystemFillColorSuccessBrush}"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"/>
			</Border>

			<TextBlock Text="{x:Bind DialogTitle, Mode=OneWay}"
					   FontSize="20"
					   FontWeight="Bold"
					   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
		</StackPanel>

		<TextBlock Text="{x:Bind DialogContent, Mode=OneWay}"
				   FontSize="14"
				   Foreground="{ThemeResource TextFillColorSecondaryBrush}"
				   TextWrapping="Wrap"
				   LineHeight="20"/>

		<!-- Separator line -->
		<Border Background="{ThemeResource ControlStrokeColorDefaultBrush}" 
				Height="1" 
				Margin="-4,0,-4,0"/>

		<Grid ColumnSpacing="10">
			<!-- OK Button using Global App Purple color -->
			<Button x:Name="CloseBtn"
					Click="CloseBtn_Click"
					HorizontalAlignment="Stretch"
					Background="{StaticResource AppAccentBrush}"
					BorderThickness="0"
					CornerRadius="8"
					Padding="14,10">
				<Button.Resources>
					<!-- Standard hover states -->
					<SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#7C4DFF"/>
					<SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
				</Button.Resources>
				<TextBlock Text="OK"
						   FontSize="14"
						   FontWeight="SemiBold"
						   Foreground="White"
						   HorizontalAlignment="Center"/>
			</Button>
		</Grid>
	</StackPanel>
</ContentDialog>
