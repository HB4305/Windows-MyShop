<ContentDialog
    x:Class="MyShop.Views.Dialogs.SupplierDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Supplier"
    PrimaryButtonText="Save"
    CloseButtonText="Cancel"
    PrimaryButtonClick="ContentDialog_PrimaryButtonClick"
    Style="{StaticResource DefaultContentDialogStyle}">

    <StackPanel Spacing="16" Width="350" Margin="0,12,0,0">
        <!-- Error Message -->
        <TextBlock x:Name="ErrorText" 
                   Foreground="Red" 
                   TextWrapping="Wrap" 
                   Visibility="Collapsed"/>

        <!-- Name -->
        <TextBox x:Name="NameTextBox" 
                 Header="Supplier Name *" 
                 PlaceholderText="e.g. ABC Sports Co., Ltd."/>

        <!-- Phone -->
        <TextBox x:Name="PhoneTextBox" 
                 Header="Phone Number" 
                 PlaceholderText="e.g. 0912345678"/>

        <!-- Type -->
        <TextBox x:Name="TypeTextBox" 
                 Header="Type (Optional)" 
                 PlaceholderText="e.g. Wholesale, Retail"/>
    </StackPanel>
</ContentDialog>
