<ContentDialog
    x:Class="MyShop.Views.Dialogs.ExportFormatDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    x:Name="DialogRoot"
    Title=""
    MinWidth="440">

    <ContentDialog.Resources>
        <!-- Use Global Resources defined in App.xaml -->
        <StaticResource x:Key="SelectedCardBackgroundBrush" ResourceKey="AppAccentBrushLow" />
        <StaticResource x:Key="SelectedCardBorderBrush" ResourceKey="AppAccentBrush" />

        <!-- Format card style -->
        <Style x:Key="FormatCard" TargetType="Border">
            <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="14,12"/>
            <Setter Property="Background" Value="{ThemeResource ControlFillColorDefaultBrush}"/>
        </Style>
    </ContentDialog.Resources>

    <StackPanel Spacing="20">

        <!-- ── Dialog header with icon ── -->
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Icon -->
            <Border Grid.Column="0"
                    Background="{ThemeResource ControlFillColorSecondaryBrush}"
                    CornerRadius="10"
                    Width="44" Height="44"
                    Margin="0,0,14,0">
                <FontIcon FontFamily="Segoe MDL2 Assets"
                          Glyph="&#xE8A5;"
                          FontSize="20"
                          Foreground="{StaticResource AppAccentBrush}"/>
            </Border>

            <!-- Title + subtitle -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                <TextBlock Text="Export Invoice"
                           FontSize="18"
                           FontWeight="Bold"
                           Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                <TextBlock x:Name="OrderIdText"
                           FontSize="12"
                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Divider -->
        <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                BorderThickness="0,0,0,1"/>

        <!-- ── Format section label ── -->
        <TextBlock Text="Select export format"
                   FontSize="13"
                   FontWeight="SemiBold"
                   Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

        <!-- ── Format cards ── -->
        <StackPanel Spacing="8">
            <!-- PDF Card -->
            <Border x:Name="PdfOptionBorder" Style="{StaticResource FormatCard}" PointerPressed="PdfOptionBorder_PointerPressed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="8" Width="40" Height="40" Margin="0,0,12,0">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE8A5;" FontSize="16" Foreground="{StaticResource AppAccentBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="PDF Document" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                        <TextBlock Text="Universal — opens in any browser or reader" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Border x:Name="PdfCheckMark" Grid.Column="2" Width="20" Height="20" CornerRadius="10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="2" VerticalAlignment="Center">
                        <Ellipse x:Name="PdfDot" Width="8" Height="8" Fill="{StaticResource AppAccentBrush}" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

            <!-- XPS Card -->
            <Border x:Name="XpsOptionBorder" Style="{StaticResource FormatCard}" PointerPressed="XpsOptionBorder_PointerPressed">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="{ThemeResource ControlFillColorSecondaryBrush}" CornerRadius="8" Width="40" Height="40" Margin="0,0,12,0">
                        <FontIcon FontFamily="Segoe MDL2 Assets" Glyph="&#xE714;" FontSize="16" Foreground="{StaticResource AppAccentBrush}"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="2">
                        <StackPanel Orientation="Horizontal" Spacing="6">
                            <TextBlock Text="XPS Document" FontSize="13" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            <Border Background="{ThemeResource SystemFillColorSuccessBackgroundBrush}" CornerRadius="4" Padding="6,2">
                                <TextBlock Text="Windows" FontSize="9" FontWeight="SemiBold" Foreground="{ThemeResource SystemFillColorSuccessBrush}"/>
                            </Border>
                        </StackPanel>
                        <TextBlock Text="Native Windows format, best print quality" FontSize="11" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    </StackPanel>
                    <Border x:Name="XpsCheckMark" Grid.Column="2" Width="20" Height="20" CornerRadius="10" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="2" VerticalAlignment="Center">
                        <Ellipse x:Name="XpsDot" Width="8" Height="8" Fill="{StaticResource AppAccentBrush}" Visibility="Collapsed" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                </Grid>
            </Border>

        </StackPanel>

        <!-- ── CUSTOM BUTTON ROW ── -->
        <Grid ColumnSpacing="12" Margin="0,8,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0"
                    HorizontalAlignment="Stretch"
                    Foreground="White"
                    Padding="0,10"
                    CornerRadius="4"
                    Click="ExportButton_Click">
                <Button.Resources>
                    <!-- Reference Global Accent Colors -->
                    <StaticResource x:Key="ButtonBackground" ResourceKey="AppAccentBrush" />
                    <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#7C4DFF" />
                    <SolidColorBrush x:Key="ButtonBackgroundPressed" Color="#6B39FF" />
                </Button.Resources>
                <TextBlock Text="Export" FontWeight="SemiBold"/>
            </Button>

            <Button Grid.Column="1"
                    HorizontalAlignment="Stretch"
                    Background="{ThemeResource ControlFillColorDefaultBrush}"
                    Padding="0,10"
                    CornerRadius="4"
                    Click="CancelButton_Click">
                <TextBlock Text="Cancel" FontWeight="SemiBold"/>
            </Button>
        </Grid>

    </StackPanel>
</ContentDialog>
