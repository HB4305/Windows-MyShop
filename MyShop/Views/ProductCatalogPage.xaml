<Page x:Class="MyShop.Views.ProductCatalogPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">
  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24" Spacing="16">
      <TextBlock Text="Product Catalog"
                 FontSize="24"
                 FontWeight="Bold"
                 Foreground="{ThemeResource TextFillColorPrimary}"/>
      <Border Padding="24" CornerRadius="12" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" BorderThickness="1">
        <StackPanel HorizontalAlignment="Center" Spacing="8">
          <TextBlock Text="&#xE7BF;" FontFamily="Segoe MDL2 Assets" FontSize="48" Foreground="{ThemeResource TextFillColorTertiary}" HorizontalAlignment="Center"/>
          <TextBlock Text="Product Catalog" FontSize="18" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorSecondary}" HorizontalAlignment="Center"/>
          <TextBlock Text="This page is under construction." FontSize="13" Foreground="{ThemeResource TextFillColorTertiary}" HorizontalAlignment="Center"/>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>
