<Page x:Class="MyShop.Views.SportItemDetailPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:m="using:MyShop.Models"
      xmlns:vm="using:MyShop.ViewModels"
      xmlns:sys="using:System"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:StringToImageConverter x:Key="StringToImageConverter"/>
    </Page.Resources>

    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" Margin="0,0,0,16">
            <Button Content="Quay lại" Click="OnBackClick" Margin="0,0,16,0"/>
            <TextBlock Text="Chi tiết sản phẩm" FontSize="24" FontWeight="Bold"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <StackPanel MaxWidth="500" Spacing="16">
                <!-- Thông tin cơ bản -->
                <TextBox Header="Tên sản phẩm" Text="{x:Bind ViewModel.Item.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                <TextBox Header="SKU" Text="{x:Bind ViewModel.Item.Sku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>

                <ComboBox Header="Danh mục" ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                        SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                        DisplayMemberPath="Name" HorizontalAlignment="Stretch"/>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <TextBox Header="Size" Text="{x:Bind ViewModel.Item.Size, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="0"/>
                    <TextBox Header="Màu" Text="{x:Bind ViewModel.Item.Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Grid.Column="1"/>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <NumberBox Header="Giá nhập" Value="{x:Bind ViewModel.Item.CostPrice, Mode=TwoWay}"/>
                    <NumberBox Header="Giá bán" Value="{x:Bind ViewModel.Item.SellingPrice, Mode=TwoWay}" Grid.Column="1"/>
                </Grid>

                <Grid ColumnSpacing="12">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition/>
                        <ColumnDefinition/>
                    </Grid.ColumnDefinitions>
                    <NumberBox Header="Số lượng tồn" Value="{x:Bind ViewModel.Item.StockQuantity, Mode=TwoWay}" Grid.Column="0"/>
                    <NumberBox Header="Ngưỡng tồn thấp" Value="{x:Bind ViewModel.Item.LowStockThreshold, Mode=TwoWay}" Grid.Column="1"/>
                </Grid>

                <!-- Quản lý hình ảnh -->
                <StackPanel Spacing="8">
                    <TextBlock Text="Hình ảnh sản phẩm" FontWeight="Bold"/>
                    <ScrollViewer HorizontalScrollBarVisibility="Auto" 
                                  VerticalScrollBarVisibility="Disabled"
                                  HorizontalScrollMode="Enabled"
                                  VerticalScrollMode="Disabled"
                                  MinHeight="160">
                        <ListView x:Name="ImageListView"
                                  ItemsSource="{x:Bind ViewModel.ImageUrls, Mode=OneWay}"
                                  SelectionMode="None"
                                  CanReorderItems="True"
                                  CanDragItems="True"
                                  AllowDrop="True">
                            <ListView.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <ItemsStackPanel Orientation="Horizontal"/>
                                </ItemsPanelTemplate>
                            </ListView.ItemsPanel>
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="140" Height="140">
                                        <Image Source="{Binding Converter={StaticResource StringToImageConverter}}" 
                                               Stretch="UniformToFill"/>
                                        <Button Click="OnDeleteImageClick"
                                                Tag="{Binding}"
                                                VerticalAlignment="Top" HorizontalAlignment="Right" 
                                                Background="Red" Foreground="White" 
                                                Width="24" Height="24" Padding="0" Margin="4">
                                            <SymbolIcon Symbol="Cancel"/>
                                        </Button>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </ScrollViewer>
                    <Button Content="+ Thêm ảnh mới" Command="{x:Bind ViewModel.PickImageCommand}" 
                            HorizontalAlignment="Stretch" Padding="8"/>
                </StackPanel>

                <ProgressBar IsIndeterminate="True" 
                            Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
        </ScrollViewer>

        <!-- Nút lưu, xóa và lỗi -->
        <StackPanel Grid.Row="2" Orientation="Vertical" Spacing="8" Margin="0,16,0,0">
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}" Foreground="Red" 
                        HorizontalAlignment="Right" TextWrapping="Wrap"/>
            <StackPanel Orientation="Horizontal" Spacing="12" HorizontalAlignment="Right">
                <Button Content="Xóa sản phẩm" Background="Red" Foreground="White"
                        Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"
                        Command="{x:Bind ViewModel.DeleteCommand}" Width="150" Padding="8"/>
                <Button Content="Lưu sản phẩm" Style="{StaticResource AccentButtonStyle}" 
                        Command="{x:Bind ViewModel.SaveCommand}" Width="150" Padding="8"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Page>
