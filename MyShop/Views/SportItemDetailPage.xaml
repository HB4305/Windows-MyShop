<Page x:Class="MyShop.Views.SportItemDetailPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      xmlns:behaviors="clr-namespace:MyShop.Behaviors;assembly=MyShop"
      xmlns:controls="using:MyShop.Controls"
      Background="#F3F4F6">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <conv:InverseStringToVisibilityConverter x:Key="InverseStringToVisibilityConverter"/>
        <conv:StringToImageConverter x:Key="StringToImageConverter"/>

        <SolidColorBrush x:Key="SportPurpleBrush" Color="#7C3AED"/>
        <SolidColorBrush x:Key="SportPurpleSoftBrush" Color="#F5F3FF"/>

        <Style x:Key="DetailOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="White"/>
            <Setter Property="Foreground" Value="#111827"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>

        <Style x:Key="DetailDeleteOutlineButtonStyle" TargetType="Button" BasedOn="{StaticResource DetailOutlineButtonStyle}">
            <Setter Property="Foreground" Value="#DC2626"/>
        </Style>

        <Style x:Key="DetailPurplePrimaryButtonStyle" TargetType="Button" BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background" Value="{StaticResource SportPurpleBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="CornerRadius" Value="10"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="MinHeight" Value="44"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>

        <Style x:Key="DetailFieldLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#6B7280"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DetailCardBorderStyle" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="BorderBrush" Value="#E5E7EB"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="22"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4" VerticalAlignment="Center">
                <TextBlock Text="Edit product"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Text="Create product"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="#111827"
                           Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <TextBlock Text="Enter details and images, then save to persist."
                           FontSize="13"
                           Foreground="#6B7280"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                <Button Content="Delete"
                        Style="{StaticResource DetailDeleteOutlineButtonStyle}"
                        Command="{x:Bind ViewModel.DeleteCommand}"
                        Visibility="{x:Bind ViewModel.IsEditMode, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Discard"
                        Style="{StaticResource DetailOutlineButtonStyle}"
                        Click="OnDiscardClick"/>
                <Button Command="{x:Bind ViewModel.SaveCommand}"
                        Style="{StaticResource DetailPurplePrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <SymbolIcon Symbol="Save" Foreground="White" VerticalAlignment="Center"/>
                        <TextBlock Text="Save changes" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: gallery + AI card -->
                <StackPanel Grid.Column="0" Spacing="18">
                    <Border Style="{StaticResource DetailCardBorderStyle}" Padding="16">
                        <StackPanel Spacing="12">
                            <Grid Height="280" CornerRadius="12">
                                <Border Background="#F9FAFB"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{x:Bind ViewModel.PreviewImageUrl, Mode=OneWay, Converter={StaticResource InverseStringToVisibilityConverter}}">
                                    <TextBlock Text="No image"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="#9CA3AF"/>
                                </Border>
                                <Image Source="{x:Bind ViewModel.PreviewImageUrl, Mode=OneWay, Converter={StaticResource StringToImageConverter}}"
                                       Stretch="UniformToFill"
                                       Visibility="{x:Bind ViewModel.PreviewImageUrl, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="8"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        Background="#FFFFFF"
                                        BorderBrush="#E5E7EB"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Opacity="0.95">
                                    <SymbolIcon Symbol="Zoom"/>
                                </Button>
                            </Grid>

                            <ScrollViewer HorizontalScrollMode="Enabled"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollMode="Disabled"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <ListView x:Name="ImageThumbnailsListView"
                                              ItemsSource="{x:Bind ViewModel.ImageUrls, Mode=TwoWay}"
                                              SelectedIndex="{x:Bind ViewModel.SelectedImageIndex, Mode=TwoWay}"
                                              SelectionMode="Single"
                                              Padding="0"
                                              Width="Auto"
                                              CanReorderItems="True"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              IsSwipeEnabled="True"
                                              ReorderMode="Enabled">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsStackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding" Value="0"/>
                                                <Setter Property="MinWidth" Value="0"/>
                                                <Setter Property="Margin" Value="0,0,0,0"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="72" Height="72" CornerRadius="8">
                                                    <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <Image Source="{Binding Converter={StaticResource StringToImageConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                    <Button Click="OnDeleteImageClick"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="2"
                                                            Width="22"
                                                            Height="22"
                                                            Padding="0"
                                                            Background="#DC2626"
                                                            CornerRadius="4">
                                                        <SymbolIcon Symbol="Cancel" Foreground="White"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <StackPanel Orientation="Vertical" Spacing="6" VerticalAlignment="Center">
                                        <Button Command="{x:Bind ViewModel.MoveSelectedImageEarlierCommand}"
                                                Style="{StaticResource DetailOutlineButtonStyle}"
                                                MinWidth="44"
                                                MinHeight="36"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="Move left">
                                            <FontIcon Glyph="&#xE76B;" FontSize="12"/>
                                        </Button>
                                        <Button Command="{x:Bind ViewModel.MoveSelectedImageLaterCommand}"
                                                Style="{StaticResource DetailOutlineButtonStyle}"
                                                MinWidth="44"
                                                MinHeight="36"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="Move right">
                                            <FontIcon Glyph="&#xE76C;" FontSize="12"/>
                                        </Button>
                                    </StackPanel>

                                    <Button Command="{x:Bind ViewModel.PickImageCommand}"
                                            Width="72"
                                            Height="72"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="#D1D5DB"
                                            BorderThickness="2"
                                            CornerRadius="8">
                                        <StackPanel Spacing="2" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE710;" FontSize="18" Foreground="#7C3AED"/>
                                            <TextBlock Text="Add" FontSize="11" Foreground="#6B7280"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SportPurpleSoftBrush}"
                            BorderBrush="#EDE9FE"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <FontIcon Glyph="&#xE8FF;" Foreground="#7C3AED"/>
                                <TextBlock Text="AI content assistant"
                                           FontWeight="SemiBold"
                                           Foreground="#5B21B6"/>
                            </StackPanel>
                            <TextBlock Text="Product copy and keyword suggestions — UI placeholder only."
                                       FontSize="12"
                                       Foreground="#6B7280"
                                       TextWrapping="Wrap"/>
                            <Button HorizontalAlignment="Stretch"
                                    Background="White"
                                    BorderBrush="#7C3AED"
                                    BorderThickness="1"
                                    Foreground="#7C3AED"
                                    CornerRadius="10"
                                    Padding="12,8"
                                    IsEnabled="False">
                                <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Center">
                                    <FontIcon Glyph="&#xE8FF;"/>
                                    <TextBlock Text="AI generate description"/>
                                </StackPanel>
                            </Button>
                            <HyperlinkButton Content="OPTIMIZE EXISTING KEYWORDS (SEO)"
                                             FontSize="11"
                                             Foreground="#7C3AED"
                                             IsEnabled="False"
                                             HorizontalAlignment="Left"
                                             Padding="0"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: form -->
                <Border Grid.Column="1" Style="{StaticResource DetailCardBorderStyle}">
                    <StackPanel Spacing="20" MaxWidth="840" HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6">
                            <TextBlock Text="PRODUCT NAME" Style="{StaticResource DetailFieldLabelStyle}"/>
                                <TextBox Text="{x:Bind ViewModel.Item.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. Apex Carbon Pro Tennis Racket"
                                     BorderBrush="#E5E7EB"
                                     Padding="12,10"/>
                        </StackPanel>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Spacing="6">
                                <TextBlock Text="PRICE (USD)" Style="{StaticResource DetailFieldLabelStyle}"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            VerticalAlignment="Stretch"
                                            Padding="12,0"
                                            BorderBrush="#E5E7EB"
                                            BorderThickness="1"
                                            CornerRadius="8,0,0,8"
                                            Background="#F9FAFB">
                                        <TextBlock Text="$" VerticalAlignment="Center" FontWeight="SemiBold" Foreground="#374151"/>
                                    </Border>
                                    <controls:DecimalTextBox Grid.Column="1"
                                               Text="{x:Bind ViewModel.SellingPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                               PlaceholderText="0.00"
                                               BorderThickness="1"
                                               BorderBrush="#E5E7EB"
                                               Padding="10,8"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Spacing="6">
                                <TextBlock Text="COST PRICE (USD)" Style="{StaticResource DetailFieldLabelStyle}"/>
                                <controls:DecimalTextBox Text="{x:Bind ViewModel.CostPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         PlaceholderText="0.00"
                                         BorderBrush="#E5E7EB"
                                         Padding="10,8"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Text="CATEGORY" Style="{StaticResource DetailFieldLabelStyle}"/>
                            <ComboBox ItemsSource="{x:Bind ViewModel.Categories, Mode=OneWay}"
                                      SelectedItem="{x:Bind ViewModel.SelectedCategory, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      HorizontalAlignment="Stretch"
                                      BorderBrush="#E5E7EB"
                                      Padding="10,8"/>
                        </StackPanel>

                        <!-- Fixed-attribute variant matrix (multi-row) -->
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="Variants matrix"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           Foreground="#111827"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Content="+ Add variant"
                                        Style="{StaticResource DetailOutlineButtonStyle}"
                                        Foreground="#7C3AED"
                                        BorderBrush="#C4B5FD"
                                        Command="{x:Bind ViewModel.AddVariantCommand}"/>
                            </Grid>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" CornerRadius="10" Background="#FAFAFA">
                                <StackPanel Padding="12,10" Spacing="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="SIZE" Style="{StaticResource DetailFieldLabelStyle}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="1" Text="COLOR" Style="{StaticResource DetailFieldLabelStyle}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="2" Text="IN STOCK" Style="{StaticResource DetailFieldLabelStyle}" Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="3" Text="VARIANT SKU" Style="{StaticResource DetailFieldLabelStyle}" Margin="0,0,0,4"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{x:Bind ViewModel.Variants, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SportItemVariant">
                                                <Grid ColumnSpacing="12" Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <controls:NumericTextBox Grid.Column="0"
                                                             Text="{x:Bind SizeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Size"
                                                             BorderBrush="#E5E7EB"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{x:Bind Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Color"
                                                             BorderBrush="#E5E7EB"/>
                                                    <controls:NumericTextBox Grid.Column="2"
                                                             Text="{x:Bind StockQuantityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Stock"
                                                             BorderBrush="#E5E7EB"/>
                                                        <TextBox Grid.Column="3"
                                                             Text="{x:Bind Sku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="SKU"
                                                             BorderBrush="#E5E7EB"/>
                                                        <Button Grid.Column="4"
                                                            Content="Remove"
                                                            Style="{StaticResource DetailDeleteOutlineButtonStyle}"
                                                            Command="{Binding ElementName=Root, Path=ViewModel.RemoveVariantCommand}"
                                                            CommandParameter="{Binding}"
                                                            MinWidth="86"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="LOW STOCK THRESHOLD" Style="{StaticResource DetailFieldLabelStyle}"/>
                            <controls:NumericTextBox Text="{x:Bind ViewModel.LowStockThresholdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="0"
                                                     BorderBrush="#E5E7EB"
                                                     Padding="10,8"/>
                        </StackPanel>

                        <!-- <StackPanel Spacing="10">
                            <TextBlock Text="PRODUCT DESCRIPTION" Style="{StaticResource DetailFieldLabelStyle}"/>
                            <Border BorderBrush="#E5E7EB" BorderThickness="1" Background="White">
                                <StackPanel>
                                    <Border BorderBrush="#E5E7EB" BorderThickness="0,0,0,1" Padding="8,6" Background="#F9FAFB">
                                        <StackPanel Orientation="Horizontal" Spacing="4">
                                            <ToggleButton Width="36" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Bold">
                                                <FontIcon Glyph="&#xE8DD;" FontSize="14"/>
                                            </ToggleButton>
                                            <ToggleButton Width="36" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Italic">
                                                <FontIcon Glyph="&#xE8DB;" FontSize="14"/>
                                            </ToggleButton>
                                            <ToggleButton Width="36" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Bulleted list">
                                                <FontIcon Glyph="&#xE8FD;" FontSize="14"/>
                                            </ToggleButton>
                                            <ToggleButton Width="36" Padding="0" IsEnabled="False" ToolTipService.ToolTip="Link">
                                                <FontIcon Glyph="&#xE71B;" FontSize="14"/>
                                            </ToggleButton>
                                        </StackPanel>
                                    </Border>
                                    <TextBox Text="{x:Bind ViewModel.ProductDescriptionUi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                             AcceptsReturn="True"
                                             TextWrapping="Wrap"
                                             MinHeight="120"
                                             BorderThickness="0"
                                             Padding="12,10"
                                             PlaceholderText="Enter description (form-only until a DB column is added)."/>
                                </StackPanel>
                            </Border>
                        </StackPanel> -->
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2" Spacing="8" Margin="0,16,0,0">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{x:Bind ViewModel.IsLoading, Mode=OneWay, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{x:Bind ViewModel.ErrorMessage, Mode=OneWay}"
                       Foreground="#DC2626"
                       TextWrapping="Wrap"
                       Visibility="{x:Bind ViewModel.ErrorMessage, Mode=OneWay, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Page>
