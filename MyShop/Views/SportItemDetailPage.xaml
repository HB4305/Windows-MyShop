<Page x:Class="MyShop.Views.SportItemDetailPage"
      x:Name="Root"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:models="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      xmlns:behaviors="clr-namespace:MyShop.Behaviors;assembly=MyShop"
      xmlns:controls="using:MyShop.Controls"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Page.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibilityConverter"/>
        <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
        <conv:InverseStringToVisibilityConverter x:Key="InverseStringToVisibilityConverter"/>
        <conv:StringToImageConverter x:Key="StringToImageConverter"/>

        <!-- Accent colors -->
        <SolidColorBrush x:Key="SportPurpleBrush"
                         Color="#8B52FF"/>
        <SolidColorBrush x:Key="SportPurpleSoftBrush"
                         Color="#8B52FF"
                         Opacity="0.08"/>
        <SolidColorBrush x:Key="SportPurpleLightBrush"
                         Color="#8B52FF"
                         Opacity="0.12"/>

        <!-- Semantic brushes (theme-aware) -->
        <StaticResource x:Key="PageBackgroundBrush"
                        ResourceKey="ApplicationPageBackgroundThemeBrush"/>
        <StaticResource x:Key="CardBackgroundBrush"
                        ResourceKey="CardBackgroundFillColorDefaultBrush"/>
        <StaticResource x:Key="CardBorderBrush"
                        ResourceKey="ControlStrokeColorDefaultBrush"/>
        <StaticResource x:Key="InputBorderBrush"
                        ResourceKey="ControlStrokeColorDefaultBrush"/>
        <SolidColorBrush x:Key="DangerBrush"
                         Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerLightBrush"
                         Color="#DC2626"
                         Opacity="0.08"/>

        <Style x:Key="DetailOutlineButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background"
                    Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="Foreground"
                    Value="{ThemeResource TextFillColorPrimary}"/>
            <Setter Property="BorderBrush"
                    Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="{ThemeResource ControlCornerRadius}"/>
            <Setter Property="Padding"
                    Value="16,10"/>
            <Setter Property="MinHeight"
                    Value="44"/>
            <Setter Property="FontSize"
                    Value="13"/>
        </Style>

        <Style x:Key="DetailDeleteOutlineButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DetailOutlineButtonStyle}">
            <Setter Property="Foreground"
                    Value="{StaticResource DangerBrush}"/>
        </Style>

        <Style x:Key="DetailPurplePrimaryButtonStyle"
               TargetType="Button"
               BasedOn="{StaticResource DefaultButtonStyle}">
            <Setter Property="Background"
                    Value="{StaticResource SportPurpleBrush}"/>
            <Setter Property="Foreground"
                    Value="White"/>
            <Setter Property="BorderThickness"
                    Value="0"/>
            <Setter Property="CornerRadius"
                    Value="{ThemeResource ControlCornerRadius}"/>
            <Setter Property="Padding"
                    Value="16,10"/>
            <Setter Property="MinHeight"
                    Value="44"/>
            <Setter Property="FontSize"
                    Value="13"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
        </Style>

        <Style x:Key="DetailFieldLabelStyle"
               TargetType="TextBlock">
            <Setter Property="FontSize"
                    Value="11"/>
            <Setter Property="FontWeight"
                    Value="SemiBold"/>
            <Setter Property="Foreground"
                    Value="{ThemeResource TextFillColorSecondary}"/>
            <Setter Property="Margin"
                    Value="0,0,0,6"/>
        </Style>

        <Style x:Key="DetailCardBorderStyle"
               TargetType="Border">
            <Setter Property="Background"
                    Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
            <Setter Property="BorderBrush"
                    Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="14"/>
            <Setter Property="Padding"
                    Value="22"/>
        </Style>

        <Style x:Key="DetailFormInputBorderStyle"
               TargetType="Border">
            <Setter Property="BorderBrush"
                    Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
            <Setter Property="BorderThickness"
                    Value="1"/>
            <Setter Property="CornerRadius"
                    Value="{ThemeResource ControlCornerRadius}"/>
            <Setter Property="Background"
                    Value="{ThemeResource ControlFillColorDefaultBrush}"/>
        </Style>
    </Page.Resources>

    <Grid Padding="24,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Grid Grid.Row="0"
              Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Spacing="4"
                        VerticalAlignment="Center">
                <TextBlock Text="Edit product"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimary}"
                           Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Text="Create product"
                           FontSize="22"
                           FontWeight="SemiBold"
                           Foreground="{ThemeResource TextFillColorPrimary}"
                           Visibility="{Binding IsEditMode, Converter={StaticResource InverseBoolToVisibilityConverter}}"/>
                <TextBlock Text="Enter details and images, then save to persist."
                           FontSize="13"
                           Foreground="{ThemeResource TextFillColorSecondary}"
                           TextWrapping="Wrap"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                        Orientation="Horizontal"
                        Spacing="10"
                        VerticalAlignment="Center">
                <Button Content="Delete"
                        Style="{StaticResource DetailDeleteOutlineButtonStyle}"
                        Command="{Binding DeleteCommand}"
                        Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <Button Content="Discard"
                        Style="{StaticResource DetailOutlineButtonStyle}"
                        Click="OnDiscardClick"/>
                <Button Command="{Binding SaveCommand}"
                        Style="{StaticResource DetailPurplePrimaryButtonStyle}">
                    <StackPanel Orientation="Horizontal"
                                Spacing="8">
                        <SymbolIcon Symbol="Save"
                                    Foreground="White"
                                    VerticalAlignment="Center"/>
                        <TextBlock Text="Save changes"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1"
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Disabled">
            <Grid ColumnSpacing="24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="360"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Left: gallery + AI card -->
                <StackPanel Grid.Column="0"
                            Spacing="18">
                    <Border Style="{StaticResource DetailCardBorderStyle}"
                            Padding="16">
                        <StackPanel Spacing="12">
                            <Grid Height="280"
                                  CornerRadius="12">
                                <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="12"
                                        Visibility="{Binding PreviewImageUrl, Converter={StaticResource InverseStringToVisibilityConverter}}">
                                    <TextBlock Text="No image"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Foreground="{ThemeResource TextFillColorTertiary}"/>
                                </Border>
                                <Image Source="{Binding PreviewImageUrl, Converter={StaticResource StringToImageConverter}}"
                                       Stretch="UniformToFill"
                                       Visibility="{Binding PreviewImageUrl, Converter={StaticResource StringToVisibilityConverter}}"/>
                                <Button HorizontalAlignment="Right"
                                        VerticalAlignment="Top"
                                        Margin="8"
                                        Width="36"
                                        Height="36"
                                        Padding="0"
                                        Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                        BorderThickness="1"
                                        CornerRadius="8"
                                        Opacity="0.95">
                                    <SymbolIcon Symbol="Zoom"/>
                                </Button>
                            </Grid>

                            <ScrollViewer HorizontalScrollMode="Enabled"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollMode="Disabled"
                                          VerticalScrollBarVisibility="Disabled">
                                <StackPanel Orientation="Horizontal"
                                            Spacing="10">
                                    <ListView x:Name="ImageThumbnailsListView"
                                              ItemsSource="{Binding ImageUrls, Mode=TwoWay}"
                                              SelectedIndex="{Binding SelectedImageIndex, Mode=TwoWay}"
                                              SelectionMode="Single"
                                              Padding="0"
                                              Width="Auto"
                                              CanReorderItems="True"
                                              CanDragItems="True"
                                              AllowDrop="True"
                                              IsSwipeEnabled="True"
                                              ReorderMode="Enabled">
                                        <ListView.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <ItemsStackPanel Orientation="Horizontal"/>
                                            </ItemsPanelTemplate>
                                        </ListView.ItemsPanel>
                                        <ListView.ItemContainerStyle>
                                            <Style TargetType="ListViewItem">
                                                <Setter Property="Padding"
                                                        Value="0"/>
                                                <Setter Property="MinWidth"
                                                        Value="0"/>
                                                <Setter Property="Margin"
                                                        Value="0,0,0,0"/>
                                            </Style>
                                        </ListView.ItemContainerStyle>
                                        <ListView.ItemTemplate>
                                            <DataTemplate>
                                                <Grid Width="72"
                                                      Height="72"
                                                      CornerRadius="8">
                                                    <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8">
                                                        <Image Source="{Binding Converter={StaticResource StringToImageConverter}}"
                                                               Stretch="UniformToFill"/>
                                                    </Border>
                                                    <Button Click="OnDeleteImageClick"
                                                            Tag="{Binding}"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Top"
                                                            Margin="2"
                                                            Width="22"
                                                            Height="22"
                                                            Padding="0"
                                                            Background="{StaticResource DangerBrush}"
                                                            CornerRadius="4">
                                                        <SymbolIcon Symbol="Cancel"
                                                                    Foreground="White"/>
                                                    </Button>
                                                </Grid>
                                            </DataTemplate>
                                        </ListView.ItemTemplate>
                                    </ListView>

                                    <StackPanel Orientation="Vertical"
                                                Spacing="6"
                                                VerticalAlignment="Center">
                                        <Button Command="{Binding MoveSelectedImageEarlierCommand}"
                                                Style="{StaticResource DetailOutlineButtonStyle}"
                                                MinWidth="44"
                                                MinHeight="36"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="Move left">
                                            <FontIcon Glyph="&#xE76B;"
                                                      FontSize="12"/>
                                        </Button>
                                        <Button Command="{Binding MoveSelectedImageLaterCommand}"
                                                Style="{StaticResource DetailOutlineButtonStyle}"
                                                MinWidth="44"
                                                MinHeight="36"
                                                Padding="8,4"
                                                ToolTipService.ToolTip="Move right">
                                            <FontIcon Glyph="&#xE76C;"
                                                      FontSize="12"/>
                                        </Button>
                                    </StackPanel>

                                    <Button Command="{Binding PickImageCommand}"
                                            Width="72"
                                            Height="72"
                                            Padding="0"
                                            Background="Transparent"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="2"
                                            CornerRadius="8">
                                        <StackPanel Spacing="2"
                                                    VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xE710;"
                                                      FontSize="18"
                                                      Foreground="{StaticResource SportPurpleBrush}"/>
                                            <TextBlock Text="Add"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondary}"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Border Background="{StaticResource SportPurpleSoftBrush}"
                            BorderBrush="{StaticResource SportPurpleLightBrush}"
                            BorderThickness="1"
                            CornerRadius="14"
                            Padding="18">
                        <StackPanel Spacing="12">
                            <StackPanel Orientation="Horizontal"
                                        Spacing="8">
                                <FontIcon Glyph="&#xEF58;"
                                          Foreground="{StaticResource SportPurpleBrush}"/>
                                <TextBlock Text="AI Content Assistant"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource SportPurpleBrush}"/>
                            </StackPanel>
                            <TextBlock Text="Generate professional product descriptions using AI based on your images and specs."
                                       FontSize="12"
                                       Foreground="{ThemeResource TextFillColorSecondary}"
                                       TextWrapping="Wrap"/>
                            <Button HorizontalAlignment="Stretch"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                                    BorderBrush="{StaticResource SportPurpleBrush}"
                                    BorderThickness="1"
                                    Foreground="{StaticResource SportPurpleBrush}"
                                    CornerRadius="10"
                                    Padding="12,8"
                                    Command="{Binding AutoFillDetailsCommand}">
                                <Grid>
                                    <StackPanel Orientation="Horizontal"
                                                Spacing="8"
                                                HorizontalAlignment="Center"
                                                Visibility="{Binding IsLoading, Converter={StaticResource InverseBoolToVisibilityConverter}}">
                                        <FontIcon Glyph="&#xEF58;"/>
                                        <TextBlock Text="AI Auto-fill Details"/>
                                    </StackPanel>
                                    <ProgressRing IsActive="True"
                                                  Width="20"
                                                  Height="20"
                                                  Foreground="{StaticResource SportPurpleBrush}"
                                                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
                                </Grid>
                            </Button>
                            <TextBlock Text="Tip: Upload an image first for better results!"
                                       FontSize="11"
                                       FontStyle="Italic"
                                       Foreground="{ThemeResource TextFillColorTertiary}"/>
                        </StackPanel>
                    </Border>
                </StackPanel>

                <!-- Right: form -->
                <Border Grid.Column="1"
                        Style="{StaticResource DetailCardBorderStyle}">
                    <StackPanel Spacing="20"
                                MaxWidth="840"
                                HorizontalAlignment="Stretch">
                        <StackPanel Spacing="6">
                            <TextBlock Text="PRODUCT NAME"
                                       Style="{StaticResource DetailFieldLabelStyle}"/>
                            <TextBox Text="{Binding Item.Name, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     PlaceholderText="e.g. Apex Carbon Pro Tennis Racket"
                                     BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                     Background="{ThemeResource ControlFillColorDefaultBrush}"
                                     Foreground="{ThemeResource TextFillColorPrimary}"
                                     BorderThickness="1"
                                     Padding="12,10"/>
                        </StackPanel>

                        <Grid ColumnSpacing="16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0"
                                        Spacing="6">
                                <TextBlock Text="PRICE (USD)"
                                           Style="{StaticResource DetailFieldLabelStyle}"/>
                                <Grid ColumnSpacing="8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            VerticalAlignment="Stretch"
                                            Padding="12,0"
                                            BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                            BorderThickness="1"
                                            CornerRadius="8,0,0,8"
                                            Background="{ThemeResource ControlFillColorDefaultBrush}">
                                        <TextBlock Text="$"
                                                   VerticalAlignment="Center"
                                                   FontWeight="SemiBold"
                                                   Foreground="{ThemeResource TextFillColorPrimary}"/>
                                    </Border>
                                    <controls:DecimalTextBox Grid.Column="1"
                                                             Text="{Binding SellingPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="0.00"
                                                             BorderThickness="1"
                                                             BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                             Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                             Foreground="{ThemeResource TextFillColorPrimary}"
                                                             Padding="10,8"/>
                                </Grid>
                            </StackPanel>
                            <StackPanel Grid.Column="1"
                                        Spacing="6">
                                <TextBlock Text="COST PRICE (USD)"
                                           Style="{StaticResource DetailFieldLabelStyle}"/>
                                <controls:DecimalTextBox Text="{Binding CostPriceText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                         PlaceholderText="0.00"
                                                         BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                         Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                         Foreground="{ThemeResource TextFillColorPrimary}"
                                                         Padding="10,8"/>
                            </StackPanel>
                        </Grid>

                        <StackPanel Spacing="6">
                            <TextBlock Text="CATEGORY"
                                       Style="{StaticResource DetailFieldLabelStyle}"/>
                            <ComboBox ItemsSource="{Binding Categories, Mode=OneWay}"
                                      SelectedItem="{Binding SelectedCategory, Mode=TwoWay}"
                                      DisplayMemberPath="Name"
                                      HorizontalAlignment="Stretch"
                                      BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                      Background="{ThemeResource ControlFillColorDefaultBrush}"
                                      Foreground="{ThemeResource TextFillColorPrimary}"
                                      BorderThickness="1"
                                      Padding="10,8"/>
                        </StackPanel>

                        <!-- Fixed-attribute variant matrix (multi-row) -->
                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="Variants matrix"
                                           FontWeight="SemiBold"
                                           FontSize="15"
                                           Foreground="{ThemeResource TextFillColorPrimary}"
                                           VerticalAlignment="Center"/>
                                <Button HorizontalAlignment="Right"
                                        Content="+ Add variant"
                                        Style="{StaticResource DetailOutlineButtonStyle}"
                                        Foreground="{StaticResource SportPurpleBrush}"
                                        BorderBrush="{StaticResource SportPurpleLightBrush}"
                                        Command="{Binding AddVariantCommand}"/>
                            </Grid>
                            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Background="{ThemeResource ControlFillColorDefaultBrush}">
                                <StackPanel Padding="12,10"
                                            Spacing="10">
                                    <Grid ColumnSpacing="12">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="SIZE"
                                                   Style="{StaticResource DetailFieldLabelStyle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="COLOR"
                                                   Style="{StaticResource DetailFieldLabelStyle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="IN STOCK"
                                                   Style="{StaticResource DetailFieldLabelStyle}"
                                                   Margin="0,0,0,4"/>
                                        <TextBlock Grid.Column="3"
                                                   Text="VARIANT SKU"
                                                   Style="{StaticResource DetailFieldLabelStyle}"
                                                   Margin="0,0,0,4"/>
                                    </Grid>

                                    <ItemsControl ItemsSource="{Binding Variants, Mode=OneWay}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate x:DataType="models:SportItemVariant">
                                                <Grid ColumnSpacing="12"
                                                      Margin="0,0,0,8">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <TextBox Grid.Column="0"
                                                             Text="{Binding SizeText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Size (e.g. 9, XL)"
                                                             BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                             Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                             Foreground="{ThemeResource TextFillColorPrimary}"
                                                             BorderThickness="1"
                                                             Padding="10,8"/>
                                                    <TextBox Grid.Column="1"
                                                             Text="{Binding Color, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="Color"
                                                             BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                             Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                             Foreground="{ThemeResource TextFillColorPrimary}"
                                                             BorderThickness="1"
                                                             Padding="10,8"/>
                                                    <controls:NumericTextBox Grid.Column="2"
                                                                             Text="{Binding StockQuantityText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                             PlaceholderText="Stock"
                                                                             BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                                             Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                                             Foreground="{ThemeResource TextFillColorPrimary}"
                                                                             BorderThickness="1"
                                                                             Padding="10,8"/>
                                                    <TextBox Grid.Column="3"
                                                             Text="{Binding Sku, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                             PlaceholderText="SKU"
                                                             BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                             Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                             Foreground="{ThemeResource TextFillColorPrimary}"
                                                             BorderThickness="1"
                                                             Padding="10,8"/>
                                                    <Button Grid.Column="4"
                                                            Content="Remove"
                                                            Style="{StaticResource DetailDeleteOutlineButtonStyle}"
                                                            Command="{Binding ElementName=Root, Path=DataContext.RemoveVariantCommand}"
                                                            CommandParameter="{Binding}"
                                                            MinWidth="86"/>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </StackPanel>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="6">
                            <TextBlock Text="LOW STOCK THRESHOLD"
                                       Style="{StaticResource DetailFieldLabelStyle}"/>
                            <controls:NumericTextBox Text="{Binding LowStockThresholdText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                     PlaceholderText="0"
                                                     BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                                                     Background="{ThemeResource ControlFillColorDefaultBrush}"
                                                     Foreground="{ThemeResource TextFillColorPrimary}"
                                                     BorderThickness="1"
                                                     Padding="10,8"/>
                        </StackPanel>

                        <StackPanel Spacing="10">
                            <Grid>
                                <TextBlock Text="PRODUCT DESCRIPTION" Style="{StaticResource DetailFieldLabelStyle}"/>
                                <Button HorizontalAlignment="Right"
                                        Command="{Binding GenerateAiDescriptionCommand}"
                                        Padding="8,4"
                                        Background="Transparent"
                                        BorderThickness="0"
                                        ToolTipService.ToolTip="Regenerate with AI">
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <FontIcon Glyph="&#xEF58;" FontSize="14" Foreground="{StaticResource SportPurpleBrush}"/>
                                        <TextBlock Text="AI Magic" FontSize="11" Foreground="{StaticResource SportPurpleBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                            <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}" 
                                    BorderThickness="1" 
                                    CornerRadius="8"
                                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}">
                                <TextBox Text="{Binding ProductDescriptionUi, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                         AcceptsReturn="True"
                                         TextWrapping="Wrap"
                                         MinHeight="160"
                                         BorderThickness="0"
                                         Padding="12,10"
                                         PlaceholderText="Describe your product or use AI to generate it..."/>
                            </Border>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>
        </ScrollViewer>

        <StackPanel Grid.Row="2"
                    Spacing="8"
                    Margin="0,16,0,0">
            <ProgressBar IsIndeterminate="True"
                         Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>
            <TextBlock Text="{Binding ErrorMessage}"
                       Foreground="{StaticResource DangerBrush}"
                       TextWrapping="Wrap"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}"/>
        </StackPanel>
    </Grid>
</Page>
