<Page x:Class="MyShop.Views.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:BoolToForegroundConverter x:Key="BoolToForegroundConverter"/>

    <FontFamily x:Key="InterFont">Segoe UI, Segoe UI Variable Display</FontFamily>

    <SolidColorBrush x:Key="PrimaryBrush"     Color="#8B52FF"/>
    <SolidColorBrush x:Key="DarkTextBrush"    Color="#101828"/>
    <SolidColorBrush x:Key="MutedTextBrush"   Color="#6A7282"/>
    <SolidColorBrush x:Key="InputBgBrush"     Color="#F9FAFB"/>
    <SolidColorBrush x:Key="InputBorderBrush" Color="#E5E7EB"/>
    <SolidColorBrush x:Key="LabelTextBrush"   Color="#364553"/>
    <SolidColorBrush x:Key="ErrorBrush"       Color="#EF4444"/>
    <SolidColorBrush x:Key="SuccessBrush"     Color="#10B981"/>
    <SolidColorBrush x:Key="CheckBgBrush"     Color="#F3F3F5"/>
    <SolidColorBrush x:Key="GrayBrush"        Color="#99A1AF"/>
    <SolidColorBrush x:Key="PurpleFaintBrush" Color="#8B52FF" Opacity="0.08"/>
  </Page.Resources>

  <Grid>
    <Grid.ColumnDefinitions>
      <!-- LEFT: Hero decoration -->
      <ColumnDefinition Width="*"/>
      <!-- RIGHT: Config Form -->
      <ColumnDefinition Width="600"/>
    </Grid.ColumnDefinitions>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- RIGHT PANEL: Config Form (600px) -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Column="1" Margin="48,48,48,48">

      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <!-- Logo + brand -->
        <RowDefinition Height="Auto"/>
        <!-- Heading -->
        <RowDefinition Height="Auto"/>
        <!-- Form fields -->
        <RowDefinition Height="*"/>
        <!-- Version footer -->
        <RowDefinition Height="Auto"/>
      </Grid.RowDefinitions>

      <!-- ── Brand Header ── -->
      <StackPanel Grid.Row="0" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,48">

        <Border Width="48" Height="48"
                CornerRadius="14"
                Background="{StaticResource PrimaryBrush}"
                Padding="12">
          <Viewbox Width="24" Height="24">
            <Path Data="M12 2L2 7L12 12L22 7L12 2Z M2 17L12 22L22 17 M2 12L12 17L22 12"
                  Stroke="White" StrokeThickness="2"
                  StrokeLineJoin="Round" Fill="Transparent"/>
          </Viewbox>
        </Border>

        <StackPanel Margin="12,0,0,0" VerticalAlignment="Center">
          <TextBlock Text="ProSport Hub"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="24" FontWeight="Bold"
                     Foreground="{ThemeResource TextFillColorPrimary}"/>
          <TextBlock Text="DATABASE CONFIGURATION"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="12" FontWeight="400"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     CharacterSpacing="600"
                     Margin="0,2,0,0"/>
        </StackPanel>
      </StackPanel>

      <!-- ── Heading ── -->
      <StackPanel Grid.Row="1" Margin="0,0,0,32">
        <TextBlock Text="Database Connection"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="30" FontWeight="Bold"
                   Foreground="{ThemeResource TextFillColorPrimary}"/>
        <TextBlock Text="Enter your PostgreSQL database connection details."
                   FontFamily="{StaticResource InterFont}"
                   FontSize="16" FontWeight="400"
                   Foreground="{ThemeResource TextFillColorSecondary}"
                   TextWrapping="Wrap"
                   Margin="0,8,0,0"/>
      </StackPanel>

      <!-- ── Form Fields ── -->
      <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
        <StackPanel VerticalAlignment="Top">

          <!-- Host -->
          <TextBlock Text="Host"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,0,0,8"/>
          <TextBox Text="{Binding DbHost, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="db.xxxxxx.supabase.co"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14"
                   IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                   Background="{ThemeResource ControlFillColorDefaultBrush}"
                   Foreground="{ThemeResource TextFillColorPrimary}"
                   BorderBrush="{ThemeResource TextBoxBorderBrush}"
                   CornerRadius="8"
                   Padding="12,10,12,10"
                   Height="48"
                   VerticalContentAlignment="Center"
                   Margin="0,0,0,16"/>

          <!-- Port + Database Name (2 columns) -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="140"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Port -->
            <StackPanel Grid.Column="0" Margin="0,0,12,0">
              <TextBlock Text="Port"
                         FontFamily="{StaticResource InterFont}"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         Margin="0,0,0,8"/>
              <TextBox Text="{Binding DbPort, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="5432"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14"
                       IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                       Background="{ThemeResource ControlFillColorDefaultBrush}"
                       Foreground="{ThemeResource TextFillColorPrimary}"
                       BorderBrush="{ThemeResource TextBoxBorderBrush}"
                       CornerRadius="8"
                       Padding="12,10,12,10"
                       Height="48"
                       VerticalContentAlignment="Center"
                       InputScope="Number"/>
            </StackPanel>

            <!-- Database Name -->
            <StackPanel Grid.Column="1" Margin="12,0,0,0">
              <TextBlock Text="Database Name"
                         FontFamily="{StaticResource InterFont}"
                         FontSize="14" FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorSecondary}"
                         Margin="0,0,0,8"/>
              <TextBox Text="{Binding DbName, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                       PlaceholderText="postgres"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14"
                       IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                       Background="{ThemeResource ControlFillColorDefaultBrush}"
                       Foreground="{ThemeResource TextFillColorPrimary}"
                       BorderBrush="{ThemeResource TextBoxBorderBrush}"
                       CornerRadius="8"
                       Padding="12,10,12,10"
                       Height="48"
                       VerticalContentAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Database User -->
          <TextBlock Text="Database User"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,0,0,8"/>
          <TextBox Text="{Binding DbUsername, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                   PlaceholderText="postgres"
                   FontFamily="{StaticResource InterFont}"
                   FontSize="14"
                   IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                   Background="{ThemeResource ControlFillColorDefaultBrush}"
                   Foreground="{ThemeResource TextFillColorPrimary}"
                   BorderBrush="{ThemeResource TextBoxBorderBrush}"
                   CornerRadius="8"
                   Padding="12,10,12,10"
                   Height="48"
                   VerticalContentAlignment="Center"
                   Margin="0,0,0,16"/>

          <!-- Database Password -->
          <TextBlock Text="Database Password"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14" FontWeight="SemiBold"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,0,0,8"/>
          <Grid Margin="0,0,0,20">
            <PasswordBox x:Name="DbPasswordBox"
                         IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
                         Background="{ThemeResource ControlFillColorDefaultBrush}"
                         Foreground="{ThemeResource TextFillColorPrimary}"
                         BorderBrush="{ThemeResource TextBoxBorderBrush}"
                         CornerRadius="8"
                         Padding="12,10,40,10"
                         Height="48"
                         VerticalContentAlignment="Center"/>
            <!-- Show/hide password toggle -->
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,8,0"
                    Width="32" Height="32"
                    Background="Transparent"
                    BorderThickness="0"
                    Click="TogglePassword_Click">
              <Viewbox Width="17" Height="12">
                <Path Data="M1 6C1 6 4 1 8.5 1C13 1 16 6 16 6C16 6 13 11 8.5 11C4 11 1 6 1 6ZM8.5 3C6.01 3 4 5.01 4 7.5C4 9.99 6.01 12 8.5 12C10.99 12 13 9.99 13 7.5C13 5.01 10.99 3 8.5 3ZM8.5 4.5C9.88 4.5 11 5.62 11 7C11 8.38 9.88 9.5 8.5 9.5C7.12 9.5 6 8.38 6 7C6 5.62 7.12 4.5 8.5 4.5ZM1 6V12H16V6"
                      Stroke="{ThemeResource TextFillColorSecondary}" StrokeThickness="1"
                      Fill="Transparent" StrokeLineJoin="Round"/>
              </Viewbox>
            </Button>
          </Grid>

          <!-- Message -->
          <TextBlock Text="{Binding Message}"
                     FontFamily="{StaticResource InterFont}"
                     FontSize="14"
                     TextWrapping="Wrap"
                     Margin="0,0,0,16"
                     Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}"
                     Foreground="{Binding IsSuccess, Converter={StaticResource BoolToForegroundConverter}}"/>

          <!-- Progress bar -->
          <ProgressBar IsIndeterminate="True"
                       Height="4"
                       Margin="0,0,0,16"
                       Foreground="{StaticResource PrimaryBrush}"
                       Background="{ThemeResource ControlFillColorDefaultBrush}"
                       Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

          <!-- Save button -->
          <Button Command="{Binding SaveCommand}"
                   HorizontalAlignment="Stretch"
                   Height="48"
                   CornerRadius="14"
                   Background="{StaticResource PrimaryBrush}"
                   BorderThickness="0"
                   IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}">
            <TextBlock Text="Save Configuration"
                       FontFamily="{StaticResource InterFont}"
                       FontSize="14" FontWeight="SemiBold"
                       Foreground="White"/>
          </Button>

        </StackPanel>
      </ScrollViewer>

      <!-- ── Version Footer ── -->
      <TextBlock Grid.Row="4"
                 Text="{Binding AppVersion}"
                 FontFamily="{StaticResource InterFont}"
                 FontSize="14" FontWeight="400"
                 Foreground="{ThemeResource TextFillColorTertiary}"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Bottom"/>
    </Grid>

    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <!-- LEFT PANEL: Hero decoration -->
    <!-- ═══════════════════════════════════════════════════════════════════ -->
    <Grid Grid.Column="0" Background="{StaticResource PrimaryBrush}">
      <Grid Margin="138,0,138,0">
        <Ellipse Width="600" Height="600"
                 HorizontalAlignment="Center"
                 VerticalAlignment="Center"
                 Opacity="0.08">
          <Ellipse.Fill>
            <SolidColorBrush Color="White"/>
          </Ellipse.Fill>
          <Ellipse.RenderTransform>
            <TranslateTransform Y="-200"/>
          </Ellipse.RenderTransform>
        </Ellipse>

        <Border Width="80" Height="80"
                CornerRadius="24"
                HorizontalAlignment="Left"
                VerticalAlignment="Top"
                Margin="60,80,0,0">
          <Grid>
            <Border Background="White" Opacity="0.20" CornerRadius="24"/>
            <Viewbox Width="40" Height="40" Margin="20">
              <Path Data="M12 2L2 7L12 12L22 7L12 2Z M2 17L12 22L22 17"
                    Stroke="White" StrokeThickness="2"
                    StrokeLineJoin="Round" Fill="Transparent"/>
            </Viewbox>
          </Grid>
        </Border>

        <StackPanel HorizontalAlignment="Left"
                    VerticalAlignment="Center">
          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="72" FontWeight="Bold"
                     Foreground="White"
                     LineHeight="88">
            <Run Text="Set Up"/><LineBreak/>
            <Run Text="Your Database"/>
          </TextBlock>

          <TextBlock FontFamily="{StaticResource InterFont}"
                     FontSize="18" FontWeight="400"
                     Foreground="White"
                     Opacity="0.90"
                     TextWrapping="Wrap"
                     Margin="0,16,0,0"
                     MaxWidth="512">
            <Run Text="Connect to your Supabase Postgres instance"/><LineBreak/>
            <Run Text="to get started."/>
          </TextBlock>
        </StackPanel>
      </Grid>
    </Grid>
  </Grid>
</Page>
