<Page x:Class="MyShop.Views.ConfigPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <conv:StringToVisibilityConverter x:Key="StringToVisibilityConverter"/>
    <conv:BoolToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    <conv:InverseBoolConverter x:Key="InverseBoolConverter"/>
    <conv:BoolToForegroundConverter x:Key="BoolToForegroundConverter"/>
  </Page.Resources>

  <Grid Margin="24">

    <Grid.RowDefinitions>
      <RowDefinition Height="Auto"/>
      <RowDefinition Height="*"/>
    </Grid.RowDefinitions>

    <!-- Thanh tiêu đề -->
    <Grid Grid.Row="0" Margin="0,0,0,24">
      <Grid.ColumnDefinitions>
        <ColumnDefinition Width="Auto"/>
        <ColumnDefinition Width="*"/>
      </Grid.ColumnDefinitions>

      <Button Grid.Column="0" Content="← Quay lại"
              Command="{Binding BackCommand}"
              VerticalAlignment="Center"/>

      <TextBlock Grid.Column="1"
                 Text="Cấu hình Server"
                 FontSize="28" FontWeight="Bold"
                 VerticalAlignment="Center"
                 HorizontalAlignment="Center"/>
    </Grid>

    <!-- Nội dung cấu hình -->
    <StackPanel Grid.Row="1" MaxWidth="600" HorizontalAlignment="Left">

      <TextBlock Text="Supabase URL"
                 FontWeight="SemiBold" Margin="0,0,0,6"/>
      <TextBox Text="{Binding SupabaseUrl, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="https://your-project.supabase.co"
               IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
               Margin="0,0,0,20"/>

      <TextBlock Text="Supabase Anon Key"
                 FontWeight="SemiBold" Margin="0,0,0,6"/>
      <TextBox Text="{Binding SupabaseAnonKey, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
               PlaceholderText="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
               IsEnabled="{Binding IsLoading, Converter={StaticResource InverseBoolConverter}}"
               TextWrapping="Wrap"
               Margin="0,0,0,20"/>

      <!-- Thông báo -->
      <TextBlock Text="{Binding Message}"
                 TextWrapping="Wrap"
                 Margin="0,0,0,16"
                 Visibility="{Binding Message, Converter={StaticResource StringToVisibilityConverter}}"
                 Foreground="{Binding IsSuccess, Converter={StaticResource BoolToForegroundConverter}}"/>

      <!-- Nút lưu -->
      <Button Content="Lưu cấu hình"
              Command="{Binding SaveCommand}"
              HorizontalAlignment="Left"
              MinWidth="160"
              Height="44"
              FontSize="15"/>
    </StackPanel>
  </Grid>
</Page>
