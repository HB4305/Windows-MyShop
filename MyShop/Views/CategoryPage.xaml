<Page x:Class="MyShop.Views.CategoryPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:m="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

  <Page.Resources>
    <!-- Purple accent color -->
    <SolidColorBrush x:Key="PurpleBrush" Color="#8B52FF"/>
    <SolidColorBrush x:Key="PurpleLightBrush" Color="#1A8B52FF"/> <!-- Faint purple, alpha 10% -->
    <SolidColorBrush x:Key="PurpleFaintBrush" Color="#0D8B52FF"/> <!-- Extra faint purple, alpha 5% -->

    <!-- Text colors -> Replaced by direct ThemeResource bindings in most places, provided here for fallback -->
    <SolidColorBrush x:Key="DarkTextBrush" Color="{ThemeResource TextFillColorPrimary}"/>
    <SolidColorBrush x:Key="GrayTextBrush" Color="{ThemeResource TextFillColorSecondary}"/>
    <SolidColorBrush x:Key="MutedTextBrush" Color="{ThemeResource TextFillColorTertiary}"/>

    <!-- Card style -->
    <Style x:Key="CardBorder" TargetType="Border">
      <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}"/>
      <Setter Property="BorderBrush" Value="{ThemeResource ControlStrokeColorDefaultBrush}"/>
      <Setter Property="BorderThickness" Value="1"/>
      <Setter Property="CornerRadius" Value="{ThemeResource ControlCornerRadius}"/>
      <Setter Property="Padding"
          Value="20"/>
    </Style>

    <!-- Transparent button style for icon buttons -->
    <Style x:Key="IconActionButton"
        TargetType="Button">
      <Setter Property="Background"
          Value="Transparent"/>
      <Setter Property="BorderThickness"
          Value="0"/>
      <Setter Property="Padding"
          Value="0"/>
      <Setter Property="MinWidth"
          Value="0"/>
      <Setter Property="MinHeight"
          Value="0"/>
    </Style>
  </Page.Resources>

  <StackPanel Margin="24"
        Spacing="20">

      <!-- ═══════════════════════════ PAGE TITLE ═══════════════════════════ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Categories"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="{ThemeResource TextFillColorPrimary}"/>
          <TextBlock Text="Organize your product catalog with categories."
                     FontSize="13"
                     Foreground="{ThemeResource TextFillColorSecondary}"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            Spacing="10"
            VerticalAlignment="Center">

          <!-- Loading indicator -->
          <ProgressRing IsActive="{Binding IsLoading}"
                        Width="20"
              Height="20"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

          <!-- Add Category button -->
          <Button Command="{Binding AddCategoryCommand}"
                  Background="{StaticResource PurpleBrush}"
                  BorderBrush="{StaticResource PurpleBrush}"
                  BorderThickness="0"
                  CornerRadius="{ThemeResource ControlCornerRadius}"
                  Padding="14,8">
            <Button.Resources>
              <SolidColorBrush x:Key="ButtonBackgroundPointerOver" Color="#9A66FF"/>
              <SolidColorBrush x:Key="ButtonBorderBrushPointerOver" Color="#9A66FF"/>
              <SolidColorBrush x:Key="ButtonForegroundPointerOver" Color="White"/>
            </Button.Resources>
            <StackPanel Orientation="Horizontal"
                Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE710;"
                  FontSize="13"
                  Foreground="White"
                  VerticalAlignment="Center"/>
              <TextBlock Text="Add Category"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="White"
                  VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ═══════════════════════════ NOTIFICATION BARS ═══════════════════════════ -->
      <StackPanel Spacing="8"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
        <Border Background="#FEF2F2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
          <StackPanel Orientation="Horizontal"
              Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                Text="&#xEA39;"
                FontSize="14"
                Foreground="#DC2626"
                VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ErrorMessage}"
                FontSize="13"
                Foreground="#DC2626"
                TextWrapping="Wrap"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Spacing="8"
                  Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
        <Border Background="#ECFDF5"
                BorderBrush="#A7F3D0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
          <StackPanel Orientation="Horizontal"
              Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                Text="&#xE73E;"
                FontSize="14"
                Foreground="#059669"
                VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SuccessMessage}"
                FontSize="13"
                Foreground="#059669"
                TextWrapping="Wrap"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ═══════════════════════════ CATEGORY LIST CARD ═══════════════════════════ -->
      <Border Style="{StaticResource CardBorder}" Padding="0">
        <Grid>
          <!-- Loading overlay -->
          <Border Background="{ThemeResource LayerOnMicaBaseAltFillColorDefaultBrush}"
                  CornerRadius="12"
                  Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"
                  HorizontalAlignment="Stretch"
                  VerticalAlignment="Stretch"
                  Canvas.ZIndex="10">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="8">
              <ProgressBar IsIndeterminate="True" Width="120" Foreground="{StaticResource PurpleBrush}"/>
              <TextBlock Text="Loading categories..."
                         FontSize="13" Foreground="{ThemeResource TextFillColorSecondary}"
                         HorizontalAlignment="Center"/>
            </StackPanel>
          </Border>

          <StackPanel Padding="20">
          <!-- Card Header -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                Spacing="8">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE8EC;"
                  FontSize="14"
                  Foreground="{StaticResource PurpleBrush}"
                  VerticalAlignment="Center"/>
              <TextBlock Text="All Categories"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="{ThemeResource TextFillColorPrimary}"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4">
              <TextBlock Text="{Binding Categories.Count, Mode=OneWay}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="{StaticResource PurpleBrush}"
                         VerticalAlignment="Center"/>
              <TextBlock Text="items"
                         FontSize="12"
                         Foreground="{ThemeResource TextFillColorTertiary}"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Table Header -->
          <Border Background="{ThemeResource ControlFillColorDefaultBrush}"
                  CornerRadius="{ThemeResource ControlCornerRadius}"
                  Padding="12,10"
                  Margin="0,0,0,4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="80"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0" Text="NAME" FontSize="10" Foreground="{ThemeResource TextFillColorTertiary}" FontWeight="SemiBold" CharacterSpacing="40"/>
              <TextBlock Grid.Column="1" Text="DESCRIPTION" FontSize="10" Foreground="{ThemeResource TextFillColorTertiary}" FontWeight="SemiBold" CharacterSpacing="40"/>
              <TextBlock Grid.Column="2" Text="ACTIONS" FontSize="10" Foreground="{ThemeResource TextFillColorTertiary}" FontWeight="SemiBold" HorizontalAlignment="Right" CharacterSpacing="40"/>
            </Grid>
          </Border>

          <!-- Category List -->
          <ItemsControl ItemsSource="{Binding Categories}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:Category">
                <Border BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,12"
                        Margin="0,0,0,0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="2*"/>
                      <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name + icon -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                      <Border Background="{StaticResource PurpleLightBrush}"
                              CornerRadius="6"
                              Width="28"
                              Height="28"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE8EC;"
                                   FontSize="12"
                                   Foreground="{StaticResource PurpleBrush}"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock Text="{x:Bind Name}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="{ThemeResource TextFillColorPrimary}"
                                 VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Description -->
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Description}"
                               FontSize="12"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               MaxLines="2"
                               TextTrimming="WordEllipsis"
                               TextWrapping="Wrap"
                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                      <!-- Edit button -->
                      <Button Style="{StaticResource IconActionButton}"
                              DataContext="{Binding}"
                              Click="EditCategory_Click">
                        <Border Background="{StaticResource PurpleLightBrush}"
                                CornerRadius="6"
                                Padding="8,5">
                          <TextBlock FontFamily="Segoe MDL2 Assets"
                                     Text="&#xE70F;"
                                     FontSize="12"
                                     Foreground="{StaticResource PurpleBrush}"/>
                        </Border>
                      </Button>

                      <!-- Delete button -->
                      <Button Style="{StaticResource IconActionButton}"
                              DataContext="{Binding}"
                              Click="DeleteCategory_Click">
                        <Border Background="{ThemeResource SystemFillColorCriticalBackgroundBrush}"
                                CornerRadius="6"
                                Padding="8,5">
                          <TextBlock FontFamily="Segoe MDL2 Assets"
                                     Text="&#xE74D;"
                                     FontSize="12"
                                     Foreground="{ThemeResource SystemFillColorCriticalBrush}"/>
                        </Border>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty State - inside card -->
          <StackPanel HorizontalAlignment="Center"
                      Spacing="12"
                      Margin="0,32,0,32"
                      Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="{StaticResource PurpleLightBrush}"
                    CornerRadius="20"
                    Width="56"
                    Height="56"
                    HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE14C;"
                         FontSize="24"
                         Foreground="{StaticResource PurpleBrush}"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="No categories yet"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="{ThemeResource TextFillColorPrimary}"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Create your first category to start organizing products."
                       FontSize="12"
                       Foreground="{ThemeResource TextFillColorSecondary}"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Grid>
    </Border>
    </StackPanel>
</Page>