<Page x:Class="MyShop.Views.CategoryPage"
      x:Name="PageRoot"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:m="using:MyShop.Models"
      xmlns:conv="using:MyShop.Converters"
      Background="#F3F4F6">

  <Page.Resources>
    <!-- Purple accent color -->
    <SolidColorBrush x:Key="PurpleBrush"
        Color="#7C3AED"/>
    <SolidColorBrush x:Key="PurpleLightBrush"
        Color="#F3F0FF"/>
    <SolidColorBrush x:Key="PurpleFaintBrush"
        Color="#EDE9FE"/>

    <!-- Text colors -->
    <SolidColorBrush x:Key="DarkTextBrush"
        Color="#1F2937"/>
    <SolidColorBrush x:Key="GrayTextBrush"
        Color="#6B7280"/>
    <SolidColorBrush x:Key="MutedTextBrush"
        Color="#9CA3AF"/>

    <!-- Card style -->
    <Style x:Key="CardBorder"
        TargetType="Border">
      <Setter Property="Background"
          Value="White"/>
      <Setter Property="BorderBrush"
          Value="#E5E7EB"/>
      <Setter Property="BorderThickness"
          Value="1"/>
      <Setter Property="CornerRadius"
          Value="12"/>
      <Setter Property="Padding"
          Value="20"/>
    </Style>

    <!-- Transparent button style for icon buttons -->
    <Style x:Key="IconActionButton"
        TargetType="Button">
      <Setter Property="Background"
          Value="Transparent"/>
      <Setter Property="BorderThickness"
          Value="0"/>
      <Setter Property="Padding"
          Value="0"/>
      <Setter Property="MinWidth"
          Value="0"/>
      <Setter Property="MinHeight"
          Value="0"/>
    </Style>
  </Page.Resources>

  <ScrollViewer VerticalScrollBarVisibility="Auto">
    <StackPanel Margin="24"
        Spacing="20">

      <!-- ═══════════════════════════ PAGE TITLE ═══════════════════════════ -->
      <Grid>
        <Grid.ColumnDefinitions>
          <ColumnDefinition Width="*"/>
          <ColumnDefinition Width="Auto"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0">
          <TextBlock Text="Categories"
                     FontSize="22"
                     FontWeight="Bold"
                     Foreground="#1F2937"/>
          <TextBlock Text="Organize your product catalog with categories."
                     FontSize="13"
                     Foreground="#6B7280"
                     Margin="0,2,0,0"/>
        </StackPanel>

        <!-- Controls -->
        <StackPanel Grid.Column="1"
            Orientation="Horizontal"
            Spacing="10"
            VerticalAlignment="Center">

          <!-- Loading indicator -->
          <ProgressRing IsActive="{Binding IsLoading}"
                        Width="20"
              Height="20"
                        Visibility="{Binding IsLoading, Converter={StaticResource BoolToVisibilityConverter}}"/>

          <!-- Add Category button -->
          <Button Command="{Binding AddCategoryCommand}"
                  Background="#7C3AED"
                  BorderBrush="#7C3AED"
                  BorderThickness="0"
                  CornerRadius="8"
                  Padding="14,8">
            <Button.Resources>
              <SolidColorBrush x:Key="ButtonBackgroundPointerOver"
                  Color="#E67C3AED"/>
              <SolidColorBrush x:Key="ButtonBorderBrushPointerOver"
                  Color="#E67C3AED"/>
              <SolidColorBrush x:Key="ButtonForegroundPointerOver"
                  Color="White"/>
            </Button.Resources>
            <StackPanel Orientation="Horizontal"
                Spacing="6">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE710;"
                  FontSize="13"
                  Foreground="White"
                  VerticalAlignment="Center"/>
              <TextBlock Text="Add Category"
                  FontSize="13"
                  FontWeight="SemiBold"
                  Foreground="White"
                  VerticalAlignment="Center"/>
            </StackPanel>
          </Button>
        </StackPanel>
      </Grid>

      <!-- ═══════════════════════════ NOTIFICATION BARS ═══════════════════════════ -->
      <StackPanel Spacing="8"
                  Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibilityConverter}}">
        <Border Background="#FEF2F2"
                BorderBrush="#FECACA"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
          <StackPanel Orientation="Horizontal"
              Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                Text="&#xEA39;"
                FontSize="14"
                Foreground="#DC2626"
                VerticalAlignment="Center"/>
            <TextBlock Text="{Binding ErrorMessage}"
                FontSize="13"
                Foreground="#DC2626"
                TextWrapping="Wrap"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </StackPanel>

      <StackPanel Spacing="8"
                  Visibility="{Binding SuccessMessage, Converter={StaticResource StringToVisibilityConverter}}">
        <Border Background="#ECFDF5"
                BorderBrush="#A7F3D0"
                BorderThickness="1"
                CornerRadius="8"
                Padding="16,12">
          <StackPanel Orientation="Horizontal"
              Spacing="8">
            <TextBlock FontFamily="Segoe MDL2 Assets"
                Text="&#xE73E;"
                FontSize="14"
                Foreground="#059669"
                VerticalAlignment="Center"/>
            <TextBlock Text="{Binding SuccessMessage}"
                FontSize="13"
                Foreground="#059669"
                TextWrapping="Wrap"
                VerticalAlignment="Center"/>
          </StackPanel>
        </Border>
      </StackPanel>

      <!-- ═══════════════════════════ CATEGORY LIST CARD ═══════════════════════════ -->
      <Border Style="{StaticResource CardBorder}">
        <StackPanel>
          <!-- Card Header -->
          <Grid Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0"
                Orientation="Horizontal"
                Spacing="8">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                  Text="&#xE8EC;"
                  FontSize="14"
                  Foreground="#7C3AED"
                  VerticalAlignment="Center"/>
              <TextBlock Text="All Categories"
                         FontSize="15"
                         FontWeight="SemiBold"
                         Foreground="#1F2937"
                         VerticalAlignment="Center"/>
            </StackPanel>

            <StackPanel Grid.Column="1"
                Orientation="Horizontal"
                Spacing="4">
              <TextBlock Text="{Binding Categories.Count, Mode=OneWay}"
                         FontSize="12"
                         FontWeight="SemiBold"
                         Foreground="#7C3AED"
                         VerticalAlignment="Center"/>
              <TextBlock Text="items"
                         FontSize="12"
                         Foreground="#9CA3AF"
                         VerticalAlignment="Center"/>
            </StackPanel>
          </Grid>

          <!-- Table Header -->
          <Border Background="#FAFAFA"
                  CornerRadius="8"
                  Padding="12,10"
                  Margin="0,0,0,4">
            <Grid>
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="80"/>
              </Grid.ColumnDefinitions>
              <TextBlock Grid.Column="0"
                  Text="NAME"
                  FontSize="10"
                  Foreground="#9CA3AF"
                  FontWeight="SemiBold"
                  CharacterSpacing="40"/>
              <TextBlock Grid.Column="1"
                  Text="DESCRIPTION"
                  FontSize="10"
                  Foreground="#9CA3AF"
                  FontWeight="SemiBold"
                  CharacterSpacing="40"/>
              <TextBlock Grid.Column="2"
                  Text="ACTIONS"
                  FontSize="10"
                  Foreground="#9CA3AF"
                  FontWeight="SemiBold"
                  HorizontalAlignment="Right"
                  CharacterSpacing="40"/>
            </Grid>
          </Border>

          <!-- Category List -->
          <ItemsControl ItemsSource="{Binding Categories}">
            <ItemsControl.ItemTemplate>
              <DataTemplate x:DataType="m:Category">
                <Border BorderBrush="#F3F4F6"
                        BorderThickness="0,0,0,1"
                        Padding="12,12"
                        Margin="0,0,0,0">
                  <Grid>
                    <Grid.ColumnDefinitions>
                      <ColumnDefinition Width="*"/>
                      <ColumnDefinition Width="2*"/>
                      <ColumnDefinition Width="80"/>
                    </Grid.ColumnDefinitions>

                    <!-- Name + icon -->
                    <StackPanel Grid.Column="0"
                                Orientation="Horizontal"
                                Spacing="10"
                                VerticalAlignment="Center">
                      <Border Background="#F3F0FF"
                              CornerRadius="6"
                              Width="28"
                              Height="28"
                              HorizontalAlignment="Left"
                              VerticalAlignment="Center">
                        <TextBlock FontFamily="Segoe MDL2 Assets"
                                   Text="&#xE8EC;"
                                   FontSize="12"
                                   Foreground="#7C3AED"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                      </Border>
                      <TextBlock Text="{x:Bind Name}"
                                 FontSize="13"
                                 FontWeight="SemiBold"
                                 Foreground="#1F2937"
                                 VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Description -->
                    <TextBlock Grid.Column="1"
                               Text="{x:Bind Description}"
                               FontSize="12"
                               Foreground="#6B7280"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               MaxLines="2"
                               TextTrimming="WordEllipsis"
                               TextWrapping="Wrap"
                               Visibility="{Binding Description, Converter={StaticResource StringToVisibilityConverter}}"/>

                    <!-- Action buttons -->
                    <StackPanel Grid.Column="2"
                                Orientation="Horizontal"
                                Spacing="4"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                      <!-- Edit button -->
                      <Button Style="{StaticResource IconActionButton}"
                              DataContext="{Binding}"
                              Click="EditCategory_Click">
                        <Border Background="#F3F0FF"
                                CornerRadius="6"
                                Padding="8,5">
                          <TextBlock FontFamily="Segoe MDL2 Assets"
                                     Text="&#xE70F;"
                                     FontSize="12"
                                     Foreground="#7C3AED"/>
                        </Border>
                      </Button>

                      <!-- Delete button -->
                      <Button Style="{StaticResource IconActionButton}"
                              DataContext="{Binding}"
                              Click="DeleteCategory_Click">
                        <Border Background="#FEF2F2"
                                CornerRadius="6"
                                Padding="8,5">
                          <TextBlock FontFamily="Segoe MDL2 Assets"
                                     Text="&#xE74D;"
                                     FontSize="12"
                                     Foreground="#DC2626"/>
                        </Border>
                      </Button>
                    </StackPanel>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>

          <!-- Empty State - inside card -->
          <StackPanel HorizontalAlignment="Center"
                      Spacing="12"
                      Margin="0,32,0,32"
                      Visibility="{Binding ShowEmptyState, Converter={StaticResource BoolToVisibilityConverter}}">
            <Border Background="#F3F0FF"
                    CornerRadius="20"
                    Width="56"
                Height="56"
                    HorizontalAlignment="Center">
              <TextBlock FontFamily="Segoe MDL2 Assets"
                         Text="&#xE14C;"
                         FontSize="24"
                         Foreground="#7C3AED"
                         HorizontalAlignment="Center"
                         VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="No categories yet"
                       FontSize="15"
                       FontWeight="SemiBold"
                       Foreground="#1F2937"
                       HorizontalAlignment="Center"/>
            <TextBlock Text="Create your first category to start organizing products."
                       FontSize="12"
                       Foreground="#9CA3AF"
                       HorizontalAlignment="Center"/>
          </StackPanel>
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</Page>