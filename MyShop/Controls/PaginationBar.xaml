<UserControl x:Class="MyShop.Controls.PaginationBar"
             x:Name="Root"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
  <Grid>
    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" HorizontalAlignment="Left" Spacing="4">
      <TextBlock Text="Showing" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
      <TextBlock Text="{Binding DisplayFrom, ElementName=Root}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
      <TextBlock Text="-" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
      <TextBlock Text="{Binding DisplayTo, ElementName=Root}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
      <TextBlock Text="of" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
      <TextBlock Text="{Binding TotalItems, ElementName=Root}" FontWeight="SemiBold" Foreground="{ThemeResource TextFillColorPrimary}" FontSize="13"/>
      <TextBlock Text="{Binding ItemLabel, ElementName=Root}" Foreground="{ThemeResource TextFillColorSecondary}" FontSize="13"/>
    </StackPanel>

    <StackPanel Orientation="Horizontal" Spacing="8" HorizontalAlignment="Right">
      <Button Command="{Binding PreviousCommand, ElementName=Root}"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Foreground="{ThemeResource TextFillColorPrimary}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="{ThemeResource ControlCornerRadius}"
              Padding="10,8"
              MinWidth="40"
              MinHeight="40"
              ToolTipService.ToolTip="Previous page">
        <FontIcon Glyph="&#xE76B;" FontSize="14"/>
      </Button>
      <Border Background="{StaticResource AppAccentBrush}" CornerRadius="8" Padding="12,8" MinWidth="40" VerticalAlignment="Center">
        <TextBlock Text="{Binding CurrentPage, ElementName=Root}"
                   Foreground="White"
                   FontWeight="SemiBold"
                   HorizontalAlignment="Center"/>
      </Border>
      <TextBlock VerticalAlignment="Center" Foreground="{ThemeResource TextFillColorTertiary}" FontSize="13" Margin="4,0">
        <Run Text="/ "/><Run Text="{Binding TotalPages, ElementName=Root}"/>
      </TextBlock>
      <Button Command="{Binding NextCommand, ElementName=Root}"
              Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
              Foreground="{ThemeResource TextFillColorPrimary}"
              BorderBrush="{ThemeResource ControlStrokeColorDefaultBrush}"
              BorderThickness="1"
              CornerRadius="{ThemeResource ControlCornerRadius}"
              Padding="10,8"
              MinWidth="40"
              MinHeight="40"
              ToolTipService.ToolTip="Next page">
        <FontIcon Glyph="&#xE76C;" FontSize="14"/>
      </Button>
    </StackPanel>
  </Grid>
</UserControl>
